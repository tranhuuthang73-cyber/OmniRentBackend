@using OmniRentBackend.Models
@{
    ViewData["Title"] = "Tổng quan";
    Layout = "~/Views/Shared/_OwnerLayout.cshtml";
    var userName  = User.Identity?.Name ?? "";
    var myProductsCount = ViewBag.MyProductsCount ?? 0;
    var pendingBookingsCount = ViewBag.PendingBookingsCount ?? 0;
    var totalRevenue = ViewBag.TotalRevenue ?? 0;
    var monthlyRevenue = ViewBag.MonthlyRevenue ?? 0;
    var monthlyCommission = ViewBag.MonthlyCommission ?? 0;
    var unpaidTotalCommission = ViewBag.UnpaidTotalCommission ?? 0;
    var recentBookings = (List<Booking>)(ViewBag.RecentBookings ?? new List<Booking>());
}

<style>
    /* Info banner */
    .info-banner {
        background: var(--primary-light);
        border: 1px solid rgba(245,158,11,0.3);
        border-radius: 12px;
        padding: 1rem 1.25rem;
        color: #92400e;
        font-size: 0.875rem;
        display: flex; align-items: flex-start; gap: 0.6rem;
        margin-bottom: 1.75rem;
    }
    .info-banner i { color: var(--primary); font-size: 1.05rem; flex-shrink: 0; margin-top: 1px; }
    .info-banner strong { color: #78350f; }

    /* Stat cards */
    .stat-card {
        background: #fff;
        border: 1px solid var(--border-color);
        border-radius: 14px;
        padding: 1.4rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        transition: transform 0.2s, box-shadow 0.2s;
        box-shadow: var(--card-shadow);
    }
    .stat-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(15,23,42,0.1);
    }
    .stat-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        flex-shrink: 0;
    }
    .stat-card .stat-value {
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--text-primary);
        line-height: 1;
    }
    .stat-card .stat-label {
        font-size: 0.78rem;
        color: var(--text-muted);
        margin-top: 0.2rem;
        text-transform: uppercase;
        letter-spacing: 0.4px;
        font-weight: 600;
    }

    /* Quick actions */
    .quick-action-card {
        background: #fff;
        border: 1px solid var(--border-color);
        border-radius: 14px;
        padding: 1.5rem;
        text-align: center;
        height: 100%;
        transition: all 0.2s;
        box-shadow: var(--card-shadow);
    }
    .quick-action-card:hover {
        transform: translateY(-4px);
        border-color: var(--primary);
        box-shadow: 0 8px 24px rgba(245,158,11,0.12);
    }
    .qa-icon {
        width: 50px;
        height: 50px;
        border-radius: 12px;
        background: var(--primary-light);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        color: var(--primary);
        margin: 0 auto 0.9rem;
    }
    .qa-title { font-size: 0.9rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.3rem; }
    .qa-desc  { font-size: 0.78rem; color: var(--text-muted); margin: 0; }

    .section-heading {
        font-size: 1rem;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }
    .section-heading i { color: var(--primary); }

    .booking-table-card {
        background: #fff;
        border: 1px solid var(--border-color);
        border-radius: 14px;
        padding: 1.25rem;
        box-shadow: var(--card-shadow);
    }
    .booking-table-card table { margin-bottom: 0; }
    .booking-table-card th {
        color: var(--text-muted);
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.4px;
        border-bottom-color: var(--border-color);
    }
    .booking-table-card td {
        vertical-align: middle;
        color: var(--text-primary);
        font-size: 0.86rem;
    }
    .btn-owner-action {
        border: 0;
        border-radius: 8px;
        padding: 0.45rem 0.75rem;
        font-size: 0.78rem;
        font-weight: 700;
        color: #fff;
    }
    .btn-confirm-deposit { background: #16a34a; }
    .btn-complete-booking { background: #2563eb; }
</style>

<!-- Info banner -->
<div class="info-banner" id="owner-info-banner">
    <i class="bi bi-info-circle-fill"></i>
    <span>Chào mừng quay lại, <strong>@userName</strong>! Tại đây bạn có thể quản lý sản phẩm cho thuê của riêng mình.</span>
</div>

<!-- Stat cards -->
<div class="section-heading">
    <i class="bi bi-bar-chart-fill"></i> Tổng quan tài sản
</div>
<div class="row g-3 mb-5" id="owner-stat-cards">
    <div class="col-md-3 col-sm-6">
        <div class="stat-card" id="stat-my-products">
            <div class="stat-icon" style="background:#dcfce7;">
                <i class="bi bi-box-seam-fill" style="color:#16a34a;"></i>
            </div>
            <div>
                <div class="stat-value">@myProductsCount</div>
                <div class="stat-label">Tài sản của tôi</div>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="stat-card" id="stat-pending">
            <div class="stat-icon" style="background:var(--primary-light);">
                <i class="bi bi-hourglass-split" style="color:var(--primary);"></i>
            </div>
            <div>
                <div class="stat-value">@pendingBookingsCount</div>
                <div class="stat-label">Đơn chờ duyệt</div>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="stat-card" id="stat-revenue">
            <div class="stat-icon" style="background:#dbeafe;">
                <i class="bi bi-currency-dollar" style="color:#1d4ed8;"></i>
            </div>
            <div>
                <div class="stat-value">@totalRevenue.ToString("N0")đ</div>
                <div class="stat-label">Doanh thu tạm tính</div>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="stat-card" id="stat-commission">
            <div class="stat-icon" style="background:#fee2e2;">
                <i class="bi bi-percent" style="color:#dc2626;"></i>
            </div>
            <div>
                <div class="stat-value">@unpaidTotalCommission.ToString("N0")đ</div>
                <div class="stat-label">Phí còn phải trả hệ thống</div>
            </div>
        </div>
    </div>
</div>

<script>
    async function confirmDeposit(bookingId) {
        if (!confirm('Xác nhận đã nhận tiền cọc cho đơn này?')) return;
        await submitOwnerBookingAction(`/bookings/${bookingId}/confirm-deposit`, 'Đã xác nhận tiền cọc.');
    }

    async function completeBooking(bookingId) {
        if (!confirm('Xác nhận khách đã trả phần còn lại và hoàn tất đơn?')) return;
        await submitOwnerBookingAction(`/bookings/${bookingId}/complete`, 'Đã hoàn tất đơn thuê.');
    }

    async function submitOwnerBookingAction(url, successMessage) {
        try {
            const response = await fetch(url, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' }
            });

            if (!response.ok) {
                let message = 'Không thể cập nhật đơn thuê.';
                try {
                    const data = await response.json();
                    message = data.message || message;
                } catch { }
                alert(message);
                return;
            }

            alert(successMessage);
            window.location.reload();
        } catch {
            alert('Không thể kết nối máy chủ.');
        }
    }
</script>

<div class="section-heading">
    <i class="bi bi-receipt-cutoff"></i> Đơn thuê gần đây
</div>
<div class="booking-table-card mb-5">
    @if (recentBookings.Any())
    {
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Sản phẩm</th>
                        <th>Khách thuê</th>
                        <th>Cọc</th>
                        <th>Còn lại</th>
                        <th>Doanh thu đơn</th>
                        <th>Phí hệ thống 20%</th>
                        <th>Phí đã trả</th>
                        <th>Trạng thái</th>
                        <th class="text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var booking in recentBookings)
                    {
                        <tr id="booking-row-@booking.Id">
                            <td class="fw-bold">@(booking.Product?.Name ?? "Sản phẩm")</td>
                            <td>@(booking.Renter?.FullName ?? "Khách thuê")</td>
                            <td>@booking.DepositAmount.ToString("N0")đ</td>
                            <td>@booking.RemainingAmount.ToString("N0")đ</td>
                            <td>@booking.TotalPrice.ToString("N0")đ</td>
                            <td style="color:#dc2626; font-weight:700;">@((booking.TotalPrice * 0.20).ToString("N0"))đ</td>
                            <td>
                                @if (booking.CommissionPaid)
                                {
                                    <span class="badge bg-success">Đã thu</span>
                                }
                                else if (booking.Status == "COMPLETED")
                                {
                                    <span class="badge bg-danger">Chưa trả</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Chưa phát sinh</span>
                                }
                            </td>
                            <td>
                                @if (booking.PaymentStatus == "WAITING_CONFIRMATION")
                                {
                                    <span class="badge bg-warning text-dark">Chờ xác nhận cọc</span>
                                }
                                else if (booking.PaymentStatus == "PAID")
                                {
                                    <span class="badge bg-success">Đã nhận cọc</span>
                                }
                                else if (booking.PaymentStatus == "PAID_FULL")
                                {
                                    <span class="badge bg-primary">Hoàn tất</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@booking.PaymentStatus</span>
                                }
                            </td>
                            <td class="text-end">
                                @if (booking.PaymentStatus == "WAITING_CONFIRMATION")
                                {
                                    <button class="btn-owner-action btn-confirm-deposit" onclick="confirmDeposit('@booking.Id')">Xác nhận cọc</button>
                                }
                                else if (booking.Status == "APPROVED" || booking.Status == "ONGOING")
                                {
                                    <button class="btn-owner-action btn-complete-booking" onclick="completeBooking('@booking.Id')">Hoàn tất đơn</button>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="mt-3 small text-muted">
            Doanh thu tháng này: <strong>@monthlyRevenue.ToString("N0")đ</strong>.
            Phí hoa hồng tháng này chưa trả: <strong>@monthlyCommission.ToString("N0")đ</strong>.
            Tổng phí còn phải trả: <strong>@unpaidTotalCommission.ToString("N0")đ</strong>.
        </div>
    }
    else
    {
        <div class="text-muted">Chưa có đơn thuê nào cho tài sản của bạn.</div>
    }
</div>

<!-- Quick actions -->
<div class="section-heading">
    <i class="bi bi-lightning-fill"></i> Thao tác nhanh
</div>
<div class="row g-3">
    <div class="col-md-4 col-6">
        <a href="/OwnerDashboard/CreateProduct" class="text-decoration-none">
            <div class="quick-action-card">
                <div class="qa-icon"><i class="bi bi-plus-circle-fill"></i></div>
                <div class="qa-title">Đăng tài sản mới</div>
                <div class="qa-desc">Thêm sản phẩm cho thuê mới của bạn</div>
            </div>
        </a>
    </div>
    <div class="col-md-4 col-6">
        <a href="/OwnerDashboard/Products" class="text-decoration-none">
            <div class="quick-action-card">
                <div class="qa-icon"><i class="bi bi-box-seam"></i></div>
                <div class="qa-title">Quản lý tài sản</div>
                <div class="qa-desc">Xem, sửa và xóa các sản phẩm hiện có</div>
            </div>
        </a>
    </div>
    <div class="col-md-4 col-6">
        <a href="/" class="text-decoration-none">
            <div class="quick-action-card">
                <div class="qa-icon"><i class="bi bi-house-door-fill"></i></div>
                <div class="qa-title">Quay lại Trang chủ</div>
                <div class="qa-desc">Xem trang chủ hệ thống cho thuê</div>
            </div>
        </a>
    </div>
</div>
