@{
    Layout = null;
    var userName  = User.Identity?.Name ?? "";
    var userEmail = User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Owner Dashboard — OmniRent</title>
    <meta name="description" content="Trang quản lý tài sản cho thuê của chủ sở hữu OmniRent." />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

    <style>
        :root {
            --primary:       #f59e0b;
            --primary-hover: #d97706;
            --primary-light: #fef3c7;
            --navy:          #0f172a;
            --navy-2:        #1e293b;
            --body-bg:       #f8fafc;
            --text-main:      #000000;
            --text-sub:       #333333;
            --text-muted:     #666666;
            --border:        #e2e8f0;
            --card-shadow:   0 1px 3px rgba(15,23,42,0.07), 0 4px 16px rgba(15,23,42,0.04);
        }

        *, *::before, *::after { box-sizing: border-box; }

        html, body {
            min-height: 100vh;
            margin: 0;
            font-family: 'Inter', sans-serif;
            background-color: var(--body-bg);
            color: var(--text-main);
        }

        /* ===================== NAVBAR ===================== */
        .omni-navbar {
            background: var(--navy);
            padding: 0.8rem 0;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: 0 1px 0 rgba(255,255,255,0.06);
        }
        .brand-icon {
            width: 34px; height: 34px;
            background: var(--primary);
            border-radius: 9px;
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0;
        }
        .brand-icon i { color: var(--navy); font-size: 1rem; }
        .brand-name {
            font-size: 1.15rem; font-weight: 800;
            color: #ffffff;
            text-decoration: none;
        }
        .role-badge {
            background: rgba(245,158,11,0.15);
            border: 1px solid rgba(245,158,11,0.35);
            color: var(--primary);
            border-radius: 20px;
            font-size: 0.72rem; font-weight: 700;
            padding: 0.25rem 0.75rem;
            letter-spacing: 0.05em;
        }
        .btn-logout {
            background: rgba(255,255,255,0.07);
            border: 1px solid rgba(255,255,255,0.12);
            color: #94a3b8;
            border-radius: 8px;
            font-size: 0.82rem; font-weight: 600;
            padding: 0.4rem 0.9rem;
            cursor: pointer;
            display: inline-flex; align-items: center; gap: 0.35rem;
            transition: all 0.2s;
        }
        .btn-logout:hover {
            background: rgba(255,255,255,0.12);
            color: #e2e8f0;
            border-color: rgba(255,255,255,0.2);
        }

        /* ===================== HERO BANNER ===================== */
        .owner-banner {
            background: var(--navy);
            padding: 3rem 0 2.5rem;
            margin-bottom: 0;
            position: relative;
            overflow: hidden;
        }
        .owner-banner::before {
            content: '';
            position: absolute;
            width: 400px; height: 400px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(245,158,11,0.12), transparent 65%);
            top: -100px; right: -50px;
            pointer-events: none;
        }
        .owner-banner h1 {
            font-size: 1.75rem; font-weight: 800;
            color: #fff;
            display: flex; align-items: center; gap: 0.65rem;
            margin-bottom: 0.4rem;
        }
        .owner-banner p { color: #64748b; font-size: 0.9rem; margin: 0; }
        .owner-banner strong { color: #e2e8f0; }

        .icon-circle {
            width: 42px; height: 42px;
            background: var(--primary);
            border-radius: 11px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.1rem;
            color: var(--navy);
            flex-shrink: 0;
            box-shadow: 0 4px 12px rgba(245,158,11,0.4);
        }

        /* ===================== CONTENT ===================== */
        .content-area {
            background: var(--body-bg);
            padding: 2rem 0;
        }

        /* Info banner */
        .info-banner {
            background: var(--primary-light);
            border: 1px solid rgba(245,158,11,0.3);
            border-radius: 12px;
            padding: 1rem 1.25rem;
            color: #92400e;
            font-size: 0.875rem;
            display: flex; align-items: flex-start; gap: 0.6rem;
            margin-bottom: 1.75rem;
        }
        .info-banner i { color: var(--primary); font-size: 1.05rem; flex-shrink: 0; margin-top: 1px; }
        .info-banner strong { color: #78350f; }

        /* Stat cards */
        .stat-card {
            background: #fff;
            border: 1.5px solid var(--border);
            border-radius: 14px;
            padding: 1.4rem;
            display: flex; align-items: center; gap: 1rem;
            transition: transform 0.2s, box-shadow 0.2s;
            box-shadow: var(--card-shadow);
        }
        .stat-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 24px rgba(15,23,42,0.1);
        }
        .stat-icon {
            width: 48px; height: 48px;
            border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.3rem;
            flex-shrink: 0;
        }
        .stat-card .stat-value {
            font-size: 1.5rem; font-weight: 800;
            color: var(--text-main);
            line-height: 1;
        }
        .stat-card .stat-label {
            font-size: 0.78rem;
            color: var(--text-muted);
            margin-top: 0.2rem;
            text-transform: uppercase;
            letter-spacing: 0.4px;
            font-weight: 600;
        }

        /* Quick actions */
        .quick-action-card {
            background: #fff;
            border: 1.5px solid var(--border);
            border-radius: 14px;
            padding: 1.5rem;
            text-align: center;
            height: 100%;
            transition: all 0.2s;
            box-shadow: var(--card-shadow);
        }
        .quick-action-card:hover {
            transform: translateY(-4px);
            border-color: var(--primary);
            box-shadow: 0 8px 24px rgba(245,158,11,0.12);
        }
        .qa-icon {
            width: 50px; height: 50px;
            border-radius: 12px;
            background: var(--primary-light);
            display: flex; align-items: center; justify-content: center;
            font-size: 1.3rem;
            color: var(--primary);
            margin: 0 auto 0.9rem;
        }
        .qa-title { font-size: 0.9rem; font-weight: 700; color: var(--text-main); margin-bottom: 0.3rem; }
        .qa-desc  { font-size: 0.78rem; color: var(--text-muted); margin: 0; }

        .section-heading {
            font-size: 1rem;
            font-weight: 700;
            color: var(--text-main);
            margin-bottom: 1rem;
            display: flex; align-items: center; gap: 0.4rem;
        }
        .section-heading i { color: var(--primary); }
    </style>
</head>
<body>

    <!-- Navbar -->
    <nav class="omni-navbar">
        <div class="container d-flex align-items-center justify-content-between">
            <a href="/" class="d-flex align-items-center gap-2 text-decoration-none">
                <div class="brand-icon"><i class="bi bi-building-fill"></i></div>
                <span class="brand-name">OmniRent</span>
            </a>
            <div class="d-flex align-items-center gap-3">
                <span class="role-badge">🏠 OWNER</span>
                <span style="color:#64748b; font-size:0.82rem;">@userName</span>
                <form method="post" action="/Account/Logout" style="margin:0;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-logout" id="logout-btn">
                        <i class="bi bi-box-arrow-right"></i> Đăng xuất
                    </button>
                </form>
            </div>
        </div>
    </nav>

    <!-- Hero banner -->
    <div class="owner-banner">
        <div class="container position-relative">
            <h1>
                <span class="icon-circle"><i class="bi bi-house-fill"></i></span>
                Owner Dashboard
            </h1>
            <p>Xin chào, <strong>@userName</strong> — đây là không gian quản lý tài sản cho thuê của bạn.</p>
        </div>
    </div>

    <!-- Main content -->
    <div class="content-area">
        <div class="container" id="owner-dashboard-main">

            <!-- Info banner -->
            <div class="info-banner" id="owner-info-banner">
                <i class="bi bi-info-circle-fill"></i>
                <span>Đây là trang <strong>Owner Dashboard</strong> của đồ án. Các chức năng quản lý tài sản, xem đơn thuê, lịch sử... sẽ được phát triển trong các sprint tiếp theo.</span>
            </div>

            <!-- Stat cards -->
            <div class="section-heading">
                <i class="bi bi-bar-chart-fill"></i> Tổng quan
            </div>
            <div class="row g-3 mb-4" id="owner-stat-cards">
                <div class="col-md-4 col-sm-6">
                    <div class="stat-card" id="stat-my-products">
                        <div class="stat-icon" style="background:#dcfce7;">
                            <i class="bi bi-box-seam-fill" style="color:#16a34a;"></i>
                        </div>
                        <div>
                            <div class="stat-value">—</div>
                            <div class="stat-label">Tài sản của tôi</div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4 col-sm-6">
                    <div class="stat-card" id="stat-pending">
                        <div class="stat-icon" style="background:var(--primary-light);">
                            <i class="bi bi-hourglass-split" style="color:var(--primary);"></i>
                        </div>
                        <div>
                            <div class="stat-value">—</div>
                            <div class="stat-label">Đơn chờ duyệt</div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4 col-sm-6">
                    <div class="stat-card" id="stat-revenue">
                        <div class="stat-icon" style="background:#dbeafe;">
                            <i class="bi bi-currency-dollar" style="color:#1d4ed8;"></i>
                        </div>
                        <div>
                            <div class="stat-value">—</div>
                            <div class="stat-label">Doanh thu (VNĐ)</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Quick actions -->
            <div class="section-heading">
                <i class="bi bi-lightning-fill"></i> Thao tác nhanh
            </div>
            <div class="row g-3">
                <div class="col-md-3 col-6">
                    <div class="quick-action-card">
                        <div class="qa-icon"><i class="bi bi-plus-circle-fill"></i></div>
                        <div class="qa-title">Thêm tài sản</div>
                        <div class="qa-desc">Đăng sản phẩm cho thuê mới</div>
                    </div>
                </div>
                <div class="col-md-3 col-6">
                    <div class="quick-action-card">
                        <div class="qa-icon"><i class="bi bi-receipt-cutoff"></i></div>
                        <div class="qa-title">Xem đơn thuê</div>
                        <div class="qa-desc">Quản lý các đơn hàng</div>
                    </div>
                </div>
                <div class="col-md-3 col-6">
                    <div class="quick-action-card">
                        <div class="qa-icon"><i class="bi bi-graph-up-arrow"></i></div>
                        <div class="qa-title">Thống kê</div>
                        <div class="qa-desc">Xem doanh thu & báo cáo</div>
                    </div>
                </div>
                <div class="col-md-3 col-6">
                    <div class="quick-action-card">
                        <div class="qa-icon"><i class="bi bi-person-gear"></i></div>
                        <div class="qa-title">Hồ sơ</div>
                        <div class="qa-desc">Cập nhật thông tin cá nhân</div>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
