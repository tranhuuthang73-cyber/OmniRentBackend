@{
    Layout = null;
    var userName  = User.Identity?.Name ?? "";
    var userEmail = User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Owner Dashboard — OmniRent</title>
    <meta name="description" content="Trang quản lý tài sản cho thuê của chủ sở hữu OmniRent." />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
          crossorigin="anonymous" />
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
          rel="stylesheet" />

    <style>
        :root {
            --brand:    #6C63FF;
            --brand-lt: #9c91ff;
            --dark-1:   #0f0c29;
            --dark-2:   #1a1a3e;
            --dark-3:   #24243e;
            --text-main:#f0eeff;
            --text-sub: #a89fd8;
            --card-bg:  rgba(255,255,255,0.06);
            --card-bd:  rgba(255,255,255,0.11);
            --owner-accent: #43e97b;
        }
        html, body { min-height: 100vh; margin: 0; font-family: 'Inter', sans-serif; color: var(--text-main); }
        body { background: linear-gradient(135deg, var(--dark-1) 0%, var(--dark-2) 55%, var(--dark-3) 100%); }

        /* Navbar */
        .omni-navbar {
            background: rgba(15,12,41,0.8);
            backdrop-filter: blur(18px);
            border-bottom: 1px solid var(--card-bd);
            padding: 0.7rem 0;
            position: sticky; top: 0; z-index: 100;
        }
        .brand-icon {
            width: 34px; height: 34px;
            background: linear-gradient(135deg, var(--brand), var(--brand-lt));
            border-radius: 9px;
            display: flex; align-items: center; justify-content: center;
            box-shadow: 0 4px 12px rgba(108,99,255,0.4);
        }
        .brand-icon i { color: #fff; font-size: 1rem; }
        .brand-name {
            font-size: 1.2rem; font-weight: 700;
            background: linear-gradient(90deg, #fff, var(--brand-lt));
            -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
        }
        .role-badge {
            background: rgba(67,233,123,0.15);
            border: 1px solid rgba(67,233,123,0.35);
            color: var(--owner-accent);
            border-radius: 20px;
            font-size: 0.75rem; font-weight: 700;
            padding: 0.25rem 0.75rem;
            letter-spacing: 0.06em;
        }
        .btn-logout {
            background: rgba(255,255,255,0.07);
            border: 1px solid rgba(255,255,255,0.14);
            color: var(--text-sub);
            border-radius: 8px;
            font-size: 0.84rem; font-weight: 600;
            padding: 0.38rem 0.9rem;
            cursor: pointer;
            display: inline-flex; align-items: center; gap: 0.35rem;
            transition: background 0.2s;
        }
        .btn-logout:hover { background: rgba(255,255,255,0.13); color: var(--text-main); }

        /* Page header */
        .page-header {
            padding: 3rem 0 2rem;
            border-bottom: 1px solid var(--card-bd);
            margin-bottom: 2.5rem;
        }
        .page-header h1 {
            font-size: 2rem; font-weight: 800;
            display: flex; align-items: center; gap: 0.6rem;
            margin-bottom: 0.35rem;
        }
        .icon-circle {
            width: 44px; height: 44px;
            background: linear-gradient(135deg, var(--owner-accent), #a8f7c1);
            border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.2rem;
            box-shadow: 0 6px 18px rgba(67,233,123,0.35);
        }
        .page-header p { color: var(--text-sub); margin: 0; font-size: 0.95rem; }

        /* Stat cards */
        .stat-card {
            background: var(--card-bg);
            border: 1px solid var(--card-bd);
            border-radius: 14px;
            padding: 1.5rem;
            display: flex; align-items: center; gap: 1rem;
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .stat-card:hover { transform: translateY(-4px); box-shadow: 0 12px 30px rgba(67,233,123,0.12); }
        .stat-icon { width: 50px; height: 50px; border-radius: 13px; display: flex; align-items: center; justify-content: center; font-size: 1.4rem; flex-shrink: 0; }
        .stat-card .stat-value { font-size: 1.6rem; font-weight: 800; line-height: 1; }
        .stat-card .stat-label { font-size: 0.8rem; color: var(--text-sub); margin-top: 0.15rem; }

        .info-banner {
            background: rgba(67,233,123,0.09);
            border: 1px solid rgba(67,233,123,0.28);
            border-radius: 12px;
            padding: 1.1rem 1.3rem;
            color: var(--text-sub);
            font-size: 0.9rem;
            display: flex; align-items: center; gap: 0.6rem;
        }
        .info-banner i { color: var(--owner-accent); font-size: 1.1rem; flex-shrink: 0; }
    </style>
</head>
<body>

    <!-- Navbar -->
    <nav class="omni-navbar">
        <div class="container d-flex align-items-center justify-content-between">
            <a href="/" class="d-flex align-items-center gap-2 text-decoration-none">
                <div class="brand-icon"><i class="bi bi-building-fill"></i></div>
                <span class="brand-name">OmniRent</span>
            </a>
            <div class="d-flex align-items-center gap-3">
                <span class="role-badge">🏠 OWNER</span>
                <span style="color:var(--text-sub); font-size:0.85rem;">@userName</span>
                <form method="post" action="/auth/logout" style="margin:0;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-logout" id="logout-btn">
                        <i class="bi bi-box-arrow-right"></i> Đăng xuất
                    </button>
                </form>
            </div>
        </div>
    </nav>

    <!-- Content -->
    <main class="container" id="owner-dashboard-main">

        <!-- Page header -->
        <div class="page-header" id="owner-page-header">
            <h1>
                <span class="icon-circle"><i class="bi bi-house-fill"></i></span>
                Owner Dashboard
            </h1>
            <p>Xin chào, <strong style="color:var(--text-main);">@userName</strong> — đây là không gian quản lý tài sản cho thuê của bạn.</p>
        </div>

        <!-- Info banner -->
        <div class="info-banner mb-4" id="owner-info-banner">
            <i class="bi bi-info-circle-fill"></i>
            <span>Đây là trang <strong style="color:var(--text-main);">Owner Dashboard</strong> sơ khai của đồ án. Các chức năng quản lý tài sản, xem đơn thuê, lịch sử... sẽ được phát triển trong các sprint tiếp theo.</span>
        </div>

        <!-- Placeholder stat cards -->
        <div class="row g-3" id="owner-stat-cards">
            <div class="col-md-4 col-sm-6">
                <div class="stat-card" id="stat-my-products">
                    <div class="stat-icon" style="background:rgba(67,233,123,0.15);">
                        <i class="bi bi-box-seam-fill" style="color:#43e97b;"></i>
                    </div>
                    <div>
                        <div class="stat-value">—</div>
                        <div class="stat-label">Tài sản của tôi</div>
                    </div>
                </div>
            </div>
            <div class="col-md-4 col-sm-6">
                <div class="stat-card" id="stat-pending">
                    <div class="stat-icon" style="background:rgba(255,193,7,0.15);">
                        <i class="bi bi-hourglass-split" style="color:#ffc107;"></i>
                    </div>
                    <div>
                        <div class="stat-value">—</div>
                        <div class="stat-label">Đơn chờ duyệt</div>
                    </div>
                </div>
            </div>
            <div class="col-md-4 col-sm-6">
                <div class="stat-card" id="stat-revenue">
                    <div class="stat-icon" style="background:rgba(108,99,255,0.18);">
                        <i class="bi bi-currency-dollar" style="color:#9c91ff;"></i>
                    </div>
                    <div>
                        <div class="stat-value">—</div>
                        <div class="stat-label">Doanh thu (VNĐ)</div>
                    </div>
                </div>
            </div>
        </div>

    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-YvpcrYf0tY3lHB60NNkmXc4s9bIOgUxi8T/jzmLCqQhN6SREfMQ2V3bM6cQBQKB"
            crossorigin="anonymous"></script>
</body>
</html>
