@using OmniRentBackend.Models
@using System.Security.Claims
@model User
@{
    Layout = null;
    var bookings = (List<Booking>)(ViewBag.Bookings ?? new List<Booking>());
    var successMessage = TempData["SuccessMessage"] as string;
    var isAuthenticated = User.Identity != null && User.Identity.IsAuthenticated;
    var currentAvatar = Model.AvatarUrl ?? "";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Trang cá nhân — OmniRent</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>
        :root, [data-theme="light"] {
            --primary:        #eab308; /* Premium Gold Yellow */
            --primary-hover:  #ca8a04;
            --primary-light:  #fef9c3;
            --navy:           #09090b; /* Pure Obsidian Black */
            --navy-2:         #18181b; /* Dark zinc */
            --accent:         #eab308;
            --body-bg:        #fafafa; /* Sleek light gray */
            --section-alt:    #ffffff;
            --text-primary:   #09090b;
            --text-secondary: #4b5563;
            --text-muted:     #9ca3af;
            --border:         #e5e7eb;
            --card-bg:        #ffffff;
            --card-shadow:    0 4px 20px rgba(9,9,11,0.03);
            --navbar-bg:      rgba(255, 255, 255, 0.85);
            --navbar-shadow:  0 1px 2px rgba(9,9,11,0.05);
            --footer-bg:      #09090b;
            --footer-text:    #9ca3af;
            --footer-heading:  #f3f4f6;
            --footer-border:  #1f2937;
        }

        [data-theme="dark"] {
            --primary:        #facc15; /* Vibrant Gold Yellow */
            --primary-hover:  #eab308;
            --primary-light:  rgba(250,204,21,0.1);
            --navy:           #f3f4f6; /* Off-white text */
            --navy-2:         #e5e7eb;
            --accent:         #fbbf24;
            --body-bg:        #09090b; /* Pure Black Background */
            --section-alt:    #121214; /* Charcoal background */
            --text-primary:   #f3f4f6;
            --text-secondary: #9ca3af;
            --text-muted:     #6b7280;
            --border:         #1f2937;
            --card-bg:        #18181b;
            --card-shadow:    0 10px 30px rgba(0,0,0,0.3);
            --navbar-bg:      rgba(9, 9, 11, 0.85);
            --navbar-shadow:  0 1px 0 rgba(255,255,255,0.05);
            --footer-bg:      #020203;
            --footer-text:    #6b7280;
            --footer-heading:  #f3f4f6;
            --footer-border:  #18181b;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--body-bg);
            color: var(--text-primary);
            min-height: 100vh;
            margin: 0; padding: 0;
            overflow-x: hidden;
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        /* Navbar */
        .navbar-custom {
            background: var(--navbar-bg);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border);
            padding: 0.875rem 0;
            position: fixed;
            top: 0; width: 100%;
            z-index: 1000;
            box-shadow: var(--navbar-shadow);
            transition: all 0.3s ease;
        }
        .navbar-brand {
            font-weight: 800; font-size: 1.4rem;
            color: var(--text-primary) !important;
            display: flex; align-items: center; gap: 0.5rem;
            text-decoration: none;
        }
        .brand-icon { color: var(--primary); font-size: 1.6rem; }
        
        .nav-link-custom {
            color: var(--text-secondary) !important;
            font-weight: 500;
            font-size: 0.9rem;
            padding: 0.5rem 0.85rem !important;
            border-radius: 6px;
            transition: all 0.2s;
            text-decoration: none;
        }
        .nav-link-custom:hover {
            color: var(--primary) !important;
            background: var(--primary-light);
        }

        .btn-nav-outline {
            color: var(--text-secondary);
            border: 1.5px solid var(--border);
            border-radius: 8px;
            padding: 0.45rem 1.1rem;
            font-size: 0.85rem;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
        }
        .btn-nav-outline:hover {
            border-color: var(--primary);
            color: var(--primary);
            background: rgba(245,158,11,0.06);
        }

        .btn-nav-primary {
            background: var(--primary);
            color: var(--navy) !important;
            border: none;
            border-radius: 8px;
            padding: 0.45rem 1.2rem;
            font-size: 0.85rem;
            font-weight: 700;
            text-decoration: none;
            transition: all 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
        }
        .btn-nav-primary:hover {
            background: var(--primary-hover);
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(245,158,11,0.4);
        }

        .cart-icon {
            color: var(--text-secondary);
            font-size: 1.25rem;
            text-decoration: none;
            position: relative;
            transition: color 0.2s;
        }
        .cart-icon:hover { color: var(--primary); }

        .theme-toggle {
            background: transparent;
            border: 1.5px solid var(--border);
            border-radius: 10px;
            width: 38px; height: 38px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 1.1rem;
            color: var(--text-secondary);
            transition: all 0.25s;
            flex-shrink: 0;
        }
        .theme-toggle:hover {
            border-color: var(--primary);
            color: var(--primary);
            background: var(--primary-light);
        }
        .theme-toggle .bi-moon-fill { display: inline; }
        .theme-toggle .bi-sun-fill { display: none; }
        [data-theme="dark"] .theme-toggle .bi-moon-fill { display: none; }
        [data-theme="dark"] .theme-toggle .bi-sun-fill { display: inline; }

        /* Content & Profile Layout */
        .main-container { margin-top: 120px; padding-bottom: 80px; }

        .profile-sidebar {
            background: var(--card-bg);
            border: 1.5px solid var(--border);
            border-radius: 24px;
            padding: 2.5rem 2rem;
            box-shadow: var(--card-shadow);
            text-align: center;
            position: sticky;
            top: 120px;
        }

        .profile-avatar-wrapper {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            margin: 0 auto 1.5rem;
            position: relative;
            border: 3px solid var(--primary);
            background: var(--body-bg);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 3rem;
            font-weight: 800;
            color: var(--primary);
            overflow: hidden;
            box-shadow: 0 8px 16px rgba(0,0,0,0.1);
        }
        .profile-avatar-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .profile-name {
            font-size: 1.35rem;
            font-weight: 800;
            color: var(--text-primary);
            margin-bottom: 0.25rem;
        }

        .profile-role-badge {
            display: inline-block;
            font-size: 0.75rem;
            font-weight: 700;
            padding: 0.35rem 0.85rem;
            border-radius: 50px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 1.25rem;
        }
        .role-renter { background: rgba(59,130,246,0.1); color: #3b82f6; }
        .role-owner { background: rgba(234,179,8,0.1); color: var(--primary); }
        .role-admin { background: rgba(239,68,68,0.1); color: #ef4444; }

        .trust-score-container {
            background: var(--body-bg);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 1rem;
            margin-bottom: 1.5rem;
        }

        .profile-nav-tabs {
            border-bottom: 1px solid var(--border);
            margin-bottom: 2rem;
            gap: 1.5rem;
        }
        .profile-nav-link {
            color: var(--text-secondary);
            font-weight: 600;
            font-size: 1rem;
            padding: 0.75rem 0.5rem;
            border: none;
            background: transparent;
            position: relative;
            transition: color 0.2s;
        }
        .profile-nav-link:hover {
            color: var(--primary);
        }
        .profile-nav-link.active {
            color: var(--primary);
        }
        .profile-nav-link.active::after {
            content: '';
            position: absolute;
            bottom: -1px;
            left: 0;
            width: 100%;
            height: 3px;
            background: var(--primary);
            border-radius: 3px 3px 0 0;
        }

        .card-custom {
            background: var(--card-bg);
            border: 1.5px solid var(--border);
            border-radius: 20px;
            padding: 2.25rem;
            box-shadow: var(--card-shadow);
        }

        .booking-card {
            background: var(--card-bg);
            border: 1.5px solid var(--border);
            border-radius: 20px;
            padding: 2rem;
            margin-bottom: 1.5rem;
            transition: all 0.25s;
            box-shadow: var(--card-shadow);
        }
        .booking-card:hover {
            border-color: var(--primary);
            box-shadow: 0 8px 24px rgba(245,158,11,0.06);
            transform: translateY(-2px);
        }

        .product-img {
            width: 100%; height: 130px;
            object-fit: cover; border-radius: 12px;
            border: 1px solid var(--border);
            background: var(--body-bg);
        }

        .badge-status {
            font-size: 0.8rem; padding: 0.45rem 0.9rem;
            border-radius: 50px; font-weight: 700;
        }

        .form-label-custom {
            font-weight: 700;
            color: var(--text-secondary);
            font-size: 0.82rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 0.5rem;
        }
        .form-control-custom {
            background: var(--body-bg) !important;
            border: 1.5px solid var(--border) !important;
            color: var(--text-primary) !important;
            border-radius: 12px !important;
            padding: 0.75rem 1rem !important;
            font-size: 0.92rem !important;
            transition: all 0.2s !important;
        }
        .form-control-custom:focus {
            border-color: var(--primary) !important;
            box-shadow: 0 0 0 3px rgba(234,179,8,0.15) !important;
        }

        /* Star Rating in Modal */
        .star-rating i {
            cursor: pointer;
            transition: color 0.15s ease-in-out;
            color: #cbd5e1;
        }
        .star-rating i:hover,
        .star-rating i.active {
            color: var(--primary) !important;
        }

        .modal-content-custom {
            background-color: var(--card-bg) !important;
            border: 1px solid var(--border) !important;
            color: var(--text-primary) !important;
            border-radius: 20px !important;
            box-shadow: var(--card-shadow) !important;
        }
        .modal-header-custom {
            border-bottom: 1px solid var(--border) !important;
        }
        .modal-footer-custom {
            border-top: 1px solid var(--border) !important;
        }

        /* User dropdown */
        .user-dropdown-btn {
            background: transparent;
            border: 0;
            color: var(--text-primary);
            padding: 0;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-weight: 600;
            font-size: 0.88rem;
        }

        footer {
            background: var(--footer-bg);
            border-top: 1px solid var(--footer-border);
            padding: 4rem 0 2rem;
            margin-top: 5rem;
            transition: background-color 0.3s ease;
        }
        .footer-brand {
            font-size: 1.5rem;
            font-weight: 800;
            color: #ffffff;
            display: flex;
            align-items: center;
            gap: 0.4rem;
            margin-bottom: 0.75rem;
        }
        .footer-text { color: #64748b; max-width: 280px; font-size: 0.875rem; line-height: 1.7; }
        .footer-title { font-weight: 700; color: #e2e8f0; font-size: 0.85rem; margin-bottom: 1.25rem; text-transform: uppercase; letter-spacing: 0.5px; }
        .footer-links { list-style: none; padding: 0; margin: 0; }
        .footer-links li { margin-bottom: 0.65rem; }
        .footer-links a { color: #64748b; text-decoration: none; font-size: 0.875rem; transition: color 0.2s; }
        .footer-links a:hover { color: var(--primary); }
        .social-icon {
            width: 36px; height: 36px;
            border-radius: 8px;
            background: rgba(255,255,255,0.06);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: #64748b;
            font-size: 1rem;
            text-decoration: none;
            transition: all 0.2s;
        }
        .social-icon:hover { background: var(--primary); color: var(--navy); }
    </style>
</head>
<body>

    <!-- ======================== NAVBAR ======================== -->
    <nav class="navbar navbar-expand-lg navbar-custom">
        <div class="container">
            <a class="navbar-brand" href="/">
                <i class="bi bi-building-fill brand-icon"></i> OmniRent
            </a>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto gap-1">
                    <li class="nav-item">
                        <a class="nav-link-custom py-2 px-3 d-inline-block rounded-3" href="/">Trang chủ</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link-custom py-2 px-3 d-inline-block rounded-3" href="/#productsSection">Khám phá</a>
                    </li>
                </ul>
                <div class="d-flex gap-3 mt-3 mt-lg-0 align-items-center">
                    <!-- Theme Toggle -->
                    <button class="theme-toggle" id="themeToggle" title="Chuyển chế độ sáng/tối">
                        <i class="bi bi-moon-fill"></i>
                        <i class="bi bi-sun-fill"></i>
                    </button>

                    <!-- Cart -->
                    <a href="/Home/Cart" class="cart-icon position-relative me-1">
                        <i class="bi bi-cart3"></i>
                        <span id="cartBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.6rem; display: none;">0</span>
                    </a>

                    @if (isAuthenticated)
                    {
                        <!-- User Profile Dropdown -->
                        <div class="dropdown">
                            <button class="user-dropdown-btn dropdown-toggle" type="button" id="userMenuButton" data-bs-toggle="dropdown" aria-expanded="false">
                                <div class="profile-avatar" style="width: 32px; height: 32px; border-radius: 50%; background: var(--primary); color: var(--navy); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.85rem; overflow: hidden; border: 1.5px solid var(--primary);">
                                    @if (!string.IsNullOrEmpty(currentAvatar))
                                    {
                                        <img src="@currentAvatar" alt="Avatar" style="width:100%; height:100%; object-fit:cover;" />
                                    }
                                    else
                                    {
                                        @Model.FullName.Substring(0, 1).ToUpper()
                                    }
                                </div>
                                <span class="d-none d-md-inline">@Model.FullName</span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end p-2 border-0" aria-labelledby="userMenuButton" style="background: var(--card-bg); box-shadow: var(--card-shadow); border-radius: 12px; min-width: 200px;">

                                <li>
                                    <a class="dropdown-item rounded-3 py-2 px-3 d-flex align-items-center gap-2 active" href="/Account/Profile" style="font-size: 0.85rem; font-weight: 500;">
                                        <i class="bi bi-person-circle"></i> Trang cá nhân & Lịch sử
                                    </a>
                                </li>
                                @if (User.IsInRole("OWNER"))
                                {
                                    <li>
                                        <a class="dropdown-item rounded-3 py-2 px-3 d-flex align-items-center gap-2" href="/OwnerDashboard" style="color: var(--text-primary); font-size: 0.85rem; font-weight: 500;">
                                            <i class="bi bi-house-door-fill text-primary"></i> Quản lý tài sản
                                        </a>
                                    </li>
                                }
                                @if (User.IsInRole("ADMIN"))
                                {
                                    <li>
                                        <a class="dropdown-item rounded-3 py-2 px-3 d-flex align-items-center gap-2" href="/AdminDashboard" style="color: var(--text-primary); font-size: 0.85rem; font-weight: 500;">
                                            <i class="bi bi-shield-lock-fill text-primary"></i> Trang quản trị
                                        </a>
                                    </li>
                                }
                                <li><hr class="dropdown-divider" style="border-color: var(--border);"></li>
                                <li>
                                    <form action="/Account/Logout" method="post" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item rounded-3 py-2 px-3 text-danger d-flex align-items-center gap-2 bg-transparent border-0 w-100 text-start" style="font-size: 0.85rem; font-weight: 600;">
                                            <i class="bi bi-box-arrow-right"></i> Đăng xuất
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a href="/Account/Login" class="btn-nav-outline">Đăng nhập</a>
                        <a href="/Account/Register" class="btn-nav-primary"><i class="bi bi-person-plus"></i> Đăng ký</a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <!-- ======================== MAIN LAYOUT ======================== -->
    <div class="container main-container">
        <!-- Toast Alerts -->
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success alert-dismissible fade show rounded-4 mb-4 border-0 p-3 shadow-sm" role="alert" style="background: rgba(16,185,129,0.1); color: #10b981;">
                <i class="bi bi-check-circle-fill me-2"></i> @successMessage
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="row g-4">
            <!-- Left Panel: Profile Quick Info -->
            <div class="col-lg-4">
                <div class="profile-sidebar">
                    <div class="profile-avatar-wrapper">
                        @if (!string.IsNullOrEmpty(currentAvatar))
                        {
                            <img id="profileSidebarAvatar" src="@currentAvatar" alt="Avatar" />
                        }
                        else
                        {
                            <span>@Model.FullName.Substring(0, 1).ToUpper()</span>
                        }
                    </div>

                    <h3 class="profile-name">@Model.FullName</h3>
                    <div class="profile-role-badge role-@(Model.Role.ToLower())">
                        @Model.Role
                    </div>

                    <div class="trust-score-container text-start">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span style="font-size: 0.78rem; font-weight: 700; color: var(--text-secondary); text-transform: uppercase;">Điểm uy tín</span>
                            <span style="font-size: 0.95rem; font-weight: 800; color: var(--primary);">@Model.RenterTrustScore.ToString("F1") / 100</span>
                        </div>
                        <div class="progress" style="height: 6px; background: var(--border); border-radius: 10px;">
                            <div class="progress-bar bg-warning" role="progressbar" style="width: @(Model.RenterTrustScore)%; border-radius: 10px;" aria-valuenow="@Model.RenterTrustScore" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                        <small class="d-block mt-2" style="font-size: 0.7rem; line-height: 1.4; color: rgba(255, 255, 255, 0.85);">Điểm uy tín cao giúp bạn dễ dàng thuê tài sản giá trị mà không cần đặt cọc lớn.</small>
                    </div>

                    <div class="text-start" style="font-size: 0.85rem; border-top: 1px solid var(--border); padding-top: 1.25rem; color: var(--text-secondary);">
                        <div class="mb-2"><i class="bi bi-envelope me-2 text-primary"></i> @Model.Email</div>
                        @if (!string.IsNullOrEmpty(Model.Phone))
                        {
                            <div class="mb-2"><i class="bi bi-telephone me-2 text-primary"></i> @Model.Phone</div>
                        }
                        @if (!string.IsNullOrEmpty(Model.Address))
                        {
                            <div><i class="bi bi-geo-alt me-2 text-danger"></i> @Model.Address</div>
                        }
                    </div>
                </div>
            </div>

            <!-- Right Panel: Tabs for details -->
            <div class="col-lg-8">
                <!-- Navigation Tabs -->
                <div class="d-flex profile-nav-tabs">
                    <button class="profile-nav-link active" id="tabRentalHistoryBtn" onclick="switchTab('rentalHistory')">
                        <i class="bi bi-box-seam me-2"></i> Lịch sử thuê đồ
                    </button>
                    <button class="profile-nav-link" id="tabEditProfileBtn" onclick="switchTab('editProfile')">
                        <i class="bi bi-person-gear me-2"></i> Thiết lập tài khoản
                    </button>
                </div>

                <!-- Tab content 1: Rental History -->
                <div id="tabRentalHistory" class="tab-pane-custom">
                    @if (bookings.Any())
                    {
                        foreach (var booking in bookings)
                        {
                            <div class="booking-card">
                                <div class="row g-4 align-items-center">
                                    <div class="col-md-3">
                                        @{
                                            var imagesList = new List<string>();
                                            try {
                                                if (booking.Product != null && !string.IsNullOrEmpty(booking.Product.ImagesJson)) {
                                                    imagesList = System.Text.Json.JsonSerializer.Deserialize<List<string>>(booking.Product.ImagesJson) ?? new List<string>();
                                                }
                                            } catch { }
                                            var mainImg = imagesList.Any() ? imagesList.First() : "https://images.unsplash.com/photo-1522771739844-6a9f6d5f14af?auto=format&fit=crop&w=600&q=80";
                                        }
                                        <img src="@mainImg" alt="@(booking.Product?.Name ?? "Tài sản")" class="product-img" onerror="this.src='https://images.unsplash.com/photo-1522771739844-6a9f6d5f14af?auto=format&fit=crop&w=600&q=80'" />
                                    </div>
                                    <div class="col-md-6">
                                        <span class="badge mb-2" style="background: var(--body-bg); color: var(--text-primary); border: 1px solid var(--border);">Đơn thuê: #@booking.Id.Substring(0, 8)</span>
                                        <h4 class="fw-bold mb-2" style="color: var(--text-primary);"><a href="/Home/ProductDetails/@booking.ProductId" style="text-decoration:none; color:inherit;">@(booking.Product?.Name ?? "N/A")</a></h4>
                                        
                                        <div class="mb-2" style="font-size: 0.9rem; color: var(--text-secondary);">
                                            <i class="bi bi-calendar3 text-primary me-2"></i> Thời gian: 
                                            <strong>@booking.StartDate.ToString("dd/MM/yyyy")</strong> đến <strong>@booking.EndDate.ToString("dd/MM/yyyy")</strong>
                                        </div>
                                        <div class="mb-3" style="font-size: 0.9rem; color: var(--text-secondary);">
                                            <i class="bi bi-geo-alt-fill text-danger me-2"></i> Địa chỉ nhận: 
                                            <span>@booking.RentalAddress</span>
                                        </div>

                                        <div class="d-flex flex-wrap gap-2 align-items-center">
                                            @if (booking.Status == "PENDING") { <span class="badge bg-warning text-dark badge-status">Chờ thanh toán cọc</span> }
                                            else if (booking.Status == "WAITING_OWNER_CONFIRM") { <span class="badge bg-warning text-dark badge-status">Chờ chủ xác nhận cọc</span> }
                                            else if (booking.Status == "APPROVED") { <span class="badge bg-info badge-status">Đã duyệt</span> }
                                            else if (booking.Status == "ONGOING") { <span class="badge badge-status" style="background: var(--primary); color: #000000;">Đang thuê</span> }
                                            else if (booking.Status == "COMPLETED") { <span class="badge bg-success badge-status">Hoàn thành</span> }
                                            else if (booking.Status == "CANCELLED" || booking.Status == "REJECTED") { <span class="badge bg-danger badge-status">Đã hủy</span> }

                                            @if (booking.PaymentStatus == "UNPAID") { <span class="badge bg-danger badge-status">Chưa thanh toán</span> }
                                            else if (booking.PaymentStatus == "WAITING_CONFIRMATION") { <span class="badge bg-warning text-dark badge-status">Đang chờ xác nhận cọc</span> }
                                            else if (booking.PaymentStatus == "PAID") { <span class="badge bg-success badge-status">Đã đặt cọc</span> }
                                            else if (booking.PaymentStatus == "PAID_FULL") { <span class="badge bg-primary badge-status">Đã thanh toán đủ</span> }
                                            else if (booking.PaymentStatus == "REFUNDED") { <span class="badge bg-info badge-status">Đã hoàn tiền</span> }
                                        </div>
                                    </div>
                                    <div class="col-md-3 text-md-end d-flex flex-column justify-content-between align-items-md-end">
                                        <div class="mb-3">
                                            <small class="d-block" style="color: var(--text-secondary);">Tổng giá thuê</small>
                                            <h3 class="fw-bold m-0" style="color: var(--primary);">@booking.TotalPrice.ToString("N0")đ</h3>
                                        </div>

                                        @if (booking.PaymentStatus == "UNPAID" && booking.Status != "CANCELLED" && booking.Status != "REJECTED")
                                        {
                                            <a href="/Home/Payment/@booking.Id" class="btn btn-nav-primary w-100 py-2 justify-content-center text-center">
                                                <i class="bi bi-wallet2"></i> Thanh toán
                                            </a>
                                        }
                                        else if (booking.Status == "COMPLETED")
                                        {
                                            var hasReviewed = booking.Reviews != null && booking.Reviews.Any();
                                            if (hasReviewed)
                                            {
                                                <button class="btn btn-secondary py-2 px-3 rounded-pill fw-bold w-100" style="background: var(--body-bg); border: 1.5px solid var(--border); color: var(--text-secondary); cursor: not-allowed;" disabled>
                                                    <i class="bi bi-check2-circle text-success"></i> Đã đánh giá
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="btn btn-nav-primary py-2 px-3 btn-review-trigger w-100 justify-content-center"
                                                        data-booking-id="@booking.Id"
                                                        data-product-name="@(booking.Product?.Name ?? "Sản phẩm")"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#reviewModal">
                                                    <i class="bi bi-star-fill"></i> Đánh giá
                                                </button>
                                            }
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-5 rounded-4 shadow-sm" style="background: var(--card-bg); border: 1px solid var(--border);">
                            <i class="bi bi-inboxes fs-1 mb-3 d-block text-muted"></i>
