@model OmniRentBackend.Models.User
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Chỉnh sửa hồ sơ cá nhân — OmniRent</title>
    <meta name="description" content="Chỉnh sửa hồ sơ cá nhân của bạn trên OmniRent." />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

    <style>
        *, *::before, *::after { box-sizing: border-box; }

        :root {
            --primary:        #f59e0b;
            --primary-hover:  #d97706;
            --primary-light:  #fef3c7;
            --navy:           #0f172a;
            --border:         #e2e8f0;
            --body-bg:        #f8fafc;
            --card-bg:        #ffffff;
            --text-primary:   #0f172a;
            --text-secondary: #475569;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--body-bg);
            color: var(--text-primary);
            min-height: 100vh;
            margin: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem 1rem;
        }

        .edit-profile-container {
            width: 100%;
            max-width: 650px;
            animation: slideUp 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) both;
        }

        @@keyframes slideUp {
            from { opacity: 0; transform: translateY(20px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .edit-profile-card {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 20px;
            box-shadow: 0 10px 25px rgba(15, 23, 42, 0.05);
            padding: 2.5rem;
        }

        .card-header-title {
            font-size: 1.5rem;
            font-weight: 800;
            color: var(--navy);
            margin: 0 0 0.5rem 0;
            display: flex;
            align-items: center;
            gap: 0.6rem;
        }
        .card-header-title i {
            color: var(--primary);
        }

        .card-subtitle {
            color: var(--text-secondary);
            font-size: 0.875rem;
            margin-bottom: 2rem;
        }

        /* Section divider */
        .section-divider {
            display: flex;
            align-items: center;
            gap: 0.65rem;
            margin: 2rem 0 1.25rem;
        }
        .section-divider .divider-icon {
            width: 28px;
            height: 28px;
            background: var(--primary-light);
            border-radius: 7px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--primary-hover);
            font-size: 0.85rem;
            flex-shrink: 0;
        }
        .section-divider .divider-label {
            font-size: 0.85rem;
            font-weight: 700;
            color: var(--text-primary);
        }
        .section-divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--border);
        }

        .form-label {
            font-size: 0.78rem;
            font-weight: 700;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 0.4rem;
        }

        .form-control {
            border: 1.5px solid var(--border);
            border-radius: 10px;
            padding: 0.65rem 0.9rem;
            font-size: 0.9rem;
            color: var(--text-primary);
            transition: border-color 0.2s, box-shadow 0.2s;
        }
        .form-control:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(245,158,11,0.15);
            outline: none;
        }
        .form-control:disabled, .form-control[readonly] {
            background-color: #f1f5f9;
            opacity: 1;
        }

        /* Avatar preview */
        .avatar-preview-box {
            display: flex;
            align-items: center;
            gap: 1.25rem;
            margin-bottom: 1.5rem;
        }
        .avatar-img-circle {
            width: 72px;
            height: 72px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid var(--primary);
            background: var(--body-bg);
        }

        /* Alert styling */
        .info-alert {
            background-color: var(--primary-light);
            border: 1px solid rgba(245, 158, 11, 0.2);
            color: var(--primary-hover);
            border-radius: 10px;
            padding: 0.85rem 1rem;
            font-size: 0.82rem;
            line-height: 1.5;
            margin-bottom: 1.5rem;
            display: flex;
            gap: 0.6rem;
            align-items: flex-start;
        }
        .info-alert i {
            font-size: 1.1rem;
            margin-top: 1px;
        }

        /* Form Actions */
        .form-actions {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 2.5rem;
            padding-top: 1.5rem;
            border-top: 1px solid var(--border);
        }

        .btn-submit {
            background: var(--primary);
            color: var(--navy);
            border: none;
            border-radius: 10px;
            padding: 0.65rem 1.5rem;
            font-size: 0.9rem;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            transition: all 0.2s;
            cursor: pointer;
            box-shadow: 0 4px 12px rgba(245,158,11,0.25);
        }
        .btn-submit:hover {
            background: var(--primary-hover);
            color: #fff;
            transform: translateY(-1px);
            box-shadow: 0 6px 16px rgba(245,158,11,0.35);
        }

        .btn-back {
            color: var(--text-secondary);
            border: 1.5px solid var(--border);
            border-radius: 10px;
            padding: 0.6rem 1.2rem;
            font-size: 0.9rem;
            font-weight: 600;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            transition: all 0.2s;
            background: transparent;
        }
        .btn-back:hover {
            background: #f1f5f9;
            color: var(--text-primary);
        }
    </style>
</head>
<body>
    <div class="edit-profile-container">

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert" style="border-radius:12px;">
                <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="edit-profile-card">
            <h1 class="card-header-title">
                <i class="bi bi-person-gear"></i> Hồ sơ cá nhân
            </h1>
            <p class="card-subtitle">Hoàn thiện thông tin tài khoản của bạn để tiếp tục trên OmniRent</p>

            <form method="post" action="/Account/EditProfile" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <!-- SECTION 1: THÔNG TIN CƠ BẢN -->
                <div class="section-divider">
                    <div class="divider-icon"><i class="bi bi-person"></i></div>
                    <span class="divider-label">Thông tin cơ bản</span>
                </div>

                <div class="avatar-preview-box">
                    <img class="avatar-img-circle" id="avatarPreview" src="@(string.IsNullOrEmpty(Model.AvatarUrl) ? "https://www.gravatar.com/avatar/00000000000000000000000000000000?d=mp&f=y" : Model.AvatarUrl)" alt="Avatar Preview" />
                    <div>
                        <div class="form-label">Ảnh đại diện</div>
                        <input type="file" class="form-control form-control-sm" name="AvatarFile" id="AvatarFile" accept="image/*" onchange="previewFileAvatar()" />
                    </div>
                </div>

                <div class="mb-3">
                    <label for="FullName" class="form-label">Họ và tên <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="FullName" name="FullName" value="@Model.FullName" required />
                </div>

                <div class="row mb-3">
                    <div class="col-md-6 mb-3 mb-md-0">
                        <label for="Email" class="form-label">Địa chỉ Email</label>
                        <input type="email" class="form-control" id="Email" value="@Model.Email" readonly disabled />
                    </div>
                    <div class="col-md-6">
                        <label for="Phone" class="form-label">Số điện thoại</label>
                        <input type="tel" class="form-control" id="Phone" name="Phone" value="@Model.Phone" placeholder="09xxxxxxxx" />
                    </div>
                </div>

                <div class="mb-3">
                    <label for="NationalId" class="form-label">Số CCCD / CMND</label>
                    <input type="text" class="form-control" id="NationalId" name="NationalId" value="@Model.NationalId" placeholder="Số CCCD/CMND" />
                </div>

                <div class="mb-3">
                    <label for="AvatarUrl" class="form-label">Đường dẫn ảnh đại diện (URL)</label>
                    <input type="text" class="form-control" id="AvatarUrl" name="AvatarUrl" value="@Model.AvatarUrl" placeholder="https://example.com/avatar.jpg" oninput="previewUrlAvatar(this.value)" />
                </div>

                <!-- SECTION 2: THÔNG TIN CHỦ CHO THUÊ -->
                @if (Model.Role == "OWNER")
                {
                    <div class="section-divider">
                        <div class="divider-icon"><i class="bi bi-bank"></i></div>
                        <span class="divider-label">Thông tin chủ cho thuê</span>
                    </div>

                    <div class="info-alert">
                        <i class="bi bi-info-circle-fill"></i>
                        <span>Thông tin tài khoản ngân hàng dùng để khách thuê chuyển tiền cọc và để hệ thống hoàn tiền cọc tự động.</span>
                    </div>

                    <div class="mb-3">
                        <label for="PickupAddress" class="form-label">Địa chỉ kho / nơi giao nhận đồ</label>
                        <textarea class="form-control" id="PickupAddress" name="PickupAddress" rows="2" placeholder="Địa chỉ nơi khách hàng đến lấy sản phẩm...">@Model.PickupAddress</textarea>
                    </div>

                    <div class="mb-3">
                        <label for="BankName" class="form-label">Tên ngân hàng</label>
                        <input type="text" class="form-control" id="BankName" name="BankName" value="@Model.BankName" placeholder="Vietcombank / Techcombank / MB Bank..." />
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6 mb-3 mb-md-0">
                            <label for="BankAccount" class="form-label">Số tài khoản ngân hàng</label>
                            <input type="text" class="form-control" id="BankAccount" name="BankAccount" value="@Model.BankAccount" placeholder="Số tài khoản ngân hàng" />
                        </div>
                        <div class="col-md-6">
                            <label for="BankAccountHolder" class="form-label">Tên chủ tài khoản</label>
                            <input type="text" class="form-control" id="BankAccountHolder" name="BankAccountHolder" value="@Model.BankAccountHolder" placeholder="Tên chủ tài khoản (IN HOA)" style="text-transform: uppercase;" />
                        </div>
                    </div>
                }

                <div class="form-actions">
                    <a href="/" class="btn-back">
                        <i class="bi bi-arrow-left"></i> Về trang chủ
                    </a>
                    <button type="submit" class="btn-submit">
                        <i class="bi bi-save2-fill"></i> Lưu hồ sơ
                    </button>
                </div>
            </form>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function previewUrlAvatar(url) {
            const preview = document.getElementById('avatarPreview');
            if (url && url.trim() !== '') {
                preview.src = url.trim();
            } else {
                preview.src = "https://www.gravatar.com/avatar/00000000000000000000000000000000?d=mp&f=y";
            }
        }

        function previewFileAvatar() {
            const fileInput = document.getElementById('AvatarFile');
            const preview = document.getElementById('avatarPreview');
            const file = fileInput.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    preview.src = e.target.result;
                }
                reader.readAsDataURL(file);
            }
        }
    </script>
</body>
</html>
