@{
    Layout = null;
    var isAuthenticated = User.Identity != null && User.Identity.IsAuthenticated;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Giỏ hàng của bạn — OmniRent</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>
        :root {
            --primary:       #f59e0b;
            --primary-hover: #d97706;
            --primary-light: #fef3c7;
            --navy:          #0f172a;
            --navy-2:        #1e293b;
            --text-main:     #000000;
            --text-sub:      #333333;
            --text-muted:    #666666;
            --border:        #e2e8f0;
            --body-bg:       #f8fafc;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--body-bg);
            color: var(--text-main);
            min-height: 100vh;
            margin: 0; padding: 0;
            overflow-x: hidden;
        }

        /* Navbar */
        .navbar-custom {
            background: var(--navy);
            border-bottom: 1px solid rgba(255,255,255,0.06);
            padding: 1rem 0;
            position: fixed;
            top: 0; width: 100%;
            z-index: 1000;
        }
        .navbar-brand {
            font-weight: 800; font-size: 1.5rem;
            color: #ffffff !important;
            display: flex; align-items: center; gap: 0.5rem;
            text-decoration: none;
        }
        .brand-icon { color: var(--primary); font-size: 1.8rem; }
        
        .nav-link { color: #cbd5e1 !important; font-weight: 500; }
        .nav-link:hover, .nav-link.active { color: #ffffff !important; }

        .btn-outline-primary-custom {
            color: #fff;
            border: 1.5px solid rgba(255,255,255,0.25);
            border-radius: 50px;
            padding: 0.5rem 1.5rem;
            font-weight: 600;
            transition: all 0.2s;
            text-decoration: none;
        }
        .btn-outline-primary-custom:hover {
            border-color: var(--primary); color: var(--primary);
            background: rgba(245,158,11,0.08);
        }

        .btn-primary-custom {
            background: var(--primary);
            color: var(--navy);
            border: none; border-radius: 50px;
            padding: 0.5rem 1.5rem;
            font-weight: 700;
            transition: all 0.2s;
            text-decoration: none;
            box-shadow: 0 4px 14px rgba(245,158,11,0.3);
        }
        .btn-primary-custom:hover {
            background: var(--primary-hover); transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(245,158,11,0.4);
        }

        /* Content */
        .main-container { margin-top: 120px; padding-bottom: 80px; }

        .cart-item-card {
            background: #ffffff;
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 1.5rem;
            margin-bottom: 1.5rem;
            display: flex; align-items: center; justify-content: space-between;
            transition: all 0.2s;
            box-shadow: 0 4px 12px rgba(15,23,42,0.03);
        }
        .cart-item-card:hover {
            border-color: var(--primary);
            box-shadow: 0 8px 24px rgba(245,158,11,0.1);
            transform: translateY(-2px);
        }

        .cart-item-img {
            width: 100px; height: 100px;
            object-fit: cover; border-radius: 12px;
            border: 1px solid var(--border);
            background: var(--body-bg);
        }

        .checkout-box {
            background: #ffffff;
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 2rem;
            box-shadow: 0 10px 30px rgba(15,23,42,0.05);
        }

        .form-control-custom {
            background: #fff !important;
            border: 1.5px solid var(--border) !important;
            color: var(--text-main) !important;
            border-radius: 10px !important;
            padding: 0.8rem 1rem !important;
            font-size: 0.95rem !important;
            transition: border-color 0.2s, box-shadow 0.2s !important;
        }
        .form-control-custom:focus {
            border-color: var(--primary) !important;
            box-shadow: 0 0 0 3px rgba(245,158,11,0.15) !important;
        }

        .form-label-custom {
            font-weight: 700; color: #333333;
            margin-bottom: 0.4rem; font-size: 0.85rem;
            text-transform: uppercase; letter-spacing: 0.5px;
        }

        /* Footer */
        footer {
            background: var(--navy); border-top: 1px solid rgba(255,255,255,0.06);
            padding: 4rem 0 2rem; margin-top: 5rem;
        }
    </style>
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-custom">
        <div class="container">
            <a class="navbar-brand" href="/">
                <i class="bi bi-building-fill brand-icon"></i> OmniRent
            </a>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto">
                    <li class="nav-item"><a class="nav-link" href="/">Trang chủ</a></li>
                    @if (isAuthenticated) {
                        <li class="nav-item"><a class="nav-link" href="/Home/MyBookings">Đơn hàng của tôi</a></li>
                    }
                </ul>
            </div>
            <div class="ms-auto d-flex gap-3 align-items-center">
                @if (isAuthenticated) {
                    <span class="text-white fw-bold d-none d-md-inline me-2">Xin chào, @User.Identity.Name</span>
                    <form action="/Account/Logout" method="post" class="d-inline m-0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-primary-custom">Đăng xuất</button>
                    </form>
                } else {
                    <a href="/Account/Login?returnUrl=/Home/Cart" class="btn btn-outline-primary-custom">Đăng nhập</a>
                }
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="container main-container">
        <h2 class="mb-5 fw-bold" style="color: #000000;"><i class="bi bi-cart3 text-primary"></i> Giỏ hàng của bạn</h2>

        <div class="row g-5">
            <!-- Left: Cart items -->
            <div class="col-lg-7">
                <div id="cartItemsList"></div>
                <div id="emptyCartMessage" class="text-center py-5 d-none bg-white border rounded-4 shadow-sm" style="border-color: var(--border);">
                    <i class="bi bi-cart-x text-muted fs-1 mb-3 d-block" style="color: var(--text-muted) !important;"></i>
                    <p class="fs-5" style="color: #333333;">Giỏ hàng của bạn đang trống.</p>
                    <a href="/" class="btn btn-primary-custom px-4 py-2 mt-3">Khám phá sản phẩm ngay</a>
                </div>
            </div>

            <!-- Right: Checkout Settings -->
            <div class="col-lg-5">
                <div id="checkoutSettings" class="checkout-box d-none">
                    <h4 class="mb-4 fw-bold" style="color: #000000;"><i class="bi bi-calendar-check text-primary"></i> Thông tin đặt thuê</h4>
                    
                    @if (isAuthenticated) {
                        <div id="bookingError" class="alert alert-danger d-none" role="alert"></div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label for="startDate" class="form-label-custom">Ngày bắt đầu</label>
                                <input type="date" class="form-control form-control-custom" id="startDate" required min="@DateTime.Now.ToString("yyyy-MM-dd")" value="@DateTime.Now.ToString("yyyy-MM-dd")">
                            </div>
                            <div class="col-md-6">
                                <label for="endDate" class="form-label-custom">Ngày trả đồ</label>
                                <input type="date" class="form-control form-control-custom" id="endDate" required min="@DateTime.Now.AddDays(1).ToString("yyyy-MM-dd")" value="@DateTime.Now.AddDays(1).ToString("yyyy-MM-dd")">
                            </div>
                        </div>

                        <div class="mb-4">
                            <label for="rentalAddress" class="form-label-custom">Địa chỉ nhận tài sản (nhập chi tiết)</label>
                            <textarea class="form-control form-control-custom" id="rentalAddress" rows="3" placeholder="Ví dụ: Số 12, ngõ 34 Đường Láng..." required></textarea>
                        </div>

                        <div class="p-3 mb-4 rounded-3" style="background: var(--body-bg); border: 1px solid var(--border); font-size: 0.95rem;">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-sub" style="color: #333333;">Tổng số tài sản</span>
                                <span id="summaryCount" class="fw-bold" style="color: #000000;">0</span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span class="text-sub" style="color: #333333;">Tổng giá trị thuê / ngày</span>
                                <span id="summaryTotalDay" class="fw-bold" style="color: var(--primary); font-size: 1.1rem;">0đ</span>
                            </div>
                        </div>

                        <button id="btnSubmitCart" class="btn btn-primary-custom w-100 py-3" onclick="submitCartBookings()">
                            <i class="bi bi-credit-card-fill"></i> Xác nhận đặt thuê
                        </button>
                    } else {
                        <div class="text-center py-4">
                            <i class="bi bi-lock-fill fs-1 mb-3 d-block" style="color: #666666;"></i>
                            <p style="color: #333333;">Bạn cần đăng nhập để thanh toán.</p>
                            <a href="/Account/Login?returnUrl=/Home/Cart" class="btn btn-primary-custom px-4 py-2 mt-2">Đăng nhập ngay</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer>
        <div class="container text-center" style="color: #64748b; font-size: 0.9rem;">
            &copy; @DateTime.Now.Year OmniRent. Mọi quyền được bảo lưu.
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function loadCartItems() {
            let cart = JSON.parse(localStorage.getItem('cart')) || [];
            let listContainer = document.getElementById('cartItemsList');
            let emptyMsg = document.getElementById('emptyCartMessage');
            let checkoutBox = document.getElementById('checkoutSettings');
            listContainer.innerHTML = '';
            if (cart.length === 0) {
                emptyMsg.classList.remove('d-none'); checkoutBox.classList.add('d-none'); return;
            }
            emptyMsg.classList.add('d-none'); checkoutBox.classList.remove('d-none');

            let totalPerDay = 0;
            cart.forEach(item => {
                totalPerDay += item.price;
                let card = document.createElement('div');
                card.className = 'cart-item-card';
                card.innerHTML = `
                    <div class="d-flex align-items-center gap-3">
                        <img src="${item.image}" class="cart-item-img" onerror="this.src='https://images.unsplash.com/photo-1522771739844-6a9f6d5f14af?auto=format&fit=crop&w=600&q=80'">
                        <div>
                            <h5 class="fw-bold m-0" style="color: #000000;">${item.name}</h5>
                            <small class="d-block mb-1" style="color: #333333;">Chủ đồ: ${item.owner}</small>
                            <span class="fw-bold" style="color: var(--primary); font-size: 1.1rem;">${item.price.toLocaleString('vi-VN')}đ / ngày</span>
                        </div>
                    </div>
                    <button class="btn btn-outline-danger btn-sm rounded-circle p-2 d-flex align-items-center" onclick="removeItem('${item.id}')">
                        <i class="bi bi-trash fs-5"></i>
                    </button>
                `;
                listContainer.appendChild(card);
            });
            document.getElementById('summaryCount').innerText = `${cart.length} sản phẩm`;
            document.getElementById('summaryTotalDay').innerText = `${totalPerDay.toLocaleString('vi-VN')}đ`;
        }
        function removeItem(id) {
            let cart = JSON.parse(localStorage.getItem('cart')) || [];
            cart = cart.filter(item => item.id !== id);
            localStorage.setItem('cart', JSON.stringify(cart));
            loadCartItems();
        }
        async function submitCartBookings() {
            let cart = JSON.parse(localStorage.getItem('cart')) || [];
            if (cart.length === 0) return;
            const startDateStr = document.getElementById('startDate').value;
            const endDateStr = document.getElementById('endDate').value;
            const rentalAddress = document.getElementById('rentalAddress').value.trim();
            const btn = document.getElementById('btnSubmitCart');
            const errorBox = document.getElementById('bookingError');
            errorBox.classList.add('d-none');
            if (!startDateStr || !endDateStr) { showError('Vui lòng chọn ngày bắt đầu và trả đồ.'); return; }
            if (!rentalAddress) { showError('Vui lòng nhập địa chỉ nhận tài sản thuê.'); return; }

            btn.disabled = true; btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status"></span> Đang tạo đơn thuê...';
            let promises = cart.map(item => fetch('/bookings', {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ productId: item.id, startDate: startDateStr, endDate: endDateStr, rentalAddress: rentalAddress })
            }));
            try {
                let results = await Promise.all(promises);
                if (results.every(res => res.ok)) {
                    localStorage.removeItem('cart');
                    window.location.href = '/Home/MyBookings';
                } else {
                    showError('Có lỗi xảy ra. Vui lòng kiểm tra lại.');
                    btn.disabled = false; btn.innerText = 'Xác nhận đặt thuê';
                }
            } catch (e) {
                showError('Lỗi kết nối tới máy chủ.');
                btn.disabled = false; btn.innerText = 'Xác nhận đặt thuê';
            }
        }
        function showError(msg) {
            const errorBox = document.getElementById('bookingError');
            errorBox.innerText = msg; errorBox.classList.remove('d-none');
        }
        document.addEventListener('DOMContentLoaded', loadCartItems);
    </script>
</body>
</html>
