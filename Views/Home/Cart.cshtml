@{
    Layout = null;
    var isAuthenticated = User.Identity != null && User.Identity.IsAuthenticated;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Giỏ hàng của bạn — OmniRent</title>

    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Bootstrap & Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>
        :root {
            --primary: #6C63FF;
            --primary-hover: #5a52d5;
            --secondary: #0f0c29;
            --dark-bg: #1a1a3e;
            --card-bg: rgba(255, 255, 255, 0.05);
            --text-main: #ffffff;
            --text-muted: #a89fd8;
            --border-color: rgba(255, 255, 255, 0.1);
            --glass-bg: rgba(26, 26, 62, 0.85);
        }

        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, var(--secondary) 0%, var(--dark-bg) 100%);
            color: var(--text-main);
            min-height: 100vh;
            margin: 0;
            padding: 0;
            overflow-x: hidden;
        }

        /* Navbar */
        .navbar-custom {
            background: var(--glass-bg);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border-color);
            padding: 1rem 0;
            position: fixed;
            top: 0;
            width: 100%;
            z-index: 1000;
        }

        .navbar-brand {
            font-weight: 800;
            font-size: 1.5rem;
            color: var(--text-main) !important;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            text-decoration: none;
        }

        .brand-icon {
            color: var(--primary);
            font-size: 1.8rem;
        }

        .btn-outline-primary-custom {
            color: var(--text-main);
            border: 1px solid var(--primary);
            border-radius: 50px;
            padding: 0.5rem 1.5rem;
            font-weight: 500;
            transition: all 0.3s;
            text-decoration: none;
        }

        .btn-outline-primary-custom:hover {
            background: var(--primary);
            color: white;
            box-shadow: 0 4px 15px rgba(108, 99, 255, 0.4);
        }

        .btn-primary-custom {
            background: var(--primary);
            color: white;
            border: none;
            border-radius: 50px;
            padding: 0.5rem 1.5rem;
            font-weight: 600;
            transition: all 0.3s;
            text-decoration: none;
        }

        .btn-primary-custom:hover {
            background: var(--primary-hover);
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(108, 99, 255, 0.4);
        }

        /* Content Container */
        .main-container {
            margin-top: 120px;
            padding-bottom: 80px;
        }

        .cart-item-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 20px;
            padding: 1.5rem;
            margin-bottom: 1.5rem;
            backdrop-filter: blur(10px);
            display: flex;
            align-items: center;
            justify-content: space-between;
            transition: all 0.3s;
        }

        .cart-item-card:hover {
            border-color: rgba(255,255,255,0.2);
            transform: translateY(-2px);
        }

        .cart-item-img {
            width: 100px;
            height: 100px;
            object-fit: cover;
            border-radius: 12px;
            border: 1px solid var(--border-color);
            background: #2a2a4a;
        }

        .form-control-custom {
            background: rgba(0, 0, 0, 0.3) !important;
            border: 1px solid var(--border-color) !important;
            color: white !important;
            border-radius: 12px !important;
            padding: 0.8rem 1rem !important;
        }

        .form-control-custom:focus {
            border-color: var(--primary) !important;
            box-shadow: 0 0 10px rgba(108, 99, 255, 0.3) !important;
        }

        .form-label-custom {
            font-weight: 600;
            color: var(--text-muted);
            margin-bottom: 0.5rem;
            font-size: 0.9rem;
        }

        .checkout-box {
            background: rgba(255,255,255,0.03);
            border: 1px solid var(--border-color);
            border-radius: 24px;
            padding: 2rem;
            backdrop-filter: blur(15px);
        }

        /* Footer */
        footer {
            background: rgba(0,0,0,0.3);
            border-top: 1px solid var(--border-color);
            padding: 4rem 0 2rem;
            margin-top: 5rem;
        }
    </style>
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-custom">
        <div class="container">
            <a class="navbar-brand" href="/">
                <i class="bi bi-building-fill brand-icon"></i> OmniRent
            </a>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/">Trang chủ</a>
                    </li>
                    @if (isAuthenticated)
                    {
                        <li class="nav-item">
                            <a class="nav-link text-white" href="/Home/MyBookings">Đơn hàng của tôi</a>
                        </li>
                    }
                </ul>
            </div>
            <div class="ms-auto d-flex gap-3 align-items-center">
                @if (isAuthenticated)
                {
                    <span class="text-white fw-bold d-none d-md-inline me-2">Xin chào, @User.Identity.Name</span>
                    <form action="/Account/Logout" method="post" class="d-inline m-0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-primary-custom">Đăng xuất</button>
                    </form>
                }
                else
                {
                    <a href="/Account/Login?returnUrl=/Home/Cart" class="btn btn-outline-primary-custom">Đăng nhập</a>
                }
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="container main-container">
        <h2 class="mb-5 fw-bold"><i class="bi bi-cart3 text-primary"></i> Giỏ hàng của bạn</h2>

        <div class="row g-5">
            <!-- Left: Cart items -->
            <div class="col-lg-7">
                <div id="cartItemsList">
                    <!-- Dynamic Cart Items via JS -->
                </div>
                <div id="emptyCartMessage" class="text-center py-5 d-none">
                    <i class="bi bi-cart-x text-muted fs-1 mb-3 d-block"></i>
                    <p class="text-muted fs-5">Giỏ hàng của bạn đang trống.</p>
                    <a href="/" class="btn btn-primary-custom px-4 py-2 mt-3">Khám phá sản phẩm ngay</a>
                </div>
            </div>

            <!-- Right: Checkout Settings -->
            <div class="col-lg-5">
                <div id="checkoutSettings" class="checkout-box d-none">
                    <h4 class="mb-4 fw-bold text-white"><i class="bi bi-calendar-check text-primary"></i> Thông tin đặt thuê</h4>
                    
                    @if (isAuthenticated)
                    {
                        <div id="bookingError" class="alert alert-danger d-none" role="alert"></div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label for="startDate" class="form-label-custom">Ngày bắt đầu nhận</label>
                                <input type="date" class="form-control form-control-custom" id="startDate" required min="@DateTime.Now.ToString("yyyy-MM-dd")" value="@DateTime.Now.ToString("yyyy-MM-dd")">
                            </div>
                            <div class="col-md-6">
                                <label for="endDate" class="form-label-custom">Ngày trả đồ</label>
                                <input type="date" class="form-control form-control-custom" id="endDate" required min="@DateTime.Now.AddDays(1).ToString("yyyy-MM-dd")" value="@DateTime.Now.AddDays(1).ToString("yyyy-MM-dd")">
                            </div>
                        </div>

                        <div class="mb-4">
                            <label for="rentalAddress" class="form-label-custom">Địa chỉ nhận tài sản thuê (nhập chi tiết)</label>
                            <textarea class="form-control form-control-custom" id="rentalAddress" rows="3" placeholder="Ví dụ: Số 12, ngõ 34 Đường Láng, Đống Đa, Hà Nội..." required></textarea>
                        </div>

                        <div class="p-3 mb-4 rounded-4" style="background: rgba(255,255,255,0.02); border: 1px solid var(--border-color); font-size: 0.9rem;">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Tổng số tài sản đặt</span>
                                <span id="summaryCount" class="fw-bold text-white">0</span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span class="text-muted">Tổng giá trị thuê / ngày</span>
                                <span id="summaryTotalDay" class="fw-bold text-success">0đ</span>
                            </div>
                        </div>

                        <button id="btnSubmitCart" class="btn btn-primary-custom w-100 py-3" onclick="submitCartBookings()">
                            <i class="bi bi-credit-card-fill"></i> Xác nhận đặt thuê giỏ hàng
                        </button>
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <i class="bi bi-lock-fill text-muted fs-1 mb-3 d-block"></i>
                            <p class="text-muted">Bạn cần đăng nhập tài khoản để thực hiện thanh toán thuê sản phẩm.</p>
                            <a href="/Account/Login?returnUrl=/Home/Cart" class="btn btn-primary-custom px-4 py-2 mt-2">Đăng nhập ngay</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer>
        <div class="container text-center text-muted" style="font-size: 0.9rem;">
            &copy; @DateTime.Now.Year OmniRent. Mọi quyền được bảo lưu.
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function loadCartItems() {
            let cart = JSON.parse(localStorage.getItem('cart')) || [];
            let listContainer = document.getElementById('cartItemsList');
            let emptyMsg = document.getElementById('emptyCartMessage');
            let checkoutBox = document.getElementById('checkoutSettings');

            listContainer.innerHTML = '';

            if (cart.length === 0) {
                emptyMsg.classList.remove('d-none');
                checkoutBox.classList.add('d-none');
                return;
            }

            emptyMsg.classList.add('d-none');
            checkoutBox.classList.remove('d-none');

            let totalPerDay = 0;

            cart.forEach(item => {
                totalPerDay += item.price;

                let card = document.createElement('div');
                card.className = 'cart-item-card';
                card.innerHTML = `
                    <div class="d-flex align-items-center gap-3">
                        <img src="${item.image}" alt="${item.name}" class="cart-item-img" onerror="this.src='https://images.unsplash.com/photo-1522771739844-6a9f6d5f14af?auto=format&fit=crop&w=600&q=80'">
                        <div>
                            <h5 class="fw-bold m-0 text-white">${item.name}</h5>
                            <small class="text-muted d-block">Chủ đồ: ${item.owner}</small>
                            <span class="fw-bold text-success" style="font-size: 1.1rem;">${item.price.toLocaleString('vi-VN')}đ / ngày</span>
                        </div>
                    </div>
                    <button class="btn btn-outline-danger btn-sm rounded-circle p-2 d-flex align-items-center" onclick="removeItem('${item.id}')">
                        <i class="bi bi-trash fs-5"></i>
                    </button>
                `;
                listContainer.appendChild(card);
            });

            document.getElementById('summaryCount').innerText = `${cart.length} sản phẩm`;
            document.getElementById('summaryTotalDay').innerText = `${totalPerDay.toLocaleString('vi-VN')}đ`;
        }

        function removeItem(id) {
            let cart = JSON.parse(localStorage.getItem('cart')) || [];
            cart = cart.filter(item => item.id !== id);
            localStorage.setItem('cart', JSON.stringify(cart));
            loadCartItems();
        }

        async function submitCartBookings() {
            let cart = JSON.parse(localStorage.getItem('cart')) || [];
            if (cart.length === 0) return;

            const startDateStr = document.getElementById('startDate').value;
            const endDateStr = document.getElementById('endDate').value;
            const rentalAddress = document.getElementById('rentalAddress').value.trim();
            const btn = document.getElementById('btnSubmitCart');
            const errorBox = document.getElementById('bookingError');

            errorBox.classList.add('d-none');

            if (!startDateStr || !endDateStr) {
                showError('Vui lòng chọn ngày bắt đầu và trả đồ.');
                return;
            }

            if (!rentalAddress) {
                showError('Vui lòng nhập địa chỉ nhận tài sản thuê.');
                return;
            }

            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Đang tạo các đơn thuê...';

            let bookingPromises = cart.map(item => {
                return fetch('/bookings', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        productId: item.id,
                        startDate: startDateStr,
                        endDate: endDateStr,
                        rentalAddress: rentalAddress
                    })
                });
            });

            try {
                let results = await Promise.all(bookingPromises);
                let allOk = results.every(res => res.ok);

                if (allOk) {
                    // Clear cart
                    localStorage.removeItem('cart');
                    // Redirect to Renter's Booking List
                    window.location.href = '/Home/MyBookings';
                } else {
                    showError('Có lỗi xảy ra khi tạo một số đơn thuê. Vui lòng kiểm tra lại.');
                    btn.disabled = false;
                    btn.innerText = 'Xác nhận đặt thuê giỏ hàng';
                }
            } catch (e) {
                showError('Lỗi kết nối tới máy chủ.');
                btn.disabled = false;
                btn.innerText = 'Xác nhận đặt thuê giỏ hàng';
            }
        }

        function showError(msg) {
            const errorBox = document.getElementById('bookingError');
            errorBox.innerText = msg;
            errorBox.classList.remove('d-none');
        }

        document.addEventListener('DOMContentLoaded', loadCartItems);
    </script>
</body>
</html>
