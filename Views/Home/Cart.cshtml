@{
    Layout = null;
    var isAuthenticated = User.Identity != null && User.Identity.IsAuthenticated;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Giỏ hàng của bạn — OmniRent</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>
        :root, [data-theme="light"] {
            --primary:        #eab308; /* Premium Gold Yellow */
            --primary-hover:  #ca8a04;
            --primary-light:  #fef9c3;
            --navy:           #09090b; /* Pure Obsidian Black */
            --navy-2:         #18181b; /* Dark zinc */
            --accent:         #eab308;
            --body-bg:        #fafafa; /* Sleek light gray */
            --section-alt:    #ffffff;
            --text-primary:   #09090b;
            --text-secondary: #4b5563;
            --text-muted:     #9ca3af;
            --border:         #e5e7eb;
            --card-bg:        #ffffff;
            --card-shadow:    0 4px 20px rgba(9,9,11,0.03);
            --navbar-bg:      rgba(255, 255, 255, 0.85);
            --navbar-shadow:  0 1px 2px rgba(9,9,11,0.05);
            --footer-bg:      #09090b;
            --footer-text:    #9ca3af;
            --footer-heading:  #f3f4f6;
            --footer-border:  #1f2937;
            --tag-color:      #854d0e;
        }

        [data-theme="dark"] {
            --primary:        #facc15; /* Vibrant Gold Yellow */
            --primary-hover:  #eab308;
            --primary-light:  rgba(250,204,21,0.1);
            --navy:           #f3f4f6; /* Off-white text */
            --navy-2:         #e5e7eb;
            --accent:         #fbbf24;
            --body-bg:        #09090b; /* Pure Black Background */
            --section-alt:    #121214; /* Charcoal background */
            --text-primary:   #f3f4f6;
            --text-secondary: #9ca3af;
            --text-muted:     #6b7280;
            --border:         #1f2937;
            --card-bg:        #18181b;
            --card-shadow:    0 10px 30px rgba(0,0,0,0.3);
            --navbar-bg:      rgba(9, 9, 11, 0.85);
            --navbar-shadow:  0 1px 0 rgba(255,255,255,0.05);
            --footer-bg:      #020203;
            --footer-text:    #6b7280;
            --footer-heading:  #f3f4f6;
            --footer-border:  #18181b;
            --tag-color:      #fde047;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--body-bg);
            color: var(--text-primary);
            min-height: 100vh;
            margin: 0; padding: 0;
            overflow-x: hidden;
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        /* Navbar */
        .navbar-custom {
            background: var(--navbar-bg);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border);
            padding: 0.875rem 0;
            position: fixed;
            top: 0; width: 100%;
            z-index: 1000;
            box-shadow: var(--navbar-shadow);
            transition: all 0.3s ease;
        }
        .navbar-brand {
            font-weight: 800; font-size: 1.4rem;
            color: var(--text-primary) !important;
            display: flex; align-items: center; gap: 0.5rem;
            text-decoration: none;
        }
        .brand-icon { color: var(--primary); font-size: 1.6rem; }
        
        .nav-link-custom {
            color: var(--text-secondary) !important;
            font-weight: 500;
            font-size: 0.9rem;
            padding: 0.5rem 0.85rem !important;
            border-radius: 6px;
            transition: all 0.2s;
            text-decoration: none;
        }
        .nav-link-custom:hover, .nav-link-custom.active {
            color: var(--primary) !important;
            background: var(--primary-light);
        }

        .btn-nav-outline {
            color: var(--text-secondary);
            border: 1.5px solid var(--border);
            border-radius: 8px;
            padding: 0.45rem 1.1rem;
            font-size: 0.85rem;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
        }
        .btn-nav-outline:hover {
            border-color: var(--primary);
            color: var(--primary);
            background: rgba(245,158,11,0.06);
        }

        .btn-nav-primary {
            background: var(--primary);
            color: var(--navy) !important;
            border: none;
            border-radius: 8px;
            padding: 0.45rem 1.2rem;
            font-size: 0.85rem;
            font-weight: 700;
            text-decoration: none;
            transition: all 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
        }
        .btn-nav-primary:hover {
            background: var(--primary-hover);
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(245,158,11,0.4);
        }

        .cart-icon {
            color: var(--text-secondary);
            font-size: 1.25rem;
            text-decoration: none;
            position: relative;
            transition: color 0.2s;
        }
        .cart-icon:hover { color: var(--primary); }

        .theme-toggle {
            background: transparent;
            border: 1.5px solid var(--border);
            border-radius: 10px;
            width: 38px; height: 38px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 1.1rem;
            color: var(--text-secondary);
            transition: all 0.25s;
            flex-shrink: 0;
        }
        .theme-toggle:hover {
            border-color: var(--primary);
            color: var(--primary);
            background: var(--primary-light);
        }
        .theme-toggle .bi-moon-fill { display: inline; }
        .theme-toggle .bi-sun-fill { display: none; }
        [data-theme="dark"] .theme-toggle .bi-moon-fill { display: none; }
        [data-theme="dark"] .theme-toggle .bi-sun-fill { display: inline; }

        /* Content */
        .main-container { margin-top: 120px; padding-bottom: 80px; }

        .cart-item-card {
            background: var(--card-bg);
            border: 1.5px solid var(--border);
            border-radius: 16px;
            padding: 1.5rem;
            margin-bottom: 1.5rem;
            display: flex; align-items: center; justify-content: space-between;
            transition: all 0.25s;
            box-shadow: var(--card-shadow);
        }
        .cart-item-card:hover {
            border-color: var(--primary);
            box-shadow: 0 8px 24px rgba(245,158,11,0.1);
            transform: translateY(-2px);
        }

        .cart-item-img {
            width: 100px; height: 100px;
            object-fit: cover; border-radius: 12px;
            border: 1px solid var(--border);
            background: var(--body-bg);
        }

        .checkout-box {
            background: var(--card-bg);
            border: 1.5px solid var(--border);
            border-radius: 20px;
            padding: 2rem;
            box-shadow: var(--card-shadow);
            transition: background-color 0.3s ease, border-color 0.3s ease;
        }

        .form-control-custom {
            background-color: var(--body-bg) !important;
            color: var(--text-primary) !important;
            border: 1.5px solid var(--border) !important;
            border-radius: 12px !important;
            padding: 0.8rem 1rem !important;
            font-size: 0.95rem !important;
            transition: border-color 0.2s, box-shadow 0.2s !important;
        }
        .form-control-custom:focus {
            border-color: var(--primary) !important;
            box-shadow: 0 0 0 0.25rem rgba(234, 179, 8, 0.25) !important;
        }

        .form-label-custom {
            font-weight: 700; color: var(--text-secondary);
            margin-bottom: 0.4rem; font-size: 0.85rem;
            text-transform: uppercase; letter-spacing: 0.5px;
        }

        /* Footer */
        footer {
            background: var(--footer-bg);
            border-top: 1px solid var(--footer-border);
            padding: 4rem 0 2rem;
            margin-top: 5rem;
            transition: background-color 0.3s ease;
        }

        .footer-brand {
            font-size: 1.5rem;
            font-weight: 800;
            color: #ffffff;
            display: flex;
            align-items: center;
            gap: 0.4rem;
            margin-bottom: 0.75rem;
        }

        .footer-text { color: #64748b; max-width: 280px; font-size: 0.875rem; line-height: 1.7; }
        .footer-title { font-weight: 700; color: #e2e8f0; font-size: 0.85rem; margin-bottom: 1.25rem; text-transform: uppercase; letter-spacing: 0.5px; }

        .footer-links { list-style: none; padding: 0; margin: 0; }
        .footer-links li { margin-bottom: 0.65rem; }
        .footer-links a { color: #64748b; text-decoration: none; font-size: 0.875rem; transition: color 0.2s; }
        .footer-links a:hover { color: var(--primary); }

        .social-icon {
            width: 36px; height: 36px;
            border-radius: 8px;
            background: rgba(255,255,255,0.06);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: #64748b;
            font-size: 1rem;
            text-decoration: none;
            transition: all 0.2s;
        }
        .social-icon:hover { background: var(--primary); color: var(--navy); }
    </style>
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-custom">
        <div class="container">
            <a class="navbar-brand" href="/">
                <i class="bi bi-building-fill brand-icon"></i> OmniRent
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                    aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <i class="bi bi-list fs-2" style="color:var(--text-primary)"></i>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto gap-1">
                    <li class="nav-item">
                        <a class="nav-link-custom" href="/">Trang chủ</a>
                    </li>
                </ul>
                <div class="d-flex gap-2 mt-3 mt-lg-0 align-items-center">
                    <!-- Theme Toggle -->
                    <button class="theme-toggle" id="themeToggle" title="Chuyển chế độ sáng/tối">
                        <i class="bi bi-moon-fill"></i>
                        <i class="bi bi-sun-fill"></i>
                    </button>

                    @if (isAuthenticated) {
                        var userAvatar = User.FindFirst("AvatarUrl")?.Value;
                        <div class="dropdown">
                            <button class="btn dropdown-toggle d-flex align-items-center gap-2 border-0 bg-transparent p-0" type="button" id="userMenuButton" data-bs-toggle="dropdown" aria-expanded="false" style="color:var(--text-primary); font-size:0.9rem; font-weight:600;">
                                <div class="profile-avatar" style="width: 32px; height: 32px; border-radius: 50%; background: var(--primary); color: var(--navy); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.85rem; overflow: hidden; border: 1.5px solid var(--primary);">
                                    @if (!string.IsNullOrEmpty(userAvatar))
                                    {
                                        <img src="@userAvatar" alt="Avatar" style="width:100%; height:100%; object-fit:cover;" />
                                    }
                                    else
                                    {
                                        @User.Identity.Name.Substring(0, 1).ToUpper()
                                    }
                                </div>
                                <span class="d-none d-md-inline" style="color:var(--text-primary)">@User.Identity.Name</span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end p-2 border-0" aria-labelledby="userMenuButton" style="background: var(--card-bg); box-shadow: var(--card-shadow); border-radius: 12px; min-width: 200px;">
                                <li>
                                    <a class="dropdown-item rounded-3 py-2 px-3 d-flex align-items-center gap-2"
                                       href="/Account/EditProfile"
                                       style="color: var(--text-primary); font-size: 0.85rem; font-weight: 500;">
                                        <i class="bi bi-person-gear text-primary"></i> Chỉnh sửa hồ sơ
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item rounded-3 py-2 px-3 d-flex align-items-center gap-2" href="/Account/Profile" style="color: var(--text-primary); font-size: 0.85rem; font-weight: 500;">
                                        <i class="bi bi-person-circle text-primary"></i> Trang cá nhân & Lịch sử
                                    </a>
                                </li>
                                @if (User.IsInRole("OWNER"))
                                {
                                    <li>
                                        <a class="dropdown-item rounded-3 py-2 px-3 d-flex align-items-center gap-2" href="/OwnerDashboard" style="color: var(--text-primary); font-size: 0.85rem; font-weight: 500;">
                                            <i class="bi bi-house-door-fill text-primary"></i> Quản lý tài sản
                                        </a>
                                    </li>
                                }
                                @if (User.IsInRole("ADMIN"))
                                {
                                    <li>
                                        <a class="dropdown-item rounded-3 py-2 px-3 d-flex align-items-center gap-2" href="/AdminDashboard/Bookings" style="color: var(--text-primary); font-size: 0.85rem; font-weight: 500;">
                                            <i class="bi bi-shield-lock-fill text-primary"></i> Trang quản trị
                                        </a>
                                    </li>
                                }
                                <li><hr class="dropdown-divider" style="border-color: var(--border);"></li>
                                <li>
                                    <form action="/Account/Logout" method="post" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item rounded-3 py-2 px-3 text-danger d-flex align-items-center gap-2 bg-transparent border-0 w-100 text-start" style="font-size: 0.85rem; font-weight: 600;">
                                            <i class="bi bi-box-arrow-right"></i> Đăng xuất
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    } else {
                        <a href="/Account/Login?returnUrl=/Home/Cart" class="btn-nav-outline">Đăng nhập</a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="container main-container">
        <h2 class="mb-5 fw-bold" style="color: var(--text-primary);"><i class="bi bi-cart3 text-primary"></i> Giỏ hàng của bạn</h2>

        <div class="row g-5">
            <!-- Left: Cart items -->
            <div class="col-lg-7">
                <div id="cartItemsList"></div>
                <div id="emptyCartMessage" class="text-center py-5 d-none rounded-4 shadow-sm" style="background: var(--card-bg); border: 1px solid var(--border);">
                    <i class="bi bi-cart-x text-muted fs-1 mb-3 d-block"></i>
                    <p class="fs-5" style="color: var(--text-secondary);">Giỏ hàng của bạn đang trống.</p>
                    <a href="/" class="btn-nav-primary px-4 py-2 mt-3">Khám phá sản phẩm ngay</a>
                </div>
            </div>

            <!-- Right: Checkout Settings -->
            <div class="col-lg-5">
                <div id="checkoutSettings" class="checkout-box d-none">
                    <h4 class="mb-4 fw-bold" style="color: var(--text-primary);"><i class="bi bi-calendar-check text-primary"></i> Thông tin đặt thuê</h4>
                    
                    @if (isAuthenticated) {
                        <div id="bookingError" class="alert alert-danger d-none" role="alert"></div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label for="startDate" class="form-label-custom">Ngày bắt đầu</label>
                                <input type="date" class="form-control form-control-custom" id="startDate" required min="@DateTime.Now.ToString("yyyy-MM-dd")" value="@DateTime.Now.ToString("yyyy-MM-dd")">
                            </div>
                            <div class="col-md-6">
                                <label for="endDate" class="form-label-custom">Ngày trả đồ</label>
                                <input type="date" class="form-control form-control-custom" id="endDate" required min="@DateTime.Now.AddDays(1).ToString("yyyy-MM-dd")" value="@DateTime.Now.AddDays(1).ToString("yyyy-MM-dd")">
                            </div>
                        </div>

                        <div class="mb-4">
                            <label for="rentalAddress" class="form-label-custom">Địa chỉ nhận tài sản (nhập chi tiết)</label>
                            <textarea class="form-control form-control-custom" id="rentalAddress" rows="3" placeholder="Ví dụ: Số 12, ngõ 34 Đường Láng..." required></textarea>
                        </div>

                        <div class="p-3 mb-4 rounded-3" style="background: var(--body-bg); border: 1px solid var(--border); font-size: 0.95rem;">
                            <div class="d-flex justify-content-between mb-2">
                                <span style="color: var(--text-secondary);">Tổng số tài sản</span>
                                <span id="summaryCount" class="fw-bold" style="color: var(--text-primary);">0</span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span style="color: var(--text-secondary);">Tổng giá trị thuê / ngày</span>
                                <span id="summaryTotalDay" class="fw-bold" style="color: var(--primary); font-size: 1.1rem;">0đ</span>
                            </div>
                        </div>

                        <button id="btnSubmitCart" class="btn-nav-primary w-100 py-3 justify-content-center">
                            <i class="bi bi-credit-card-fill"></i> Xác nhận đặt thuê
                        </button>
                    } else {
                        <div class="text-center py-4">
                            <i class="bi bi-lock-fill fs-1 mb-3 d-block text-muted"></i>
                            <p style="color: var(--text-secondary);">Bạn cần đăng nhập để thanh toán.</p>
                            <a href="/Account/Login?returnUrl=/Home/Cart" class="btn-nav-primary px-4 py-2 mt-2">Đăng nhập ngay</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- ======================== FOOTER ======================== -->
    <footer>
        <div class="container">
            <div class="row g-5">
                <div class="col-lg-4">
                    <div class="footer-brand">
                        <i class="bi bi-building-fill" style="color: var(--primary);"></i> OmniRent
                    </div>
                    <p class="footer-text">Nền tảng kết nối người thuê và người cho thuê nhanh chóng, an toàn và minh bạch nhất hiện nay.</p>
                    <div class="d-flex gap-2 mt-3">
                        <a href="#" class="social-icon"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="social-icon"><i class="bi bi-instagram"></i></a>
                        <a href="#" class="social-icon"><i class="bi bi-twitter-x"></i></a>
                    </div>
                </div>
                <div class="col-lg-2 col-md-4">
                    <h4 class="footer-title">Khám phá</h4>
                    <ul class="footer-links">
                        <li><a href="#">Tất cả tài sản</a></li>
                        <li><a href="#">Danh mục nổi bật</a></li>
                        <li><a href="#">Chủ cho thuê uy tín</a></li>
                    </ul>
                </div>
                <div class="col-lg-2 col-md-4">
                    <h4 class="footer-title">Hỗ trợ</h4>
                    <ul class="footer-links">
                        <li><a href="#">Trung tâm trợ giúp</a></li>
                        <li><a href="#">Quy định an toàn</a></li>
                        <li><a href="#">Chính sách bảo mật</a></li>
                    </ul>
                </div>
                <div class="col-lg-4 col-md-4">
                    <h4 class="footer-title">Liên hệ</h4>
                    <ul class="footer-links">
                        <li><i class="bi bi-envelope me-2" style="color:var(--primary)"></i>support@omnirent.vn</li>
                        <li><i class="bi bi-telephone me-2" style="color:var(--primary)"></i>1800 000 000</li>
                        <li><i class="bi bi-geo-alt me-2" style="color:var(--primary)"></i>Hồ Chí Minh, Việt Nam</li>
                    </ul>
                </div>
            </div>
            <div class="text-center mt-5 pt-4" style="border-top: 1px solid rgba(255,255,255,0.06); color: #475569; font-size: 0.82rem;">
                &copy; @DateTime.Now.Year OmniRent. Mọi quyền được bảo lưu.
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // =================== Theme Toggle ===================
        (function() {
            const root = document.documentElement;
            const toggle = document.getElementById('themeToggle');
            const storageKey = 'omnirent-theme';

            function getPreferred() {
                const saved = localStorage.getItem(storageKey);
                if (saved) return saved;
                return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
            }

            function applyTheme(theme) {
                root.setAttribute('data-theme', theme);
                localStorage.setItem(storageKey, theme);
            }

            applyTheme(getPreferred());

            if (toggle) {
                toggle.addEventListener('click', () => {
                    const current = root.getAttribute('data-theme') || 'light';
                    applyTheme(current === 'dark' ? 'light' : 'dark');
                });
            }

            window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
                if (!localStorage.getItem(storageKey)) {
                    applyTheme(e.matches ? 'dark' : 'light');
                }
            });
        })();

        function loadCartItems() {
            let cart = JSON.parse(localStorage.getItem('cart')) || [];
            let listContainer = document.getElementById('cartItemsList');
            let emptyMsg = document.getElementById('emptyCartMessage');
            let checkoutBox = document.getElementById('checkoutSettings');
            listContainer.innerHTML = '';
            if (cart.length === 0) {
                emptyMsg.classList.remove('d-none'); checkoutBox.classList.add('d-none'); return;
            }
            emptyMsg.classList.add('d-none'); checkoutBox.classList.remove('d-none');

            let totalPerDay = 0;
            cart.forEach(item => {
                totalPerDay += item.price;
                let card = document.createElement('div');
                card.className = 'cart-item-card';
                card.innerHTML = `
                    <div class="d-flex align-items-center gap-3">
                        <img src="${item.image}" class="cart-item-img" onerror="this.src='https://images.unsplash.com/photo-1522771739844-6a9f6d5f14af?auto=format&fit=crop&w=600&q=80'">
                        <div>
                            <h5 class="fw-bold m-0" style="color: var(--text-primary);">${item.name}</h5>
                            <small class="d-block mb-1" style="color: var(--text-secondary);">Chủ đồ: ${item.owner}</small>
                            <span class="fw-bold" style="color: var(--primary); font-size: 1.1rem;">${item.price.toLocaleString('vi-VN')}đ / ngày</span>
                        </div>
                    </div>
                    <button class="btn btn-outline-danger btn-sm rounded-circle p-2 d-flex align-items-center" onclick="removeItem('${item.id}')">
                        <i class="bi bi-trash fs-5"></i>
                    </button>
                `;
                listContainer.appendChild(card);
            });
            document.getElementById('summaryCount').innerText = `${cart.length} sản phẩm`;
            document.getElementById('summaryTotalDay').innerText = `${totalPerDay.toLocaleString('vi-VN')}đ`;
        }
        function removeItem(id) {
            let cart = JSON.parse(localStorage.getItem('cart')) || [];
            cart = cart.filter(item => item.id !== id);
            localStorage.setItem('cart', JSON.stringify(cart));
            loadCartItems();
        }
        async function submitCartBookings() {
            let cart = JSON.parse(localStorage.getItem('cart')) || [];
            if (cart.length === 0) return;
            const startDateStr = document.getElementById('startDate').value;
            const endDateStr = document.getElementById('endDate').value;
            const rentalAddress = document.getElementById('rentalAddress').value.trim();
            const btn = document.getElementById('btnSubmitCart');
            const errorBox = document.getElementById('bookingError');
            if (errorBox) errorBox.classList.add('d-none');
            if (!startDateStr || !endDateStr) { showError('Vui lòng chọn ngày bắt đầu và trả đồ.'); return; }
            if (!rentalAddress) { showError('Vui lòng nhập địa chỉ nhận tài sản thuê.'); return; }

            btn.disabled = true; btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status"></span> Đang tạo đơn thuê...';
            let promises = cart.map(item => fetch('/bookings', {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ productId: item.id, startDate: startDateStr, endDate: endDateStr, rentalAddress: rentalAddress })
            }));
            try {
                let results = await Promise.all(promises);
                if (results.every(res => res.ok)) {
                    localStorage.removeItem('cart');
                    window.location.href = '/Home/MyBookings';
                } else {
                    showError('Có lỗi xảy ra. Vui lòng kiểm tra lại.');
                    btn.disabled = false; btn.innerText = 'Xác nhận đặt thuê';
                }
            } catch (e) {
                showError('Lỗi kết nối tới máy chủ.');
                btn.disabled = false; btn.innerText = 'Xác nhận đặt thuê';
            }
        }
        function showError(msg) {
            const errorBox = document.getElementById('bookingError');
            if (errorBox) {
                errorBox.innerText = msg; errorBox.classList.remove('d-none');
            }
        }
        document.addEventListener('DOMContentLoaded', loadCartItems);
    </script>
</body>
</html>
