@using OmniRentBackend.Models
@model Product
@{
    Layout = null;
    var isAuthenticated = User.Identity != null && User.Identity.IsAuthenticated;
    var ownerPickupAddress = Model.Owner?.PickupAddress ?? Model.Owner?.Address ?? "Chủ cho thuê chưa cập nhật địa chỉ nhận đồ.";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Xác nhận đặt thuê — OmniRent</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>
        :root, [data-theme="light"] {
            --primary:        #eab308; /* Premium Gold Yellow */
            --primary-hover:  #ca8a04;
            --primary-light:  #fef9c3;
            --navy:           #09090b; /* Pure Obsidian Black */
            --navy-2:         #18181b; /* Dark zinc */
            --accent:         #eab308;
            --body-bg:        #fafafa; /* Sleek light gray */
            --section-alt:    #ffffff;
            --text-primary:   #09090b;
            --text-secondary: #4b5563;
            --text-muted:     #9ca3af;
            --border:         #e5e7eb;
            --card-bg:        #ffffff;
            --card-shadow:    0 4px 20px rgba(9,9,11,0.03);
            --navbar-bg:      rgba(255, 255, 255, 0.85);
            --navbar-shadow:  0 1px 2px rgba(9,9,11,0.05);
            --footer-bg:      #09090b;
            --footer-text:    #9ca3af;
            --footer-heading:  #f3f4f6;
            --footer-border:  #1f2937;
        }

        [data-theme="dark"] {
            --primary:        #facc15; /* Vibrant Gold Yellow */
            --primary-hover:  #eab308;
            --primary-light:  rgba(250,204,21,0.1);
            --navy:           #f3f4f6; /* Off-white text */
            --navy-2:         #e5e7eb;
            --accent:         #fbbf24;
            --body-bg:        #09090b; /* Pure Black Background */
            --section-alt:    #121214; /* Charcoal background */
            --text-primary:   #f3f4f6;
            --text-secondary: #9ca3af;
            --text-muted:     #6b7280;
            --border:         #1f2937;
            --card-bg:        #18181b;
            --card-shadow:    0 10px 30px rgba(0,0,0,0.3);
            --navbar-bg:      rgba(9, 9, 11, 0.85);
            --navbar-shadow:  0 1px 0 rgba(255,255,255,0.05);
            --footer-bg:      #020203;
            --footer-text:    #6b7280;
            --footer-heading:  #f3f4f6;
            --footer-border:  #18181b;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--body-bg);
            color: var(--text-primary);
            min-height: 100vh;
            margin: 0; padding: 0;
            overflow-x: hidden;
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        /* Navbar */
        .navbar-custom {
            background: var(--navbar-bg);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border);
            padding: 0.875rem 0;
            position: fixed;
            top: 0; width: 100%;
            z-index: 1000;
            box-shadow: var(--navbar-shadow);
            transition: all 0.3s ease;
        }
        .navbar-brand {
            font-weight: 800; font-size: 1.4rem;
            color: var(--text-primary) !important;
            display: flex; align-items: center; gap: 0.5rem;
            text-decoration: none;
        }
        .brand-icon { color: var(--primary); font-size: 1.6rem; }
        
        .nav-link {
            color: var(--text-secondary) !important;
            font-weight: 500;
            font-size: 0.9rem;
            padding: 0.5rem 0.85rem !important;
            border-radius: 6px;
            transition: all 0.2s;
            text-decoration: none;
        }
        .nav-link:hover {
            color: var(--primary) !important;
            background: var(--primary-light);
        }

        .btn-outline-primary-custom {
            color: var(--text-secondary);
            border: 1.5px solid var(--border);
            border-radius: 8px;
            padding: 0.45rem 1.1rem;
            font-size: 0.85rem;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
        }
        .btn-outline-primary-custom:hover {
            border-color: var(--primary); color: var(--primary);
            background: rgba(245,158,11,0.06);
        }

        .btn-primary-custom {
            background: var(--primary);
            color: var(--navy) !important;
            border: none; border-radius: 8px;
            padding: 0.5rem 1.5rem;
            font-weight: 700;
            transition: all 0.2s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.3rem;
        }
        .btn-primary-custom:hover {
            background: var(--primary-hover);
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(245,158,11,0.4);
        }

        .cart-icon {
            color: var(--text-secondary);
            font-size: 1.25rem;
            text-decoration: none;
            position: relative;
            transition: color 0.2s;
        }
        .cart-icon:hover { color: var(--primary); }

        .theme-toggle {
            background: transparent;
            border: 1.5px solid var(--border);
            border-radius: 10px;
            width: 38px; height: 38px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 1.1rem;
            color: var(--text-secondary);
            transition: all 0.25s;
            flex-shrink: 0;
        }
        .theme-toggle:hover {
            border-color: var(--primary);
            color: var(--primary);
            background: var(--primary-light);
        }
        .theme-toggle .bi-moon-fill { display: inline; }
        .theme-toggle .bi-sun-fill { display: none; }
        [data-theme="dark"] .theme-toggle .bi-moon-fill { display: none; }
        [data-theme="dark"] .theme-toggle .bi-sun-fill { display: inline; }

        /* User dropdown */
        .user-dropdown-btn {
            background: transparent;
            border: 0;
            color: var(--text-primary);
            padding: 0;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-weight: 600;
            font-size: 0.88rem;
        }

        /* Content */
        .main-container { margin-top: 120px; padding-bottom: 80px; }

        .checkout-card {
            background: var(--card-bg);
            border: 1.5px solid var(--border);
            border-radius: 20px;
            padding: 2.5rem;
            box-shadow: var(--card-shadow);
        }

        .product-summary-card {
            background: var(--card-bg);
            border: 1.5px solid var(--border);
            border-radius: 20px;
            padding: 1.5rem;
            box-shadow: var(--card-shadow);
        }

        .summary-img {
            width: 100%; height: 200px;
            object-fit: cover; border-radius: 12px;
            border: 1px solid var(--border);
            background: var(--body-bg);
        }

        .form-control-custom {
            background: var(--body-bg) !important;
            border: 1.5px solid var(--border) !important;
            color: var(--text-primary) !important;
            border-radius: 12px !important;
            padding: 0.8rem 1rem !important;
            font-size: 0.95rem !important;
            transition: border-color 0.2s, box-shadow 0.2s !important;
        }
        .form-control-custom:focus {
            border-color: var(--primary) !important;
            box-shadow: 0 0 0 3px rgba(234,179,8,0.15) !important;
        }

        .form-label-custom {
            font-weight: 700; color: var(--text-secondary);
            margin-bottom: 0.4rem; font-size: 0.82rem;
            text-transform: uppercase; letter-spacing: 0.5px;
        }

        .pricing-summary {
            background: var(--body-bg);
            border-radius: 16px;
            padding: 1.5rem;
            margin: 1.5rem 0;
            border: 1px solid var(--border);
        }
        .summary-row {
            display: flex; justify-content: space-between;
            margin-bottom: 0.75rem; font-size: 0.95rem;
            color: var(--text-secondary);
        }
        .summary-row .fw-bold { color: var(--text-primary); }
        .summary-row.total {
            margin-bottom: 0; padding-top: 0.75rem;
            border-top: 1px solid var(--border);
            font-size: 1.25rem; font-weight: 800;
            color: var(--primary);
        }

        /* Footer */
        footer {
            background: var(--footer-bg);
            border-top: 1px solid var(--footer-border);
            padding: 3rem 0 2rem;
            margin-top: 5rem;
        }
    </style>
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-custom">
        <div class="container">
            <a class="navbar-brand" href="/">
                <i class="bi bi-building-fill brand-icon"></i> OmniRent
            </a>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto">
                    <li class="nav-item"><a class="nav-link" href="/">Trang chủ</a></li>
                </ul>
            </div>
            <div class="ms-auto d-flex gap-3 align-items-center">
                <!-- Theme Toggle -->
                <button class="theme-toggle" id="themeToggle" title="Chuyển chế độ sáng/tối">
                    <i class="bi bi-moon-fill"></i>
                    <i class="bi bi-sun-fill"></i>
                </button>

                <!-- Cart -->
                <a href="/Home/Cart" class="cart-icon position-relative me-3">
                    <i class="bi bi-cart3"></i>
                    <span id="cartBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.65rem; display: none;">0</span>
                </a>

                @if (isAuthenticated) {
                    var userAvatar = User.FindFirst("AvatarUrl")?.Value;
                    <div class="dropdown">
                        <button class="user-dropdown-btn dropdown-toggle" type="button" id="userMenuButton" data-bs-toggle="dropdown" aria-expanded="false">
                            <div class="profile-avatar" style="width: 32px; height: 32px; border-radius: 50%; background: var(--primary); color: var(--navy); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.85rem; overflow: hidden; border: 1.5px solid var(--primary);">
                                @if (!string.IsNullOrEmpty(userAvatar))
                                {
                                    <img src="@userAvatar" alt="Avatar" style="width:100%; height:100%; object-fit:cover;" />
                                }
                                else
                                {
                                    @User.Identity.Name.Substring(0, 1).ToUpper()
                                }
                            </div>
                            <span class="d-none d-md-inline" style="color:var(--text-primary)">@User.Identity.Name</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end p-2 border-0" aria-labelledby="userMenuButton" style="background: var(--card-bg); box-shadow: var(--card-shadow); border-radius: 12px; min-width: 200px;">

                            <li>
                                <a class="dropdown-item rounded-3 py-2 px-3 d-flex align-items-center gap-2" href="/Account/Profile" style="color: var(--text-primary); font-size: 0.85rem; font-weight: 500;">
                                    <i class="bi bi-person-circle text-primary"></i> Trang cá nhân & Lịch sử
                                </a>
                            </li>
                            @if (User.IsInRole("OWNER"))
                            {
                                <li>
                                    <a class="dropdown-item rounded-3 py-2 px-3 d-flex align-items-center gap-2" href="/OwnerDashboard" style="color: var(--text-primary); font-size: 0.85rem; font-weight: 500;">
                                        <i class="bi bi-house-door-fill text-primary"></i> Quản lý tài sản
                                    </a>
                                </li>
                            }
                            @if (User.IsInRole("ADMIN"))
                            {
                                <li>
                                    <a class="dropdown-item rounded-3 py-2 px-3 d-flex align-items-center gap-2" href="/AdminDashboard/Bookings" style="color: var(--text-primary); font-size: 0.85rem; font-weight: 500;">
                                        <i class="bi bi-shield-lock-fill text-primary"></i> Trang quản trị
                                    </a>
                                </li>
                            }
                            <li><hr class="dropdown-divider" style="border-color: var(--border);"></li>
                            <li>
                                <form action="/Account/Logout" method="post" class="m-0">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="dropdown-item rounded-3 py-2 px-3 text-danger d-flex align-items-center gap-2 bg-transparent border-0 w-100 text-start" style="font-size: 0.85rem; font-weight: 600;">
                                        <i class="bi bi-box-arrow-right"></i> Đăng xuất
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>
                } else {
                    <a href="/Account/Login?returnUrl=/Home/Checkout/@Model.Id" class="btn btn-outline-primary-custom">Đăng nhập</a>
                }
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="container main-container">
        <h2 class="mb-5 fw-bold text-center" style="color: var(--text-primary);"><i class="bi bi-wallet2 text-primary"></i> Xác nhận thanh toán &amp; Địa chỉ thuê</h2>

        <div class="row g-5">
            <!-- Left: Product Summary -->
            <div class="col-lg-5">
                <div class="product-summary-card">
                    @{
                        var imagesList = new List<string>();
                        try {
                            if (!string.IsNullOrEmpty(Model.ImagesJson)) {
                                imagesList = System.Text.Json.JsonSerializer.Deserialize<List<string>>(Model.ImagesJson) ?? new List<string>();
                            }
                        } catch { }
                        var mainImg = imagesList.Any() ? imagesList.First() : "https://images.unsplash.com/photo-1522771739844-6a9f6d5f14af?auto=format&fit=crop&w=600&q=80";
                    }
                    <img src="@mainImg" alt="@Model.Name" class="summary-img mb-3" onerror="this.src='https://images.unsplash.com/photo-1522771739844-6a9f6d5f14af?auto=format&fit=crop&w=600&q=80'" />
                    
                    <span class="badge mb-2" style="background: var(--primary-light); color: var(--primary); font-weight: 700;">@(Model.Category?.Name ?? "Sản phẩm")</span>
                    <h4 class="fw-bold mb-3" style="color: var(--text-primary);">@Model.Name</h4>
                    
                    <div class="d-flex justify-content-between mb-2 pb-2 border-bottom" style="border-color: var(--border) !important;">
                        <span class="text-secondary">Đơn giá thuê</span>
                        <span class="fw-bold" style="color: var(--text-primary);">@Model.PricePerDay.ToString("N0")đ / ngày</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-secondary">Cọc khi đặt thuê</span>
                        <span class="fw-bold" style="color: #dc2626;">50% tổng tiền thuê</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="text-secondary">Chủ sở hữu</span>
                        <span style="font-weight: 500; color: var(--text-primary);">@(Model.Owner?.FullName ?? "Chủ đồ")</span>
                    </div>
                </div>
            </div>

            <!-- Right: Checkout Form -->
            <div class="col-lg-7">
                <div class="checkout-card">
                    @if (isAuthenticated) {
                        <div id="bookingError" class="alert alert-danger d-none" role="alert"></div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label for="startDate" class="form-label-custom">Ngày bắt đầu nhận đồ</label>
                                <input type="date" class="form-control form-control-custom" id="startDate" required min="@DateTime.Now.ToString("yyyy-MM-dd")" value="@DateTime.Now.ToString("yyyy-MM-dd")">
                            </div>
                            <div class="col-md-6">
                                <label for="endDate" class="form-label-custom">Ngày trả đồ dự kiến</label>
                                <input type="date" class="form-control form-control-custom" id="endDate" required min="@DateTime.Now.AddDays(1).ToString("yyyy-MM-dd")" value="@DateTime.Now.AddDays(1).ToString("yyyy-MM-dd")">
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label-custom">Địa chỉ nhận tài sản của chủ cho thuê</label>
                            <div class="form-control-custom" style="min-height: 82px; line-height: 1.6;">
                                <i class="bi bi-geo-alt-fill text-danger me-2"></i>@ownerPickupAddress
                            </div>
                            <input type="hidden" id="rentalAddress" value="@ownerPickupAddress" />
                        </div>

                        <div class="pricing-summary">
                            <div class="summary-row">
                                <span>Thời gian thuê</span>
                                <span id="summaryDays" class="fw-bold">1 ngày</span>
                            </div>
                            <div class="summary-row">
                                <span>Tiền cọc cần chuyển (50%)</span>
                                <span id="summaryDeposit" class="fw-bold" style="color: #dc2626;">Calculating...</span>
                            </div>
                            <div class="summary-row total">
                                <span>Tổng cộng chi phí thuê</span>
                                <span id="summaryTotal">Calculating...</span>
                            </div>
                        </div>

                        <button id="btnSubmitBooking" class="btn btn-primary-custom w-100 py-3 mt-2" onclick="submitBookingRequest()">
                            <i class="bi bi-credit-card-fill"></i> Tiến hành thuê &amp; Thanh toán đặt cọc
                        </button>
                    } else {
                        <div class="text-center py-4">
                            <i class="bi bi-lock-fill fs-1 mb-3 d-block" style="color: var(--text-muted);"></i>
                            <p style="color: var(--text-secondary);">Bạn cần đăng nhập tài khoản để thực hiện thanh toán thuê sản phẩm này.</p>
                            <a href="/Account/Login?returnUrl=/Home/Checkout/@Model.Id" class="btn btn-primary-custom px-4 py-2 mt-2">Đăng nhập ngay</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer>
        <div class="container text-center" style="color: var(--footer-text); font-size: 0.9rem;">
            &copy; @DateTime.Now.Year OmniRent. Mọi quyền được bảo lưu.
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const productId = "@Model.Id";
        const pricePerDay = @Model.PricePerDay;

        // =================== Theme Toggle ===================
        (function() {
            const root = document.documentElement;
            const toggle = document.getElementById('themeToggle');
            const storageKey = 'omnirent-theme';

            function getPreferred() {
                const saved = localStorage.getItem(storageKey);
                if (saved) return saved;
                return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
            }

            function applyTheme(theme) {
                root.setAttribute('data-theme', theme);
                localStorage.setItem(storageKey, theme);
            }

            applyTheme(getPreferred());

            if (toggle) {
                toggle.addEventListener('click', () => {
                    const current = root.getAttribute('data-theme') || 'light';
                    applyTheme(current === 'dark' ? 'light' : 'dark');
                });
            }
        })();

        function updateCartBadge() {
            let cart = JSON.parse(localStorage.getItem('cart')) || [];
            let badge = document.getElementById('cartBadge');
            if (badge) {
                if (cart.length > 0) {
                    badge.innerText = cart.length; badge.style.display = 'inline-block';
                } else { badge.style.display = 'none'; }
            }
        }

        document.getElementById('startDate').addEventListener('change', updatePriceEstimate);
        document.getElementById('endDate').addEventListener('change', updatePriceEstimate);

        async function updatePriceEstimate() {
            const startStr = document.getElementById('startDate').value;
            const endStr = document.getElementById('endDate').value;
            const sumDays = document.getElementById('summaryDays');
            const sumTotal = document.getElementById('summaryTotal');
            const sumDeposit = document.getElementById('summaryDeposit');
            if (!startStr || !endStr) return;
            const start = new Date(startStr); const end = new Date(endStr);
            if (end < start) {
                sumDays.innerText = '0 ngày';
                sumTotal.innerText = 'Không hợp lệ';
                if (sumDeposit) sumDeposit.innerText = 'Không hợp lệ';
                return;
            }
            try {
                const res = await fetch('/bookings/estimate-price', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ productId: productId, startDate: startStr, endDate: endStr })
                });
                if (res.ok) {
                    const data = await res.json();
                    const deposit = Math.round(data.totalPrice * 0.5);
                    sumDays.innerText = `${data.days} ngày`;
                    sumTotal.innerText = `${data.totalPrice.toLocaleString('vi-VN')}đ`;
                    if (sumDeposit) sumDeposit.innerText = `${deposit.toLocaleString('vi-VN')}đ`;
                } else {
                    const err = await res.json(); sumTotal.innerText = err.message || 'Lỗi tính giá';
                }
            } catch (e) {
                const diffDays = Math.max(1, Math.ceil(Math.abs(end - start) / (1000 * 60 * 60 * 24)));
                const fallbackTotal = diffDays * pricePerDay;
                const fallbackDeposit = Math.round(fallbackTotal * 0.5);
                sumDays.innerText = `${diffDays} ngày`;
                sumTotal.innerText = `${fallbackTotal.toLocaleString('vi-VN')}đ`;
                if (sumDeposit) sumDeposit.innerText = `${fallbackDeposit.toLocaleString('vi-VN')}đ`;
            }
        }

        async function submitBookingRequest() {
            const startStr = document.getElementById('startDate').value;
            const endStr = document.getElementById('endDate').value;
            const addr = document.getElementById('rentalAddress').value.trim();
            const btn = document.getElementById('btnSubmitBooking');
            const errBox = document.getElementById('bookingError');
            errBox.classList.add('d-none');
            if (!startStr || !endStr) { showError('Vui lòng chọn ngày.'); return; }
            if (!addr) { showError('Vui lòng nhập địa chỉ.'); return; }

            btn.disabled = true; btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status"></span> Đang tạo đơn...';
            try {
                const res = await fetch('/bookings', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ productId: productId, startDate: startStr, endDate: endStr, rentalAddress: addr })
                });
                if (res.ok) {
                    const booking = await res.json(); window.location.href = `/Home/Payment/${booking.id}`;
                } else {
                    const err = await res.json(); showError(err.message || 'Có lỗi xảy ra.');
                    btn.disabled = false; btn.innerText = 'Tiến hành thuê & Thanh toán';
                }
            } catch (e) {
                showError('Lỗi kết nối máy chủ.');
                btn.disabled = false; btn.innerText = 'Tiến hành thuê & Thanh toán';
            }
        }
        function showError(msg) {
            const box = document.getElementById('bookingError');
            box.innerText = msg; box.classList.remove('d-none');
        }
        document.addEventListener('DOMContentLoaded', () => { updateCartBadge(); updatePriceEstimate(); });
    </script>
</body>
