@using OmniRentBackend.Models
@model Booking
@{
    Layout = null;
    var depositAmount = (long)Math.Round(Model.DepositAmount > 0 ? Model.DepositAmount : Model.TotalPrice * 0.5, 0);
    var remainingAmount = (long)Math.Max(0, Model.TotalPrice - depositAmount);
    var transferContent = !string.IsNullOrWhiteSpace(Model.TransferContent)
        ? Model.TransferContent
        : $"COC OMNIRENT {Model.Id.Substring(0, 8).ToUpper()}";
    var owner = Model.Product?.Owner;
    var bankName = !string.IsNullOrWhiteSpace(owner?.BankName) ? owner!.BankName! : "VietinBank";
    var bankAccount = !string.IsNullOrWhiteSpace(owner?.BankAccount) ? owner!.BankAccount! : "102878922105";
    var bankHolder = !string.IsNullOrWhiteSpace(owner?.BankAccountHolder) ? owner!.BankAccountHolder! : "NGUYEN TAN KIET";
    var addInfo = Uri.EscapeDataString(transferContent);
    var accountName = Uri.EscapeDataString(bankHolder);
    var qrUrl = $"https://img.vietqr.io/image/970415-{bankAccount}-compact2.png?amount={depositAmount}&addInfo={addInfo}&accountName={accountName}";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Thanh toán đặt cọc — OmniRent</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>
        :root, [data-theme="light"] {
            --primary:        #eab308; /* Premium Gold Yellow */
            --primary-hover:  #ca8a04;
            --primary-light:  #fef9c3;
            --navy:           #09090b; /* Pure Obsidian Black */
            --navy-2:         #18181b; /* Dark zinc */
            --accent:         #eab308;
            --body-bg:        #fafafa; /* Sleek light gray */
            --section-alt:    #ffffff;
            --text-primary:   #09090b;
            --text-secondary: #4b5563;
            --text-muted:     #9ca3af;
            --border:         #e5e7eb;
            --card-bg:        #ffffff;
            --card-shadow:    0 4px 20px rgba(9,9,11,0.03);
            --navbar-bg:      rgba(255, 255, 255, 0.85);
            --navbar-shadow:  0 1px 2px rgba(9,9,11,0.05);
            --footer-bg:      #09090b;
            --footer-text:    #9ca3af;
            --footer-heading:  #f3f4f6;
            --footer-border:  #1f2937;
        }

        [data-theme="dark"] {
            --primary:        #facc15; /* Vibrant Gold Yellow */
            --primary-hover:  #eab308;
            --primary-light:  rgba(250,204,21,0.1);
            --navy:           #f3f4f6; /* Off-white text */
            --navy-2:         #e5e7eb;
            --accent:         #fbbf24;
            --body-bg:        #09090b; /* Pure Black Background */
            --section-alt:    #121214; /* Charcoal background */
            --text-primary:   #f3f4f6;
            --text-secondary: #9ca3af;
            --text-muted:     #6b7280;
            --border:         #1f2937;
            --card-bg:        #18181b;
            --card-shadow:    0 10px 30px rgba(0,0,0,0.3);
            --navbar-bg:      rgba(9, 9, 11, 0.85);
            --navbar-shadow:  0 1px 0 rgba(255,255,255,0.05);
            --footer-bg:      #020203;
            --footer-text:    #6b7280;
            --footer-heading:  #f3f4f6;
            --footer-border:  #18181b;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--body-bg);
            color: var(--text-primary);
            min-height: 100vh;
            margin: 0; padding: 0;
            display: flex; align-items: center; justify-content: center;
            overflow-x: hidden;
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        .payment-container { width: 100%; max-width: 900px; padding: 2rem 1rem; position: relative; z-index: 1; }

        .payment-card {
            background: var(--card-bg);
            border: 1.5px solid var(--border);
            border-radius: 28px;
            padding: 3rem;
            box-shadow: var(--card-shadow);
            position: relative; overflow: hidden;
        }
        .payment-card::before {
            content: ''; position: absolute;
            top: -50%; left: -50%; width: 200%; height: 200%;
            background: radial-gradient(circle, rgba(234,179,8,0.06), transparent 50%);
            pointer-events: none; z-index: 0;
        }

        .billing-item {
            display: flex; justify-content: space-between;
            margin-bottom: 0.8rem; font-size: 0.95rem;
            color: var(--text-secondary);
        }
        .billing-item.highlight { color: var(--text-primary); font-weight: 700; }

        .total-box {
            background: var(--primary-light);
            border: 1px solid rgba(234,179,8,0.3);
            border-radius: 16px; padding: 1.5rem; margin-top: 1.5rem;
            color: #854d0e;
        }

        .qr-placeholder {
            width: 200px; height: 200px;
            background: white; border-radius: 16px;
            padding: 10px; display: flex; align-items: center; justify-content: center;
            border: 1.5px solid var(--border);
            box-shadow: var(--card-shadow);
            margin: 0 auto;
        }
        .qr-placeholder img { max-width: 100%; height: auto; }

        .btn-pay-custom {
            background: #22c55e;
            color: #fff; border: none; border-radius: 50px;
            padding: 1rem 2rem; font-weight: 700; font-size: 1.1rem;
            transition: all 0.2s;
            box-shadow: 0 4px 14px rgba(34,197,94,0.3);
            width: 100%; position: relative; z-index: 2;
        }
        .btn-pay-custom:hover {
            background: #16a34a; transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(34,197,94,0.4);
        }

        /* Success Animation */
        .success-overlay {
            position: absolute; top: 0; left: 0; right: 0; bottom: 0;
            background: var(--card-bg);
            backdrop-filter: blur(5px);
            z-index: 10; display: flex; flex-direction: column;
            align-items: center; justify-content: center;
            opacity: 0; visibility: hidden; transition: all 0.4s ease;
        }
        .success-overlay.show { opacity: 1; visibility: visible; }
        
        .checkmark-circle {
            width: 100px; height: 100px; border-radius: 50%;
            background: rgba(34,197,94,0.1); border: 3px solid #22c55e;
            display: flex; align-items: center; justify-content: center;
            font-size: 3.5rem; color: #22c55e;
            margin-bottom: 2rem;
            animation: popCheckmark 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275) both;
        }
        @@keyframes popCheckmark {
            0% { transform: scale(0); opacity: 0; }
            100% { transform: scale(1); opacity: 1; }
        }

        /* Theme Toggle floating button */
        .theme-toggle-floating {
            position: fixed;
            top: 20px;
            right: 20px;
            background: var(--card-bg);
            border: 1.5px solid var(--border);
            border-radius: 50%;
            width: 44px; height: 44px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 1.25rem;
            color: var(--text-secondary);
            box-shadow: var(--card-shadow);
            transition: all 0.25s;
            z-index: 1000;
        }
        .theme-toggle-floating:hover {
            border-color: var(--primary);
            color: var(--primary);
            background: var(--primary-light);
        }
        .theme-toggle-floating .bi-moon-fill { display: inline; }
        .theme-toggle-floating .bi-sun-fill { display: none; }
        [data-theme="dark"] .theme-toggle-floating .bi-moon-fill { display: none; }
        [data-theme="dark"] .theme-toggle-floating .bi-sun-fill { display: inline; }
    </style>
</head>
<body>

    <!-- Theme Toggle Floating -->
    <button class="theme-toggle-floating" id="themeToggle" title="Chuyển chế độ sáng/tối">
        <i class="bi bi-moon-fill"></i>
        <i class="bi bi-sun-fill"></i>
    </button>

    <div class="payment-container">
        <div class="payment-card">
            <!-- Success state -->
            <div id="successOverlay" class="success-overlay">
                <div class="checkmark-circle"><i class="bi bi-check-lg"></i></div>
                <h2 class="fw-bold mb-2" style="color: var(--text-primary);">Đã gửi xác nhận chuyển cọc!</h2>
                <p class="text-center" style="color: var(--text-secondary); max-width: 400px;">Đơn thuê của bạn đã chuyển sang trạng thái chờ chủ cho thuê xác nhận tiền cọc.</p>
                <div class="spinner-border mt-3" style="color: var(--primary);" role="status"><span class="visually-hidden">Loading...</span></div>
                <small class="mt-2 text-muted">Đang chuyển hướng về trang cá nhân của bạn...</small>
            </div>

            <div class="d-flex align-items-center justify-content-between border-bottom pb-4 mb-4" style="border-color: var(--border) !important; position: relative; z-index: 2;">
                <div>
                    <h2 class="fw-bold m-0" style="color: var(--text-primary);"><i class="bi bi-shield-check text-primary"></i> Thanh toán đặt cọc</h2>
                    <small style="color: var(--text-muted);">Mã đơn thuê: #@Model.Id.Substring(0, 8).ToUpper()</small>
                </div>
                <a href="/Account/Profile" class="btn btn-sm btn-outline-secondary"><i class="bi bi-x-lg"></i> Quay lại</a>
            </div>

            <div id="paymentError" class="alert alert-danger d-none" role="alert" style="position: relative; z-index: 2;"></div>

            <div class="row g-5" style="position: relative; z-index: 2;">
                <!-- Left: Billing summary -->
                <div class="col-md-6 border-end" style="border-color: var(--border) !important;">
                    <h4 class="mb-4 fw-bold" style="color: var(--text-primary);"><i class="bi bi-receipt-cutoff text-primary"></i> Tóm tắt thuê đồ</h4>

                    <div class="billing-item highlight">
                        <span>Tài sản thuê</span>
                        <span>@(Model.Product?.Name ?? "Sản phẩm")</span>
                    </div>
                    <div class="billing-item">
                        <span>Chủ sở hữu</span>
                        <span>@(Model.Product?.Owner?.FullName ?? "Chủ đồ")</span>
                    </div>
                    <div class="billing-item">
                        <span>Ngày nhận đồ</span>
                        <span>@Model.StartDate.ToString("dd/MM/yyyy")</span>
                    </div>
                    <div class="billing-item">
                        <span>Ngày trả đồ</span>
                        <span>@Model.EndDate.ToString("dd/MM/yyyy")</span>
                    </div>

                    <div class="p-3 my-4 rounded-4" style="background: var(--body-bg); border: 1px solid var(--border);">
                        <h6 class="fw-bold mb-2" style="color: var(--text-primary);"><i class="bi bi-geo-alt-fill text-danger"></i> Địa chỉ nhận tài sản:</h6>
                        <p class="m-0" style="color: var(--text-secondary); font-size: 0.95rem; line-height: 1.6;">@Model.RentalAddress</p>
                    </div>

                    <div class="total-box">
                        <div class="d-flex justify-content-between mb-2">
                            <span>Tổng tiền thuê</span>
                            <span class="fw-bold">@Model.TotalPrice.ToString("N0")đ</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center pt-2 border-top" style="border-color: rgba(234,179,8,0.2) !important;">
                            <span class="fw-bold">Tiền cọc cần chuyển (50%)</span>
                            <h3 class="fw-bold m-0 text-danger">@depositAmount.ToString("N0")đ</h3>
                        </div>
                        <div class="d-flex justify-content-between mt-2">
                            <span>Còn lại trả trực tiếp/chuyển khoản</span>
                            <span class="fw-bold">@remainingAmount.ToString("N0")đ</span>
                        </div>
                    </div>
                </div>

                <!-- Right: Simulated payment interface -->
                <div class="col-md-6 d-flex flex-column justify-content-between text-center">
                    <div>
                        <h4 class="mb-4 fw-bold" style="color: var(--text-primary);"><i class="bi bi-qr-code text-primary"></i> Chuyển khoản QR ngân hàng</h4>
                        <p class="mb-4" style="color: var(--text-secondary); font-size: 0.9rem;">Quét mã QR sau để thanh toán tiền đặt cọc tự động qua ngân hàng.</p>
                        
                        <div class="qr-placeholder mb-4">
                            <img src="@qrUrl" alt="Mã thanh toán QR" />
                        </div>

                        <div style="color: var(--text-secondary); font-size: 0.85rem;">
                            <div>Chủ tài khoản: <strong style="color: var(--text-primary);">@bankHolder</strong></div>
                            <div>Số tài khoản: <strong style="color: var(--text-primary);">@bankAccount</strong> (@bankName)</div>
                            <div>Số tiền: <strong style="color: var(--text-primary);">@depositAmount.ToString("N0")đ</strong></div>
                            <div>Nội dung: <strong style="color: var(--text-primary);">@transferContent</strong></div>
                        </div>
                    </div>

                    <div class="mt-4 pt-3">
                        <button id="btnConfirmPayment" class="btn btn-pay-custom py-3" onclick="confirmPayment()">
                            <i class="bi bi-check-circle-fill"></i> Tôi đã chuyển tiền cọc
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const bookingId = "@Model.Id";

        // =================== Theme Toggle ===================
        (function() {
            const root = document.documentElement;
            const toggle = document.getElementById('themeToggle');
            const storageKey = 'omnirent-theme';

            function getPreferred() {
                const saved = localStorage.getItem(storageKey);
                if (saved) return saved;
                return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
            }

            function applyTheme(theme) {
                root.setAttribute('data-theme', theme);
                localStorage.setItem(storageKey, theme);
            }

            applyTheme(getPreferred());

            if (toggle) {
                toggle.addEventListener('click', () => {
                    const current = root.getAttribute('data-theme') || 'light';
                    applyTheme(current === 'dark' ? 'light' : 'dark');
                });
            }
        })();

        async function confirmPayment() {
            const btn = document.getElementById('btnConfirmPayment');
            const errorBox = document.getElementById('paymentError');
            const successOverlay = document.getElementById('successOverlay');

            errorBox.classList.add('d-none');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Đang xác thực giao dịch...';

            try {
                const res = await fetch(`/bookings/${bookingId}/pay-deposit`, {
                    method: 'PUT', headers: { 'Content-Type': 'application/json' }
                });

                if (res.ok) {
                    successOverlay.classList.add('show');
                    // Chuyển hướng về trang cá nhân & lịch sử đặt thuê sau khi thanh toán thành công
                    setTimeout(() => { window.location.href = '/Account/Profile'; }, 3000);
                } else {
                    const err = await res.json();
                    showError(err.message || 'Xác thực thanh toán thất bại.');
                    btn.disabled = false; btn.innerHTML = '<i class="bi bi-check-circle-fill"></i> Tôi đã chuyển tiền cọc';
                }
            } catch (e) {
                showError('Không thể kết nối máy chủ để kiểm tra giao dịch.');
                btn.disabled = false; btn.innerHTML = '<i class="bi bi-check-circle-fill"></i> Tôi đã chuyển tiền cọc';
            }
        }
        function showError(msg) {
            const box = document.getElementById('paymentError');
            box.innerText = msg; box.classList.remove('d-none');
        }
    </script>
</body>
</html>
