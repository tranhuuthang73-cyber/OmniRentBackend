@using OmniRentBackend.Models.ViewModels
@model HomeViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Trang chủ — OmniRent</title>
    <meta name="description" content="Nền tảng kết nối cho thuê tài sản trực tuyến hàng đầu." />

    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Bootstrap & Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>
        :root {
            --primary: #6C63FF;
            --primary-hover: #5a52d5;
            --secondary: #0f0c29;
            --dark-bg: #1a1a3e;
            --card-bg: rgba(255, 255, 255, 0.05);
            --text-main: #ffffff;
            --text-muted: #a89fd8;
            --border-color: rgba(255, 255, 255, 0.1);
            --glass-bg: rgba(26, 26, 62, 0.85);
        }

        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, var(--secondary) 0%, var(--dark-bg) 100%);
            color: var(--text-main);
            min-height: 100vh;
            margin: 0;
            padding: 0;
            overflow-x: hidden;
        }

        /* Navbar */
        .navbar-custom {
            background: var(--glass-bg);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border-color);
            padding: 1rem 0;
            position: fixed;
            top: 0;
            width: 100%;
            z-index: 1000;
        }

        .navbar-brand {
            font-weight: 800;
            font-size: 1.5rem;
            color: var(--text-main) !important;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .brand-icon {
            color: var(--primary);
            font-size: 1.8rem;
        }

        .nav-link {
            color: var(--text-main) !important;
            font-weight: 500;
            transition: color 0.3s;
        }

        .nav-link:hover {
            color: var(--primary) !important;
        }

        .btn-outline-primary-custom {
            color: var(--text-main);
            border: 1px solid var(--primary);
            border-radius: 50px;
            padding: 0.5rem 1.5rem;
            font-weight: 500;
            transition: all 0.3s;
        }

        .btn-outline-primary-custom:hover {
            background: var(--primary);
            color: white;
            box-shadow: 0 4px 15px rgba(108, 99, 255, 0.4);
        }

        .btn-primary-custom {
            background: var(--primary);
            color: white;
            border: none;
            border-radius: 50px;
            padding: 0.5rem 1.5rem;
            font-weight: 600;
            transition: all 0.3s;
        }

        .btn-primary-custom:hover {
            background: var(--primary-hover);
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(108, 99, 255, 0.4);
        }

        /* Hero Section */
        .hero-section {
            padding: 180px 0 100px;
            position: relative;
            text-align: center;
        }

        .hero-bg-orb {
            position: absolute;
            width: 500px;
            height: 500px;
            background: radial-gradient(circle, var(--primary), transparent 70%);
            top: 10%;
            left: 50%;
            transform: translateX(-50%);
            filter: blur(100px);
            opacity: 0.2;
            z-index: -1;
            animation: pulseOrb 6s infinite alternate ease-in-out;
        }

        @@keyframes pulseOrb {
            0% { transform: translateX(-50%) scale(1); opacity: 0.15; }
            100% { transform: translateX(-50%) scale(1.1); opacity: 0.25; }
        }

        .hero-title {
            font-size: 4rem;
            font-weight: 800;
            margin-bottom: 1.5rem;
            background: linear-gradient(90deg, #fff 0%, #a89fd8 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            line-height: 1.2;
        }

        .hero-subtitle {
            font-size: 1.25rem;
            color: var(--text-muted);
            max-width: 600px;
            margin: 0 auto 3rem;
        }

        /* Search Bar */
        .search-box {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 50px;
            padding: 0.5rem;
            display: flex;
            max-width: 700px;
            margin: 0 auto;
            backdrop-filter: blur(10px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.2);
        }

        .search-input {
            background: transparent;
            border: none;
            color: white;
            padding: 1rem 1.5rem;
            width: 100%;
            outline: none;
            font-size: 1.1rem;
        }

        .search-input::placeholder {
            color: var(--text-muted);
        }

        .btn-search {
            background: var(--primary);
            color: white;
            border: none;
            border-radius: 40px;
            padding: 0 2rem;
            font-weight: 600;
            transition: all 0.3s;
        }

        .btn-search:hover {
            background: var(--primary-hover);
            box-shadow: 0 4px 15px rgba(108, 99, 255, 0.4);
        }

        /* Section Titles */
        .section-title {
            font-size: 2.5rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
        }

        .section-subtitle {
            color: var(--text-muted);
            margin-bottom: 3rem;
        }

        /* Categories */
        .category-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 20px;
            padding: 2rem 1.5rem;
            text-align: center;
            transition: all 0.3s ease;
            cursor: pointer;
            height: 100%;
            backdrop-filter: blur(5px);
        }

        .category-card.active-category {
            border-color: var(--primary);
            background: rgba(108, 99, 255, 0.2);
            box-shadow: 0 10px 30px rgba(108, 99, 255, 0.3);
            transform: translateY(-5px);
        }

        .category-card:hover {
            transform: translateY(-10px);
            border-color: var(--primary);
            background: rgba(108, 99, 255, 0.1);
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        }

        .category-icon {
            font-size: 2.5rem;
            color: var(--primary);
            margin-bottom: 1rem;
        }

        .category-name {
            font-weight: 600;
            font-size: 1.2rem;
            margin: 0;
        }

        /* Products */
        .product-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 20px;
            overflow: hidden;
            transition: all 0.3s ease;
            height: 100%;
            display: flex;
            flex-direction: column;
        }

        .product-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 40px rgba(0,0,0,0.3);
            border-color: rgba(255,255,255,0.2);
        }

        .product-img-wrapper {
            position: relative;
            padding-top: 65%; /* Aspect ratio */
            overflow: hidden;
            background: #2a2a4a;
        }

        .product-img {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s ease;
        }

        .product-card:hover .product-img {
            transform: scale(1.05);
        }

        .product-badge {
            position: absolute;
            top: 1rem;
            right: 1rem;
            background: rgba(0,0,0,0.6);
            backdrop-filter: blur(5px);
            padding: 0.4rem 0.8rem;
            border-radius: 50px;
            font-size: 0.85rem;
            font-weight: 600;
            color: #43e97b;
            border: 1px solid rgba(67, 233, 123, 0.3);
        }

        .product-content {
            padding: 1.5rem;
            flex-grow: 1;
            display: flex;
            flex-direction: column;
        }

        .product-category {
            font-size: 0.85rem;
            color: var(--primary);
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 0.5rem;
        }

        .product-title {
            font-size: 1.25rem;
            font-weight: 700;
            margin-bottom: 1rem;
            color: white;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .product-footer {
            margin-top: auto;
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            border-top: 1px solid var(--border-color);
            padding-top: 1.2rem;
        }

        .product-price {
            font-size: 1.5rem;
            font-weight: 800;
            color: white;
        }

        .product-price span {
            font-size: 0.9rem;
            font-weight: 400;
            color: var(--text-muted);
        }

        .product-owner {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.9rem;
            color: var(--text-muted);
        }

        .owner-avatar {
            width: 24px;
            height: 24px;
            border-radius: 50%;
            background: var(--primary);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.7rem;
            color: white;
        }

        /* Footer */
        footer {
            background: rgba(0,0,0,0.3);
            border-top: 1px solid var(--border-color);
            padding: 4rem 0 2rem;
            margin-top: 5rem;
        }

        .footer-brand {
            font-size: 1.8rem;
            font-weight: 800;
            margin-bottom: 1rem;
        }

        .footer-text {
            color: var(--text-muted);
            max-width: 300px;
        }

        .footer-title {
            font-weight: 700;
            margin-bottom: 1.5rem;
            color: white;
        }

        .footer-links {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .footer-links li {
            margin-bottom: 0.8rem;
        }

        .footer-links a {
            color: var(--text-muted);
            text-decoration: none;
            transition: color 0.3s;
        }

        .footer-links a:hover {
            color: var(--primary);
        }

        @@media (max-width: 768px) {
            .hero-title { font-size: 2.5rem; }
            .hero-section { padding: 140px 0 60px; }
            .search-box { flex-direction: column; border-radius: 20px; padding: 1rem; gap: 1rem; }
            .btn-search { padding: 1rem; border-radius: 10px; }
        }
    </style>
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-custom">
        <div class="container">
            <a class="navbar-brand" href="/">
                <i class="bi bi-building-fill brand-icon"></i> OmniRent
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <i class="bi bi-list text-white fs-2"></i>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/">Trang chủ</a>
                    </li>
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/Home/MyBookings">Đơn hàng của tôi</a>
                        </li>
                    }
                    <li class="nav-item">
                        <a class="nav-link" href="#">Khám phá</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#">Về chúng tôi</a>
                    </li>
                </ul>
                <div class="d-flex gap-3 mt-3 mt-lg-0 align-items-center">
                    <a href="/Home/Cart" class="position-relative text-white me-3 d-flex align-items-center" style="font-size: 1.3rem; text-decoration: none;">
                        <i class="bi bi-cart3"></i>
                        <span id="cartBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.65rem; display: none;">0</span>
                    </a>

                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <span class="text-white fw-bold me-2">Xin chào, @User.Identity.Name</span>
                        
                        @if (User.IsInRole("ADMIN"))
                        {
                            <a href="/AdminDashboard/Bookings" class="btn btn-outline-primary-custom">Trang Quản trị</a>
                        }

                        <form action="/Account/Logout" method="post" class="d-inline m-0">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-primary-custom">Đăng xuất</button>
                        </form>
                    }
                    else
                    {
                        <a href="/Account/Login" class="btn btn-outline-primary-custom">Đăng nhập</a>
                        <a href="/Account/Register" class="btn btn-primary-custom">Đăng ký</a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero-section">
        <div class="hero-bg-orb"></div>
        <div class="container">
            <h1 class="hero-title">Thuê mọi thứ bạn cần<br />Dễ dàng & Nhanh chóng</h1>
            <p class="hero-subtitle">Khám phá hàng ngàn tài sản, thiết bị và dịch vụ chất lượng cao từ cộng đồng OmniRent. Tiết kiệm chi phí, tối đa hóa giá trị.</p>
            
            <div class="search-box">
                <i class="bi bi-search ms-3 mt-3 text-muted"></i>
                <input type="text" class="search-input" placeholder="Bạn muốn thuê gì hôm nay?" />
                <button class="btn-search">Tìm kiếm</button>
            </div>
        </div>
    </section>

    <!-- Categories Section -->
    <section class="py-5">
        <div class="container">
            <div class="text-center mb-5">
                <h2 class="section-title">Danh mục nổi bật</h2>
                <p class="section-subtitle">Khám phá các loại tài sản phong phú trên OmniRent</p>
            </div>
            
            <div class="row g-4 justify-content-center">
                @if (Model.Categories != null && Model.Categories.Any())
                {
                    foreach (var category in Model.Categories)
                    {
                        <div class="col-6 col-md-4 col-lg-3">
                            <a href="/?categoryId=@category.Id" style="text-decoration: none; color: inherit;">
                                <div class="category-card @(ViewBag.SelectedCategoryId == category.Id ? "active-category" : "")">
                                    <i class="bi bi-grid-fill category-icon"></i>
                                    <h3 class="category-name">@category.Name</h3>
                                </div>
                            </a>
                        </div>
                    }
                }
                else
                {
                    <!-- Placeholder categories if DB is empty -->
                    var mockCategories = new[] { 
                        new { Icon = "bi-car-front-fill", Name = "Xe cộ" },
                        new { Icon = "bi-house-heart-fill", Name = "Bất động sản" },
                        new { Icon = "bi-camera-fill", Name = "Thiết bị điện tử" },
                        new { Icon = "bi-tools", Name = "Dụng cụ cơ khí" }
                    };
                    
                    foreach (var cat in mockCategories)
                    {
                        <div class="col-6 col-md-4 col-lg-3">
                            <div class="category-card">
                                <i class="bi @cat.Icon category-icon"></i>
                                <h3 class="category-name">@cat.Name</h3>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </section>

    <!-- Featured Products Section -->
    <section class="py-5 mb-5">
        <div class="container">
            <div class="d-flex justify-content-between align-items-end mb-5">
                <div>
                    @if (ViewBag.SelectedCategoryId != null)
                    {
                        var selectedCat = Model.Categories.FirstOrDefault(c => c.Id == ViewBag.SelectedCategoryId);
                        <h2 class="section-title">Sản phẩm: @selectedCat?.Name</h2>
                        <a href="/" class="btn btn-sm btn-outline-secondary mt-2 text-white"><i class="bi bi-arrow-left"></i> Xem tất cả danh mục</a>
                    }
                    else
                    {
                        <h2 class="section-title">Tài sản mới nhất</h2>
                        <p class="section-subtitle mb-0">Các tài sản vừa được đăng cho thuê</p>
                    }
                </div>
                <a href="#" class="text-link" style="color: var(--primary); text-decoration: none; font-weight: 500;">Xem tất cả <i class="bi bi-arrow-right"></i></a>
            </div>

            <div class="row g-4">
                @if (Model.FeaturedProducts != null && Model.FeaturedProducts.Any())
                {
                    foreach (var product in Model.FeaturedProducts)
                    {
                        <div class="col-12 col-md-6 col-lg-3">
                            <a href="/Home/ProductDetails/@product.Id" style="text-decoration: none; color: inherit; display: block; height: 100%;">
                                <div class="product-card">
                                    <div class="product-img-wrapper">
                                        <div class="product-badge">Có sẵn</div>
                                        @{
                                            var firstImage = "https://images.unsplash.com/photo-1522771739844-6a9f6d5f14af?auto=format&fit=crop&w=600&q=80"; // Default
                                            try {
                                                if (!string.IsNullOrEmpty(product.ImagesJson)) {
                                                    var images = System.Text.Json.JsonSerializer.Deserialize<List<string>>(product.ImagesJson);
                                                    if (images != null && images.Any()) {
                                                        firstImage = images.First();
                                                    }
                                                }
                                            } catch { }
                                        }
                                        <img src="@firstImage" alt="@product.Name" class="product-img" onerror="this.src='https://images.unsplash.com/photo-1522771739844-6a9f6d5f14af?auto=format&fit=crop&w=600&q=80'" />
                                    </div>
                                    <div class="product-content">
                                        <div class="product-category">@(product.Category?.Name ?? "Chung")</div>
                                        <h3 class="product-title">@product.Name</h3>
                                        <div class="product-footer">
                                            <div class="product-price">
                                                @product.PricePerDay.ToString("N0")đ <span>/ ngày</span>
                                            </div>
                                            <div class="product-owner" title="@(product.Owner?.FullName ?? "Người dùng")">
                                                <div class="owner-avatar">
                                                    @((product.Owner?.FullName ?? "U").Substring(0, 1).ToUpper())
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </a>
                        </div>
                    }
                }
                else
                {
                    <!-- Mock data if DB is empty to show aesthetics -->
                    <div class="col-12 text-center text-muted py-5">
                        <i class="bi bi-box-seam fs-1 mb-3 d-block"></i>
                        <p>Chưa có sản phẩm nào được đăng.</p>
                    </div>
                }
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer>
        <div class="container">
            <div class="row g-5">
                <div class="col-lg-4">
                    <div class="footer-brand text-white">
                        <i class="bi bi-building-fill" style="color: var(--primary);"></i> OmniRent
                    </div>
                    <p class="footer-text">Nền tảng kết nối người thuê và người cho thuê nhanh chóng, an toàn và minh bạch nhất hiện nay.</p>
                </div>
                <div class="col-lg-2 col-md-4">
                    <h4 class="footer-title">Khám phá</h4>
                    <ul class="footer-links">
                        <li><a href="#">Tất cả tài sản</a></li>
                        <li><a href="#">Danh mục nổi bật</a></li>
                        <li><a href="#">Chủ cho thuê uy tín</a></li>
                    </ul>
                </div>
                <div class="col-lg-2 col-md-4">
                    <h4 class="footer-title">Hỗ trợ</h4>
                    <ul class="footer-links">
                        <li><a href="#">Trung tâm trợ giúp</a></li>
                        <li><a href="#">Quy định an toàn</a></li>
                        <li><a href="#">Chính sách bảo mật</a></li>
                    </ul>
                </div>
                <div class="col-lg-4 col-md-4">
                    <h4 class="footer-title">Theo dõi chúng tôi</h4>
                    <div class="d-flex gap-3">
                        <a href="#" style="color: var(--text-muted); font-size: 1.5rem;"><i class="bi bi-facebook"></i></a>
                        <a href="#" style="color: var(--text-muted); font-size: 1.5rem;"><i class="bi bi-instagram"></i></a>
                        <a href="#" style="color: var(--text-muted); font-size: 1.5rem;"><i class="bi bi-twitter-x"></i></a>
                    </div>
                </div>
            </div>
            <div class="text-center mt-5 pt-4 border-top" style="border-color: var(--border-color) !important; color: var(--text-muted); font-size: 0.9rem;">
                &copy; @DateTime.Now.Year OmniRent. Mọi quyền được bảo lưu.
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function updateCartBadge() {
            let cart = JSON.parse(localStorage.getItem('cart')) || [];
            let badge = document.getElementById('cartBadge');
            if (badge) {
                if (cart.length > 0) {
                    badge.innerText = cart.length;
                    badge.style.display = 'inline-block';
                } else {
                    badge.style.display = 'none';
                }
            }
        }
        document.addEventListener('DOMContentLoaded', updateCartBadge);
    </script>
</body>
</html>