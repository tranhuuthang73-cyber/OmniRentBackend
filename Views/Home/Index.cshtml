@using OmniRentBackend.Models.ViewModels
@model HomeViewModel
@{
    Layout = null;

    string getCategoryIcon(string slug) => slug switch
    {
        "mobility" => "bi-car-front-fill",
        "tech-gear" => "bi-cpu-fill",
        "apparel" => "bi-tag-fill",
        "xe-may" => "bi-bicycle",
        "xe-dien" => "bi-lightning-charge",
        "xe-dap" => "bi-bicycle",
        "laptop" => "bi-laptop",
        "may-anh" => "bi-camera",
        "may-chieu" => "bi-projector",
        "loa" => "bi-speaker",
        "vay-tiec" => "bi-gender-female",
        "vest" => "bi-person-square",
        "cosplay" => "bi-emoji-smile",
        _ => "bi-grid-fill"
    };
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Trang chủ — OmniRent</title>
    <meta name="description" content="Nền tảng kết nối cho thuê tài sản trực tuyến hàng đầu." />

    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Bootstrap & Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>
        html {
            scroll-behavior: smooth;
        }
        /* ============================================================
           OMNIRENT — Light/Dark Theme  |  Gold Yellow & Obsidian Black
           ============================================================ */
        :root, [data-theme="light"] {
            --primary:        #eab308; /* Premium Gold Yellow */
            --primary-hover:  #ca8a04;
            --primary-light:  #fef9c3;
            --navy:           #09090b; /* Pure Obsidian Black */
            --navy-2:         #18181b; /* Dark zinc */
            --accent:         #eab308;
            --body-bg:        #fafafa; /* Sleek light gray */
            --section-alt:    #ffffff;
            --text-primary:   #09090b;
            --text-secondary: #4b5563;
            --text-muted:     #9ca3af;
            --border:         #e5e7eb;
            --card-bg:        #ffffff;
            --card-shadow:    0 4px 20px rgba(9,9,11,0.03);
            --navbar-bg:      rgba(255, 255, 255, 0.85);
            --navbar-shadow:  0 1px 2px rgba(9,9,11,0.05);
            --hero-bg:        #ffffff;
            --hero-circle:    rgba(234,179,8,0.06);
            --search-border:  #e5e7eb;
            --search-shadow:  0 4px 30px rgba(9,9,11,0.05);
            --footer-bg:      #09090b;
            --footer-text:    #9ca3af;
            --footer-heading:  #f3f4f6;
            --footer-border:  #1f2937;
            --dropzone-bg:    #fafafa;
            --preview-bg:     #09090b;
            --tag-color:      #854d0e;
        }

        [data-theme="dark"] {
            --primary:        #facc15; /* Vibrant Gold Yellow */
            --primary-hover:  #eab308;
            --primary-light:  rgba(250,204,21,0.1);
            --navy:           #f3f4f6; /* Off-white text */
            --navy-2:         #e5e7eb;
            --accent:         #fbbf24;
            --body-bg:        #09090b; /* Pure Black Background */
            --section-alt:    #121214; /* Charcoal background */
            --text-primary:   #f3f4f6;
            --text-secondary: #9ca3af;
            --text-muted:     #6b7280;
            --border:         #1f2937;
            --card-bg:        #18181b;
            --card-shadow:    0 10px 30px rgba(0,0,0,0.3);
            --navbar-bg:      rgba(9, 9, 11, 0.85);
            --navbar-shadow:  0 1px 0 rgba(255,255,255,0.05);
            --hero-bg:        #09090b;
            --hero-circle:    rgba(250,204,21,0.08);
            --search-border:  #1f2937;
            --search-shadow:  0 4px 30px rgba(0,0,0,0.4);
            --footer-bg:      #020203;
            --footer-text:    #6b7280;
            --footer-heading:  #f3f4f6;
            --footer-border:  #18181b;
            --dropzone-bg:    #18181b;
            --preview-bg:     #020203;
            --tag-color:      #fde047;
        }

        * { box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--body-bg);
            color: var(--text-primary);
            min-height: 100vh;
            margin: 0;
            padding: 0;
            overflow-x: hidden;
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        /* ===================== NAVBAR ===================== */
        .navbar-custom {
            background: var(--navbar-bg);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border);
            padding: 0.875rem 0;
            position: fixed;
            top: 0;
            width: 100%;
            z-index: 1000;
            box-shadow: var(--navbar-shadow);
            transition: all 0.3s ease;
        }

        .navbar-brand {
            font-weight: 800;
            font-size: 1.4rem;
            color: var(--navy) !important;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            text-decoration: none;
        }

        .brand-icon {
            color: var(--primary);
            font-size: 1.6rem;
        }

        .nav-link-custom {
            color: var(--text-secondary) !important;
            font-weight: 500;
            font-size: 0.9rem;
            padding: 0.5rem 0.85rem !important;
            border-radius: 6px;
            transition: all 0.2s;
            text-decoration: none;
        }

        .nav-link-custom:hover {
            color: var(--primary) !important;
            background: var(--primary-light);
        }

        /* Navbar Buttons */
        .btn-nav-outline {
            color: var(--text-secondary);
            border: 1.5px solid var(--border);
            border-radius: 8px;
            padding: 0.45rem 1.1rem;
            font-size: 0.85rem;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
        }
        .btn-nav-outline:hover {
            border-color: var(--primary);
            color: var(--primary);
            background: rgba(245,158,11,0.06);
        }

        .btn-nav-primary {
            background: var(--primary);
            color: var(--navy) !important;
            border: none;
            border-radius: 8px;
            padding: 0.45rem 1.2rem;
            font-size: 0.85rem;
            font-weight: 700;
            text-decoration: none;
            transition: all 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
        }
        .btn-nav-primary:hover {
            background: var(--primary-hover);
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(245,158,11,0.4);
        }

        .cart-icon {
            color: var(--text-secondary);
            font-size: 1.25rem;
            text-decoration: none;
            position: relative;
            transition: color 0.2s;
        }
        .cart-icon:hover { color: var(--primary); }

        /* ===================== HERO ===================== */
        .hero-section {
            padding: 160px 0 90px;
            background: var(--hero-bg);
            position: relative;
            overflow: hidden;
            text-align: center;
            transition: background-color 0.3s ease;
        }

        /* Decorative circles */
        .hero-section::before {
            content: '';
            position: absolute;
            width: 800px; height: 600px;
            border-radius: 50%;
            background: radial-gradient(circle, var(--hero-circle), transparent 60%);
            top: -150px; left: 50%;
            transform: translateX(-50%);
            pointer-events: none;
        }

        .hero-tag {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            background: var(--primary-light);
            border: 1px solid rgba(245,158,11,0.25);
            color: var(--tag-color);
            font-size: 0.78rem;
            font-weight: 700;
            letter-spacing: 0.5px;
            padding: 0.35rem 0.9rem;
            border-radius: 50px;
            margin-bottom: 1.25rem;
            text-transform: uppercase;
        }

        .hero-title {
            font-size: 3.8rem;
            font-weight: 800;
            color: var(--navy);
            line-height: 1.15;
            margin-bottom: 1.25rem;
            letter-spacing: -0.5px;
        }

        .hero-title .highlight {
            color: var(--primary);
        }

        .hero-subtitle {
            font-size: 1.1rem;
            color: var(--text-secondary);
            max-width: 580px;
            margin: 0 auto 2.5rem;
            line-height: 1.7;
        }

        /* Search box */
        .search-box {
            background: var(--card-bg);
            border-radius: 14px;
            padding: 6px 6px 6px 1.25rem;
            display: flex;
            align-items: center;
            max-width: 660px;
            margin: 0 auto;
            border: 1.5px solid var(--search-border);
            box-shadow: var(--search-shadow);
            transition: background-color 0.3s ease, border-color 0.3s ease;
        }

        .search-icon {
            color: #94a3b8;
            font-size: 1.1rem;
            flex-shrink: 0;
            margin-right: 0.5rem;
        }

        .search-input {
            background: transparent;
            border: none;
            color: var(--text-primary);
            padding: 0.75rem 0.5rem;
            width: 100%;
            outline: none;
            font-size: 0.95rem;
            font-family: 'Inter', sans-serif;
        }
        .search-input::placeholder { color: var(--text-muted); }

        .btn-search {
            background: var(--primary);
            color: var(--navy);
            border: none;
            border-radius: 10px;
            padding: 0.75rem 1.75rem;
            font-weight: 700;
            font-size: 0.9rem;
            transition: all 0.2s;
            white-space: nowrap;
            flex-shrink: 0;
        }
        .btn-search:hover {
            background: var(--primary-hover);
            box-shadow: 0 4px 15px rgba(245,158,11,0.4);
        }

        /* ===================== IMAGE SCAN BUTTON ===================== */
        .btn-scan {
            background: transparent;
            border: 1.5px solid var(--border);
            border-radius: 10px;
            padding: 0.75rem;
            color: var(--text-secondary);
            font-size: 1.15rem;
            cursor: pointer;
            transition: all 0.25s;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 6px;
            position: relative;
        }
        .btn-scan:hover {
            border-color: var(--primary);
            color: var(--primary);
            background: var(--primary-light);
            transform: scale(1.05);
        }
        .btn-scan .scan-tooltip {
            position: absolute;
            bottom: -34px;
            left: 50%;
            transform: translateX(-50%);
            background: var(--navy);
            color: #fff;
            font-size: 0.68rem;
            font-weight: 600;
            padding: 4px 10px;
            border-radius: 6px;
            white-space: nowrap;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.2s;
        }
        .btn-scan:hover .scan-tooltip { opacity: 1; }

        /* ===================== SCAN MODAL ===================== */
        .scan-overlay {
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(15,23,42,0.7);
            backdrop-filter: blur(8px);
            z-index: 9999;
            display: none;
            align-items: center;
            justify-content: center;
            animation: fadeIn 0.25s ease;
        }
        .scan-overlay.active { display: flex; }

        @@keyframes fadeIn {
            from { opacity: 0; }
            to   { opacity: 1; }
        }
        @@keyframes slideUp {
            from { opacity: 0; transform: translateY(30px) scale(0.96); }
            to   { opacity: 1; transform: translateY(0) scale(1); }
        }
        @@keyframes pulse-ring {
            0%   { transform: scale(0.9); opacity: 1; }
            100% { transform: scale(1.6); opacity: 0; }
        }
        @@keyframes scan-line {
            0%   { top: 10%; }
            50%  { top: 85%; }
            100% { top: 10%; }
        }

        .scan-modal {
            background: #fff;
            border-radius: 20px;
            width: 95%;
            max-width: 580px;
            max-height: 92vh;
            overflow-y: auto;
            box-shadow: 0 25px 80px rgba(0,0,0,0.35);
            animation: slideUp 0.35s ease;
            position: relative;
        }

        .scan-modal-header {
            padding: 1.75rem 2rem 0;
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
        }
        .scan-modal-header h3 {
            font-size: 1.3rem;
            font-weight: 800;
            margin: 0;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        .scan-modal-header h3 i {
            color: var(--primary);
            font-size: 1.4rem;
        }
        .scan-modal-header p {
            color: var(--text-secondary);
            font-size: 0.85rem;
            margin: 0.35rem 0 0;
        }
        .scan-close {
            background: #f1f5f9;
            border: none;
            border-radius: 10px;
            width: 36px; height: 36px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            color: var(--text-secondary);
            cursor: pointer;
            transition: all 0.2s;
            flex-shrink: 0;
        }
        .scan-close:hover { background: #fee2e2; color: #dc2626; }

        .scan-modal-body {
            padding: 1.5rem 2rem 2rem;
        }

        /* Dropzone */
        .scan-dropzone {
            border: 2.5px dashed #cbd5e1;
            border-radius: 16px;
            padding: 2.5rem 1.5rem;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s;
            background: #f8fafc;
            position: relative;
        }
        .scan-dropzone:hover,
        .scan-dropzone.drag-over {
            border-color: var(--primary);
            background: #fffbeb;
        }
        .scan-dropzone-icon {
            width: 72px; height: 72px;
            border-radius: 50%;
            background: var(--primary-light);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1rem;
            font-size: 1.8rem;
            color: var(--primary);
            position: relative;
        }
        .scan-dropzone-icon::after {
            content: '';
            position: absolute;
            width: 100%; height: 100%;
            border-radius: 50%;
            border: 2px solid var(--primary);
            opacity: 0.3;
            animation: pulse-ring 2s infinite;
        }
        .scan-dropzone h4 {
            font-size: 1rem;
            font-weight: 700;
            margin: 0 0 0.35rem;
        }
        .scan-dropzone p {
            color: var(--text-muted);
            font-size: 0.82rem;
            margin: 0;
        }
        .scan-dropzone .supported-types {
            margin-top: 0.75rem;
            font-size: 0.72rem;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.3rem;
        }

        /* Preview */
        .scan-preview {
            display: none;
            border-radius: 16px;
            overflow: hidden;
            position: relative;
            background: #0f172a;
        }
        .scan-preview img {
            width: 100%;
            max-height: 300px;
            object-fit: contain;
            display: block;
        }
        .scan-preview .scan-line {
            position: absolute;
            left: 5%; right: 5%;
            height: 3px;
            background: linear-gradient(90deg, transparent, var(--primary), transparent);
            box-shadow: 0 0 15px var(--primary), 0 0 40px rgba(245,158,11,0.3);
            animation: scan-line 2s ease-in-out infinite;
            border-radius: 2px;
            display: none;
        }
        .scan-preview.scanning .scan-line { display: block; }
        .scan-preview .scan-corners {
            position: absolute;
            top: 12px; left: 12px; right: 12px; bottom: 12px;
            border: 2px solid rgba(245,158,11,0.5);
            border-radius: 8px;
            pointer-events: none;
        }
        .scan-actions {
            display: none;
            gap: 0.75rem;
            margin-top: 1rem;
        }
        .scan-actions.active { display: flex; }
        .btn-scan-action {
            flex: 1;
            padding: 0.75rem;
            border-radius: 10px;
            font-weight: 700;
            font-size: 0.88rem;
            border: none;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.4rem;
        }
        .btn-scan-submit {
            background: var(--primary);
            color: var(--navy);
        }
        .btn-scan-submit:hover {
            background: var(--primary-hover);
            transform: translateY(-1px);
            box-shadow: 0 4px 15px rgba(245,158,11,0.4);
        }
        .btn-scan-reset {
            background: #f1f5f9;
            color: var(--text-secondary);
            border: 1.5px solid var(--border);
        }
        .btn-scan-reset:hover {
            background: #e2e8f0;
        }

        /* Scanning state */
        .scan-status {
            display: none;
            text-align: center;
            padding: 1rem 0;
        }
        .scan-status.active { display: block; }
        .scan-status p {
            font-size: 0.88rem;
            font-weight: 600;
            color: var(--primary);
            margin: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
        }
        .scan-spinner {
            width: 18px; height: 18px;
            border: 2.5px solid var(--primary-light);
            border-top-color: var(--primary);
            border-radius: 50%;
            animation: spin 0.7s linear infinite;
            flex-shrink: 0;
        }
        @@keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* Results */
        .scan-results {
            display: none;
            margin-top: 1.25rem;
        }
        .scan-results.active { display: block; }
        .scan-results-title {
            font-size: 0.88rem;
            font-weight: 700;
            margin-bottom: 0.75rem;
            display: flex;
            align-items: center;
            gap: 0.4rem;
        }
        .scan-results-title i { color: #16a34a; }

        .scan-result-card {
            display: flex;
            gap: 0.85rem;
            padding: 0.85rem;
            border: 1.5px solid var(--border);
            border-radius: 12px;
            margin-bottom: 0.6rem;
            transition: all 0.2s;
            text-decoration: none;
            color: inherit;
        }
        .scan-result-card:hover {
            border-color: var(--primary);
            box-shadow: 0 4px 12px rgba(245,158,11,0.12);
            transform: translateY(-2px);
            color: inherit;
            text-decoration: none;
        }
        .scan-result-img {
            width: 72px; height: 72px;
            border-radius: 10px;
            object-fit: cover;
            flex-shrink: 0;
            background: #f1f5f9;
        }
        .scan-result-info { flex: 1; min-width: 0; }
        .scan-result-info h5 {
            font-size: 0.88rem;
            font-weight: 700;
            margin: 0 0 0.2rem;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .scan-result-info .result-cat {
            font-size: 0.7rem;
            color: #92400e;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.3px;
            background: var(--primary-light);
            padding: 1px 6px;
            border-radius: 4px;
            display: inline-block;
            margin-bottom: 0.25rem;
        }
        .scan-result-info .result-price {
            font-size: 0.92rem;
            font-weight: 800;
            color: var(--text-primary);
        }
        .scan-result-info .result-price span {
            font-size: 0.72rem;
            font-weight: 400;
            color: var(--text-muted);
        }
        .scan-result-match {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }
        .match-percent {
            font-size: 1rem;
            font-weight: 800;
            color: #16a34a;
        }
        .match-label {
            font-size: 0.62rem;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.3px;
        }

        .scan-no-results {
            text-align: center;
            padding: 1.5rem;
            color: var(--text-secondary);
        }
        .scan-no-results i {
            font-size: 2.5rem;
            color: var(--text-muted);
            display: block;
            margin-bottom: 0.75rem;
        }
        .scan-no-results p {
            font-size: 0.88rem;
            margin: 0;
        }

        /* Hero stats */
        .hero-stats {
            display: flex;
            justify-content: center;
            gap: 3rem;
            margin-top: 3.5rem;
        }
        .hero-stat-value {
            font-size: 1.6rem;
            font-weight: 800;
            color: var(--navy);
        }
        .hero-stat-label {
            font-size: 0.75rem;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        /* ===================== SECTIONS ===================== */
        .section-tag {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            background: var(--primary-light);
            color: var(--tag-color);
            font-size: 0.72rem;
            font-weight: 700;
            letter-spacing: 0.6px;
            padding: 0.3rem 0.8rem;
            border-radius: 50px;
            margin-bottom: 0.75rem;
            text-transform: uppercase;
        }

        .section-title {
            font-size: 2.2rem;
            font-weight: 800;
            color: var(--text-primary);
            margin-bottom: 0.5rem;
            letter-spacing: -0.3px;
        }

        .section-subtitle {
            color: var(--text-secondary);
            font-size: 1rem;
        }

        /* ===================== CATEGORIES ===================== */
        .categories-card-wrapper {
            background: var(--section-alt);
            border: 1.5px solid var(--border);
            border-radius: 24px;
            padding: 3.5rem 2.5rem;
            margin-top: 3.5rem;
            margin-bottom: 2rem;
            box-shadow: var(--card-shadow);
        }

        .category-card {
            background: var(--card-bg);
            border: 1.5px solid var(--border);
            border-radius: 16px;
            padding: 1.75rem 1.25rem;
            text-align: center;
            transition: all 0.25s ease;
            cursor: pointer;
            height: 100%;
            text-decoration: none;
            color: inherit;
            display: block;
        }

        .category-card:hover {
            transform: translateY(-6px);
            border-color: var(--primary);
            box-shadow: 0 12px 30px rgba(245,158,11,0.15);
            color: inherit;
            text-decoration: none;
        }

        .category-card.active-category {
            border-color: var(--primary);
            background: var(--primary-light);
            box-shadow: 0 8px 24px rgba(245,158,11,0.2);
            transform: translateY(-4px);
        }

        .category-icon-wrap {
            width: 60px;
            height: 60px;
            border-radius: 14px;
            background: var(--primary-light);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1rem;
            transition: all 0.25s;
        }
        .category-card:hover .category-icon-wrap,
        .category-card.active-category .category-icon-wrap {
            background: var(--primary);
        }
        .category-icon-wrap i {
            font-size: 1.5rem;
            color: var(--primary);
            transition: color 0.25s;
        }
        .category-card:hover .category-icon-wrap i,
        .category-card.active-category .category-icon-wrap i {
            color: var(--navy);
        }

        .category-name {
            font-weight: 700;
            font-size: 0.95rem;
            margin: 0;
            color: var(--text-primary);
        }

        /* ===================== PRODUCT CARDS ===================== */
        .product-card {
            background: var(--card-bg);
            border: 1.5px solid var(--border);
            border-radius: 16px;
            overflow: hidden;
            transition: all 0.25s ease;
            height: 100%;
            display: flex;
            flex-direction: column;
            text-decoration: none;
            color: inherit;
        }

        .product-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 16px 40px rgba(15,23,42,0.12);
            border-color: #cbd5e1;
            color: inherit;
            text-decoration: none;
        }

        .product-img-wrapper {
            position: relative;
            padding-top: 62%;
            overflow: hidden;
            background: #f1f5f9;
        }

        .product-img {
            position: absolute;
            top: 0; left: 0;
            width: 100%; height: 100%;
            object-fit: cover;
            transition: transform 0.4s ease;
        }

        .product-card:hover .product-img { transform: scale(1.05); }

        .product-badge {
            position: absolute;
            top: 0.75rem;
            right: 0.75rem;
            background: rgba(16, 185, 129, 0.15);
            color: #10b981;
            padding: 0.25rem 0.7rem;
            border-radius: 50px;
            font-size: 0.72rem;
            font-weight: 700;
            border: 1px solid rgba(16, 185, 129, 0.3);
            backdrop-filter: blur(4px);
        }

        .product-content {
            padding: 1.25rem;
            flex-grow: 1;
            display: flex;
            flex-direction: column;
        }

        .product-category {
            font-size: 0.72rem;
            color: var(--tag-color);
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            background: var(--primary-light);
            display: inline-block;
            padding: 0.2rem 0.55rem;
            border-radius: 4px;
            margin-bottom: 0.65rem;
        }

        .product-title {
            font-size: 1rem;
            font-weight: 700;
            color: var(--text-primary);
            margin-bottom: 0.75rem;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            line-height: 1.45;
        }

        .product-footer {
            margin-top: auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-top: 1px solid var(--border);
            padding-top: 0.9rem;
        }

        .product-price {
            font-size: 1.25rem;
            font-weight: 800;
            color: var(--text-primary);
        }

        .product-price span {
            font-size: 0.8rem;
            font-weight: 400;
            color: var(--text-muted);
        }

        .owner-avatar {
            width: 28px; height: 28px;
            border-radius: 50%;
            background: var(--primary);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.7rem;
            font-weight: 700;
            color: #09090b; /* Always dark contrast text on gold bg */
        }

        /* ===================== SECTION: WHY US ===================== */
        .feature-card {
            padding: 1.75rem;
            border-radius: 16px;
            background: var(--card-bg);
            border: 1.5px solid var(--border);
            height: 100%;
            transition: all 0.25s;
        }
        .feature-card:hover {
            transform: translateY(-4px);
            box-shadow: var(--card-shadow);
            border-color: var(--primary);
        }
        .feature-icon {
            width: 50px; height: 50px;
            border-radius: 12px;
            background: var(--primary-light);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.3rem;
            color: var(--primary);
            margin-bottom: 1rem;
        }
        .feature-title { font-size: 1rem; font-weight: 700; margin-bottom: 0.4rem; }
        .feature-desc  { font-size: 0.85rem; color: var(--text-secondary); margin: 0; }

        /* ===================== CTA BANNER ===================== */
        .cta-banner {
            background: linear-gradient(135deg, #09090b 0%, #1c1917 100%);
            border: 1.5px solid rgba(234, 179, 8, 0.25);
            border-radius: 20px;
            padding: 3.5rem 2.5rem;
            text-align: center;
            position: relative;
            overflow: hidden;
            box-shadow: 0 10px 40px rgba(0,0,0,0.4);
        }
        .cta-banner::before {
            content: '';
            position: absolute;
            width: 400px; height: 400px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(234, 179, 8, 0.15), transparent 70%);
            top: -100px; right: -100px;
            pointer-events: none;
        }
        .cta-banner h2 { font-size: 2rem; font-weight: 800; color: #ffd700; margin-bottom: 0.75rem; }
        .cta-banner p  { color: #d4d4d8; font-size: 1rem; margin-bottom: 2rem; }

        .btn-cta-primary {
            background: var(--primary);
            color: var(--navy);
            font-weight: 700;
            border: none;
            border-radius: 10px;
            padding: 0.85rem 2rem;
            font-size: 0.95rem;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            transition: all 0.2s;
        }
        .btn-cta-primary:hover {
            background: var(--primary-hover);
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(245,158,11,0.4);
            color: var(--navy);
        }
        .btn-cta-outline {
            border: 1.5px solid rgba(255,255,255,0.25);
            color: #fff;
            font-weight: 600;
            border-radius: 10px;
            padding: 0.85rem 2rem;
            font-size: 0.95rem;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            transition: all 0.2s;
        }
        .btn-cta-outline:hover {
            border-color: var(--primary);
            color: var(--primary);
            background: rgba(245,158,11,0.08);
        }

        /* ===================== FOOTER ===================== */
        footer {
            background: var(--footer-bg);
            border-top: 1px solid var(--footer-border);
            padding: 4rem 0 2rem;
            margin-top: 5rem;
            transition: background-color 0.3s ease;
        }

        .footer-brand {
            font-size: 1.5rem;
            font-weight: 800;
            color: #ffffff;
            display: flex;
            align-items: center;
            gap: 0.4rem;
            margin-bottom: 0.75rem;
        }

        .footer-text { color: #64748b; max-width: 280px; font-size: 0.875rem; line-height: 1.7; }
        .footer-title { font-weight: 700; color: #e2e8f0; font-size: 0.85rem; margin-bottom: 1.25rem; text-transform: uppercase; letter-spacing: 0.5px; }

        .footer-links { list-style: none; padding: 0; margin: 0; }
        .footer-links li { margin-bottom: 0.65rem; }
        .footer-links a { color: #64748b; text-decoration: none; font-size: 0.875rem; transition: color 0.2s; }
        .footer-links a:hover { color: var(--primary); }

        .social-icon {
            width: 36px; height: 36px;
            border-radius: 8px;
            background: rgba(255,255,255,0.06);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: #64748b;
            font-size: 1rem;
            text-decoration: none;
            transition: all 0.2s;
        }
        .social-icon:hover { background: var(--primary); color: var(--navy); }

        /* ===================== THEME TOGGLE ===================== */
        .theme-toggle {
            background: transparent;
            border: 1.5px solid var(--border);
            border-radius: 10px;
            width: 38px; height: 38px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 1.1rem;
            color: var(--text-secondary);
            transition: all 0.25s;
            flex-shrink: 0;
        }
        .theme-toggle:hover {
            border-color: var(--primary);
            color: var(--primary);
            background: var(--primary-light);
        }
        .theme-toggle .bi-moon-fill { display: inline; }
        .theme-toggle .bi-sun-fill { display: none; }
        [data-theme="dark"] .theme-toggle .bi-moon-fill { display: none; }
        [data-theme="dark"] .theme-toggle .bi-sun-fill { display: inline; }

        /* ===================== RESPONSIVE ===================== */
        @@media (max-width: 768px) {
            .hero-title { font-size: 2.4rem; }
            .hero-section { padding: 130px 0 60px; }
            .hero-stats { gap: 1.5rem; }
            .search-box { flex-direction: column; border-radius: 14px; padding: 0.75rem; gap: 0.5rem; }
            .btn-search { padding: 0.85rem; border-radius: 8px; width: 100%; }
            .section-title { font-size: 1.75rem; }
        }
    </style>
</head>
<body>

    <!-- ======================== NAVBAR ======================== -->
    <nav class="navbar navbar-expand-lg navbar-custom">
        <div class="container">
            <a class="navbar-brand" href="/">
                <i class="bi bi-building-fill brand-icon"></i> OmniRent
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                    aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <i class="bi bi-list fs-2" style="color:var(--navy)"></i>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto gap-1">
                    <li class="nav-item">
                        <a class="nav-link-custom" href="#">Trang chủ</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link-custom" href="#productsSection">Khám phá</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link-custom" href="#">Về chúng tôi</a>
                    </li>
                </ul>
                <div class="d-flex gap-2 mt-3 mt-lg-0 align-items-center">
                    <!-- Theme Toggle -->
                    <button class="theme-toggle" id="themeToggle" title="Chuyển chế độ sáng/tối">
                        <i class="bi bi-moon-fill"></i>
                        <i class="bi bi-sun-fill"></i>
                    </button>

                    <!-- Cart -->
                    <a href="/Home/Cart" class="cart-icon position-relative me-1">
                        <i class="bi bi-cart3"></i>
                        <span id="cartBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.6rem; display: none;">0</span>
                    </a>

                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        var userAvatar = User.FindFirst("AvatarUrl")?.Value;
                        <div class="dropdown">
                            <button class="btn dropdown-toggle d-flex align-items-center gap-2 border-0 bg-transparent p-0" type="button" id="userMenuButton" data-bs-toggle="dropdown" aria-expanded="false" style="color:var(--text-primary); font-size:0.9rem; font-weight:600;">
                                <div class="profile-avatar" style="width: 32px; height: 32px; border-radius: 50%; background: var(--primary); color: var(--navy); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.85rem; overflow: hidden; border: 1.5px solid var(--primary);">
                                    @if (!string.IsNullOrEmpty(userAvatar))
                                    {
                                        <img src="@userAvatar" alt="Avatar" style="width:100%; height:100%; object-fit:cover;" />
                                    }
                                    else
                                    {
                                        @User.Identity.Name.Substring(0, 1).ToUpper()
                                    }
                                </div>
                                <span class="d-none d-md-inline" style="color:var(--text-primary)">@User.Identity.Name</span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end p-2 border-0" aria-labelledby="userMenuButton" style="background: var(--card-bg); box-shadow: var(--card-shadow); border-radius: 12px; min-width: 200px;">
                                <li>
                                    <a class="dropdown-item rounded-3 py-2 px-3 d-flex align-items-center gap-2" href="/Account/Profile" style="color: var(--text-primary); font-size: 0.85rem; font-weight: 500;">
                                        <i class="bi bi-person-circle text-primary"></i> Trang cá nhân & Lịch sử
                                    </a>
                                </li>
                                @if (User.IsInRole("OWNER"))
                                {
                                    <li>
                                        <a class="dropdown-item rounded-3 py-2 px-3 d-flex align-items-center gap-2" href="/OwnerDashboard" style="color: var(--text-primary); font-size: 0.85rem; font-weight: 500;">
                                            <i class="bi bi-house-door-fill text-primary"></i> Quản lý tài sản
                                        </a>
                                    </li>
                                }
                                @if (User.IsInRole("ADMIN"))
                                {
                                    <li>
                                        <a class="dropdown-item rounded-3 py-2 px-3 d-flex align-items-center gap-2" href="/AdminDashboard/Bookings" style="color: var(--text-primary); font-size: 0.85rem; font-weight: 500;">
                                            <i class="bi bi-shield-lock-fill text-primary"></i> Trang quản trị
                                        </a>
                                    </li>
                                }
                                <li><hr class="dropdown-divider" style="border-color: var(--border);"></li>
                                <li>
                                    <form action="/Account/Logout" method="post" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item rounded-3 py-2 px-3 text-danger d-flex align-items-center gap-2 bg-transparent border-0 w-100 text-start" style="font-size: 0.85rem; font-weight: 600;">
                                            <i class="bi bi-box-arrow-right"></i> Đăng xuất
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a href="/Account/Login" class="btn-nav-outline">Đăng nhập</a>
                        <a href="/Account/Register" class="btn-nav-primary"><i class="bi bi-person-plus"></i> Đăng ký</a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <!-- ======================== HERO ======================== -->
    <section class="hero-section">
        <div class="container position-relative">
            <div class="hero-tag">
                <i class="bi bi-stars"></i> Nền tảng cho thuê #1 Việt Nam
            </div>
            <h1 class="hero-title">
                Thuê mọi thứ bạn cần<br />
                <span class="highlight">Dễ dàng & Nhanh chóng</span>
            </h1>
            <p class="hero-subtitle">
                Khám phá hàng ngàn tài sản, thiết bị và dịch vụ chất lượng cao từ cộng đồng OmniRent.
                Tiết kiệm chi phí, tối đa hóa giá trị.
            </p>

            <!-- Search -->
            <div class="search-box">
                <i class="bi bi-search search-icon"></i>
                <input type="text" class="search-input" id="heroSearch" placeholder="Bạn muốn thuê gì hôm nay?" />
                <button class="btn-scan" id="btnOpenScan" title="Tìm bằng ảnh">
                    <i class="bi bi-camera-fill"></i>
                    <span class="scan-tooltip">Scan ảnh tìm sản phẩm</span>
                </button>
                <button class="btn-search" onclick="handleSearch()">Tìm kiếm</button>
            </div>
        </div>
    </section>

    <!-- ======================== CATEGORIES ======================== -->
    <section class="py-4">
        <div class="container">
            <div class="categories-card-wrapper">
                <div class="text-center mb-5">
                    <div class="section-tag"><i class="bi bi-grid-fill"></i> Danh mục</div>
                    <h2 class="section-title">Danh mục nổi bật</h2>
                    <p class="section-subtitle">Khám phá các loại tài sản phong phú trên OmniRent</p>
                </div>

                <div class="row g-4 justify-content-center">
                    @if (Model.Categories != null && Model.Categories.Any())
                    {
                        foreach (var category in Model.Categories)
                        {
                            <div class="col-6 col-md-4 col-lg-3">
                                <a href="/?categoryId=@category.Id" class="category-card @(ViewBag.SelectedCategoryId == category.Id ? "active-category" : "")">
                                    <div class="category-icon-wrap">
                                        <i class="bi @getCategoryIcon(category.Slug)"></i>
                                    </div>
                                    <h3 class="category-name">@category.Name</h3>
                                </a>
                            </div>
                        }
                    }
                    else
                    {
                        var mockCategories = new[]
                        {
                            new { Icon = "bi-car-front-fill",   Name = "Xe cộ" },
                            new { Icon = "bi-house-heart-fill", Name = "Bất động sản" },
                            new { Icon = "bi-camera-fill",      Name = "Thiết bị điện tử" },
                            new { Icon = "bi-tools",            Name = "Dụng cụ cơ khí" },
                        };
                        foreach (var cat in mockCategories)
                        {
                            <div class="col-6 col-md-4 col-lg-3">
                                <div class="category-card">
                                    <div class="category-icon-wrap">
                                        <i class="bi @cat.Icon"></i>
                                    </div>
                                    <h3 class="category-name">@cat.Name</h3>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </section>

    <!-- ======================== PRODUCTS ======================== -->
    <section class="py-5" id="productsSection">
        <div class="container">
            <div class="d-flex justify-content-between align-items-end mb-5 flex-wrap gap-3">
                <div>
                    <div class="section-tag"><i class="bi bi-box-seam"></i> Sản phẩm</div>
                    @if (ViewBag.SelectedCategoryId != null)
                    {
                        var selectedCat = Model.Categories.FirstOrDefault(c => c.Id == ViewBag.SelectedCategoryId);
                        <h2 class="section-title">Sản phẩm: @selectedCat?.Name</h2>
                        <a href="/" style="font-size:0.82rem; color:var(--text-secondary); text-decoration:none;">
                            <i class="bi bi-arrow-left"></i> Xem tất cả danh mục
                        </a>
                    }
                    else
                    {
                        <h2 class="section-title">Tài sản mới nhất</h2>
                        <p class="section-subtitle mb-0">Các tài sản vừa được đăng cho thuê</p>
                    }
                </div>
                <a href="#" style="color:var(--primary); text-decoration:none; font-weight:600; font-size:0.9rem;">
                    Xem tất cả <i class="bi bi-arrow-right"></i>
                </a>
            </div>

            <div class="row g-4">
                @if (Model.FeaturedProducts != null && Model.FeaturedProducts.Any())
                {
                    foreach (var product in Model.FeaturedProducts)
                    {
                        <div class="col-12 col-md-6 col-lg-3">
                            <a href="/Home/ProductDetails/@product.Id" class="product-card">
                                <div class="product-img-wrapper">
                                    <span class="product-badge">Có sẵn</span>
                                    @{
                                        var firstImage = "https://images.unsplash.com/photo-1522771739844-6a9f6d5f14af?auto=format&fit=crop&w=600&q=80";
                                        try
                                        {
                                            if (!string.IsNullOrEmpty(product.ImagesJson))
                                            {
                                                var imgs = System.Text.Json.JsonSerializer.Deserialize<List<string>>(product.ImagesJson);
                                                if (imgs != null && imgs.Any()) { firstImage = imgs.First(); }
                                            }
                                        }
                                        catch { }
                                    }
                                    <img src="@firstImage" alt="@product.Name" class="product-img"
                                         onerror="this.src='https://images.unsplash.com/photo-1522771739844-6a9f6d5f14af?auto=format&fit=crop&w=600&q=80'" />
                                </div>
                                <div class="product-content">
                                    <div class="product-category">@(product.Category?.Name ?? "Chung")</div>
                                    <h3 class="product-title">@product.Name</h3>
                                    <div class="product-footer">
                                        <div class="product-price">
                                            @product.PricePerDay.ToString("N0")đ <span>/ ngày</span>
                                        </div>
                                        <div class="owner-avatar" title="@(product.Owner?.FullName ?? "Người dùng")">
                                            @((product.Owner?.FullName ?? "U").Substring(0, 1).ToUpper())
                                        </div>
                                    </div>
                                </div>
                            </a>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12 text-center py-5" style="color:var(--text-muted);">
                        <i class="bi bi-box-seam" style="font-size:2.5rem; display:block; margin-bottom:0.75rem;"></i>
                        <p style="font-size:0.9rem;">Chưa có sản phẩm nào được đăng.</p>
                    </div>
                }
            </div>
        </div>
    </section>


    <!-- ======================== FOOTER ======================== -->
    <footer>
        <div class="container">
            <div class="row g-5">
                <div class="col-lg-4">
                    <div class="footer-brand">
                        <i class="bi bi-building-fill" style="color: var(--primary);"></i> OmniRent
                    </div>
                    <p class="footer-text">Nền tảng kết nối người thuê và người cho thuê nhanh chóng, an toàn và minh bạch nhất hiện nay.</p>
                    <div class="d-flex gap-2 mt-3">
                        <a href="#" class="social-icon"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="social-icon"><i class="bi bi-instagram"></i></a>
                        <a href="#" class="social-icon"><i class="bi bi-twitter-x"></i></a>
                    </div>
                </div>
                <div class="col-lg-2 col-md-4">
                    <h4 class="footer-title">Khám phá</h4>
                    <ul class="footer-links">
                        <li><a href="#">Tất cả tài sản</a></li>
                        <li><a href="#">Danh mục nổi bật</a></li>
                        <li><a href="#">Chủ cho thuê uy tín</a></li>
                    </ul>
                </div>
                <div class="col-lg-2 col-md-4">
                    <h4 class="footer-title">Hỗ trợ</h4>
                    <ul class="footer-links">
                        <li><a href="#">Trung tâm trợ giúp</a></li>
                        <li><a href="#">Quy định an toàn</a></li>
                        <li><a href="#">Chính sách bảo mật</a></li>
                    </ul>
                </div>
                <div class="col-lg-4 col-md-4">
                    <h4 class="footer-title">Liên hệ</h4>
                    <ul class="footer-links">
                        <li><i class="bi bi-envelope me-2" style="color:var(--primary)"></i>support@omnirent.vn</li>
                        <li><i class="bi bi-telephone me-2" style="color:var(--primary)"></i>1800 000 000</li>
                        <li><i class="bi bi-geo-alt me-2" style="color:var(--primary)"></i>Hồ Chí Minh, Việt Nam</li>
                    </ul>
                </div>
            </div>
            <div class="text-center mt-5 pt-4" style="border-top: 1px solid rgba(255,255,255,0.06); color: #475569; font-size: 0.82rem;">
                &copy; @DateTime.Now.Year OmniRent. Mọi quyền được bảo lưu.
            </div>
        </div>
    </footer>

    <!-- ======================== SCAN MODAL ======================== -->
    <div class="scan-overlay" id="scanOverlay">
        <div class="scan-modal">
            <div class="scan-modal-header">
                <div>
                    <h3><i class="bi bi-cpu"></i> Tìm kiếm thông minh</h3>
                    <p>Upload ảnh sản phẩm — Hệ thống sẽ rà soát và tìm sản phẩm khớp</p>
                </div>
                <button class="scan-close" id="btnCloseScan"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="scan-modal-body">
                <!-- Dropzone -->
                <div class="scan-dropzone" id="scanDropzone">
                    <div class="scan-dropzone-icon">
                        <i class="bi bi-cloud-arrow-up"></i>
                    </div>
                    <h4>Kéo thả ảnh vào đây</h4>
                    <p>hoặc <strong style="color:var(--primary);cursor:pointer;">nhấn để chọn file</strong></p>
                    <div class="supported-types">
                        <i class="bi bi-info-circle"></i>
                        Hỗ trợ: JPG, PNG, WebP, GIF — Tối đa 10MB
                    </div>
                    <input type="file" id="scanFileInput" accept="image/*" style="display:none;" />
                </div>

                <!-- Preview -->
                <div class="scan-preview" id="scanPreview">
                    <img id="scanPreviewImg" src="" alt="Preview" />
                    <div class="scan-corners"></div>
                    <div class="scan-line"></div>
                </div>

                <!-- Actions -->
                <div class="scan-actions" id="scanActions">
                    <button class="btn-scan-action btn-scan-reset" id="btnScanReset">
                        <i class="bi bi-arrow-counterclockwise"></i> Chọn ảnh khác
                    </button>
                    <button class="btn-scan-action btn-scan-submit" id="btnScanSubmit">
                        <i class="bi bi-search-heart"></i> Bắt đầu rà soát
                    </button>
                </div>

                <!-- Scanning status -->
                <div class="scan-status" id="scanStatus">
                    <p><span class="scan-spinner"></span> Đang quét và so sánh ảnh sản phẩm...</p>
                </div>

                <!-- Results -->
                <div class="scan-results" id="scanResults">
                    <div class="scan-results-title" id="scanResultsTitle">
                        <i class="bi bi-check-circle-fill"></i>
                        <span>Kết quả tìm kiếm</span>
                    </div>
                    <div id="scanResultsList"></div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // =================== Theme Toggle ===================
        (function() {
            const root = document.documentElement;
            const toggle = document.getElementById('themeToggle');
            const storageKey = 'omnirent-theme';

            // Detect saved or system preference
            function getPreferred() {
                const saved = localStorage.getItem(storageKey);
                if (saved) return saved;
                return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
            }

            function applyTheme(theme) {
                root.setAttribute('data-theme', theme);
                localStorage.setItem(storageKey, theme);
            }

            // Apply immediately
            applyTheme(getPreferred());

            // Toggle on click
            toggle.addEventListener('click', () => {
                const current = root.getAttribute('data-theme') || 'light';
                applyTheme(current === 'dark' ? 'light' : 'dark');
            });

            // Listen to system preference changes
            window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
                if (!localStorage.getItem(storageKey)) {
                    applyTheme(e.matches ? 'dark' : 'light');
                }
            });
        })();

        // =================== Cart badge ===================
        function updateCartBadge() {
            let cart = JSON.parse(localStorage.getItem('cart')) || [];
            let badge = document.getElementById('cartBadge');
            if (badge) {
                badge.innerText = cart.length;
                badge.style.display = cart.length > 0 ? 'inline-block' : 'none';
            }
        }
        document.addEventListener('DOMContentLoaded', updateCartBadge);

        // =================== Text Search ===================
        function handleSearch() {
            const q = document.getElementById('heroSearch').value.trim();
            if (q) window.location.href = '/?search=' + encodeURIComponent(q);
        }
        document.getElementById('heroSearch').addEventListener('keypress', function (e) {
            if (e.key === 'Enter') handleSearch();
        });

        // =================== Image Scan Search ===================
        (function() {
            const overlay      = document.getElementById('scanOverlay');
            const btnOpen      = document.getElementById('btnOpenScan');
            const btnClose     = document.getElementById('btnCloseScan');
            const dropzone     = document.getElementById('scanDropzone');
            const fileInput    = document.getElementById('scanFileInput');
            const preview      = document.getElementById('scanPreview');
            const previewImg   = document.getElementById('scanPreviewImg');
            const actions      = document.getElementById('scanActions');
            const btnReset     = document.getElementById('btnScanReset');
            const btnSubmit    = document.getElementById('btnScanSubmit');
            const scanStatus   = document.getElementById('scanStatus');
            const scanResults  = document.getElementById('scanResults');
            const resultsTitle = document.getElementById('scanResultsTitle');
            const resultsList  = document.getElementById('scanResultsList');

            let selectedFile = null;

            // Open / Close modal
            btnOpen.addEventListener('click', () => {
                overlay.classList.add('active');
                document.body.style.overflow = 'hidden';
            });

            function closeModal() {
                overlay.classList.remove('active');
                document.body.style.overflow = '';
                resetScan();
            }
            btnClose.addEventListener('click', closeModal);
            overlay.addEventListener('click', (e) => { if (e.target === overlay) closeModal(); });
            document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && overlay.classList.contains('active')) closeModal(); });

            // Dropzone click
            dropzone.addEventListener('click', () => fileInput.click());

            // Drag & Drop
            dropzone.addEventListener('dragover', (e) => { e.preventDefault(); dropzone.classList.add('drag-over'); });
            dropzone.addEventListener('dragleave', () => dropzone.classList.remove('drag-over'));
            dropzone.addEventListener('drop', (e) => {
                e.preventDefault();
                dropzone.classList.remove('drag-over');
                if (e.dataTransfer.files.length > 0) handleFile(e.dataTransfer.files[0]);
            });

            // File input change
            fileInput.addEventListener('change', () => {
                if (fileInput.files.length > 0) handleFile(fileInput.files[0]);
            });

            function handleFile(file) {
                if (!file.type.startsWith('image/')) {
                    alert('Vui lòng chọn file ảnh!');
                    return;
                }
                if (file.size > 10 * 1024 * 1024) {
                    alert('File quá lớn! Tối đa 10MB.');
                    return;
                }
                selectedFile = file;
                const reader = new FileReader();
                reader.onload = (e) => {
                    previewImg.src = e.target.result;
                    dropzone.style.display = 'none';
                    preview.style.display = 'block';
                    actions.classList.add('active');
                    scanResults.classList.remove('active');
                    scanStatus.classList.remove('active');
                };
                reader.readAsDataURL(file);
            }

            // Reset
            btnReset.addEventListener('click', resetScan);
            function resetScan() {
                selectedFile = null;
                fileInput.value = '';
                previewImg.src = '';
                dropzone.style.display = '';
                preview.style.display = 'none';
                preview.classList.remove('scanning');
                actions.classList.remove('active');
                scanStatus.classList.remove('active');
                scanResults.classList.remove('active');
                resultsList.innerHTML = '';
            }

            // Submit scan
            btnSubmit.addEventListener('click', async () => {
                if (!selectedFile) return;

                // Show scanning state
                actions.classList.remove('active');
                scanStatus.classList.add('active');
                scanResults.classList.remove('active');
                preview.classList.add('scanning');

                const formData = new FormData();
                formData.append('image', selectedFile);

                try {
                    const response = await fetch('/ai/image-search', {
                        method: 'POST',
                        body: formData
                    });
                    const data = await response.json();

                    // Hide scanning, show results
                    scanStatus.classList.remove('active');
                    preview.classList.remove('scanning');
                    actions.classList.add('active');
                    scanResults.classList.add('active');

                    if (data.success && data.results && data.results.length > 0) {
                        resultsTitle.innerHTML = `<i class="bi bi-check-circle-fill"></i> <span>Tìm thấy ${data.results.length} sản phẩm khớp!</span>`;
                        resultsList.innerHTML = data.results.map(r => `
                            <a href="/Home/ProductDetails/${r.id}" class="scan-result-card">
                                <img src="${r.matchedImage}" class="scan-result-img"
                                     onerror="this.src='https://images.unsplash.com/photo-1522771739844-6a9f6d5f14af?auto=format&fit=crop&w=200&q=80'" />
                                <div class="scan-result-info">
                                    <span class="result-cat">${r.categoryName}</span>
                                    <h5>${r.name}</h5>
                                    <div class="result-price">${Number(r.pricePerDay).toLocaleString('vi-VN')}đ <span>/ ngày</span></div>
                                </div>
                                <div class="scan-result-match">
                                    <div class="match-percent">${r.similarity}%</div>
                                    <div class="match-label">Khớp</div>
                                </div>
                            </a>
                        `).join('');
                    } else {
                        resultsTitle.innerHTML = `<i class="bi bi-info-circle" style="color:var(--text-muted)"></i> <span>Kết quả</span>`;
                        resultsList.innerHTML = `
                            <div class="scan-no-results">
                                <i class="bi bi-search"></i>
                                <p>${data.message || 'Không tìm thấy sản phẩm nào khớp với ảnh. Hãy thử ảnh khác hoặc tìm bằng từ khóa.'}</p>
                            </div>
                        `;
                    }
                } catch (err) {
                    scanStatus.classList.remove('active');
                    preview.classList.remove('scanning');
                    actions.classList.add('active');
                    scanResults.classList.add('active');
                    resultsTitle.innerHTML = `<i class="bi bi-exclamation-triangle" style="color:#dc2626"></i> <span>Lỗi</span>`;
                    resultsList.innerHTML = `
                        <div class="scan-no-results">
                            <i class="bi bi-exclamation-circle" style="color:#dc2626"></i>
                            <p>Đã xảy ra lỗi khi xử lý ảnh. Vui lòng thử lại.</p>
                        </div>
                    `;
                }
            });
        })();
    </script>
</body>
</html>