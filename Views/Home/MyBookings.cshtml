@using OmniRentBackend.Models
@model IEnumerable<Booking>
@{
    Layout = null;
    var isAuthenticated = User.Identity != null && User.Identity.IsAuthenticated;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đơn hàng của tôi — OmniRent</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>
        :root {
            --primary:       #f59e0b;
            --primary-hover: #d97706;
            --primary-light: #fef3c7;
            --navy:          #0f172a;
            --navy-2:        #1e293b;
            --text-main:     #000000;
            --text-sub:      #333333;
            --text-muted:    #666666;
            --border:        #e2e8f0;
            --body-bg:       #f8fafc;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--body-bg);
            color: var(--text-main);
            min-height: 100vh;
            margin: 0; padding: 0;
            overflow-x: hidden;
        }

        /* Navbar */
        .navbar-custom {
            background: var(--navy);
            border-bottom: 1px solid rgba(255,255,255,0.06);
            padding: 1rem 0;
            position: fixed;
            top: 0; width: 100%;
            z-index: 1000;
        }
        .navbar-brand {
            font-weight: 800; font-size: 1.5rem;
            color: #ffffff !important;
            display: flex; align-items: center; gap: 0.5rem;
            text-decoration: none;
        }
        .brand-icon { color: var(--primary); font-size: 1.8rem; }
        
        .nav-link { color: #cbd5e1 !important; font-weight: 500; }
        .nav-link:hover, .nav-link.active { color: #ffffff !important; }

        .btn-outline-primary-custom {
            color: #fff;
            border: 1.5px solid rgba(255,255,255,0.25);
            border-radius: 50px;
            padding: 0.5rem 1.5rem;
            font-weight: 600;
            transition: all 0.2s;
            text-decoration: none;
        }
        .btn-outline-primary-custom:hover {
            border-color: var(--primary); color: var(--primary);
            background: rgba(245,158,11,0.08);
        }

        .btn-primary-custom {
            background: var(--primary);
            color: var(--navy);
            border: none; border-radius: 50px;
            padding: 0.5rem 1.5rem;
            font-weight: 700;
            transition: all 0.2s;
            text-decoration: none;
            box-shadow: 0 4px 14px rgba(245,158,11,0.3);
        }
        .btn-primary-custom:hover {
            background: var(--primary-hover); transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(245,158,11,0.4);
        }

        /* Content */
        .main-container { margin-top: 120px; padding-bottom: 80px; }

        .booking-card {
            background: #ffffff;
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 2rem;
            margin-bottom: 2rem;
            transition: all 0.2s;
            box-shadow: 0 4px 12px rgba(15,23,42,0.04);
        }
        .booking-card:hover {
            border-color: var(--primary);
            box-shadow: 0 8px 24px rgba(245,158,11,0.1);
            transform: translateY(-2px);
        }

        .product-img {
            width: 100%; height: 150px;
            object-fit: cover; border-radius: 12px;
            border: 1px solid var(--border);
            background: var(--body-bg);
        }

        .badge-status {
            font-size: 0.82rem; padding: 0.5rem 1rem;
            border-radius: 50px; font-weight: 700;
        }

        /* Footer */
        footer {
            background: var(--navy); border-top: 1px solid rgba(255,255,255,0.06);
            padding: 4rem 0 2rem; margin-top: 5rem;
        }
    </style>
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-custom">
        <div class="container">
            <a class="navbar-brand" href="/">
                <i class="bi bi-building-fill brand-icon"></i> OmniRent
            </a>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto">
                    <li class="nav-item"><a class="nav-link" href="/">Trang chủ</a></li>
                    <li class="nav-item"><a class="nav-link active" href="/Home/MyBookings">Đơn hàng của tôi</a></li>
                </ul>
            </div>
            <div class="ms-auto d-flex gap-3 align-items-center">
                <a href="/Home/Cart" class="position-relative text-white me-3 d-flex align-items-center" style="font-size: 1.3rem; text-decoration: none;">
                    <i class="bi bi-cart3"></i>
                    <span id="cartBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.65rem; display: none;">0</span>
                </a>

                @if (isAuthenticated) {
                    <span class="text-white fw-bold d-none d-md-inline me-2">Xin chào, @User.Identity.Name</span>
                    <form action="/Account/Logout" method="post" class="d-inline m-0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-primary-custom">Đăng xuất</button>
                    </form>
                } else {
                    <a href="/Account/Login?returnUrl=/Home/MyBookings" class="btn btn-outline-primary-custom">Đăng nhập</a>
                }
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="container main-container">
        <h2 class="mb-5 fw-bold" style="color: #000000;"><i class="bi bi-box-seam-fill text-primary"></i> Đơn thuê tài sản của bạn</h2>

        <div class="row">
            <div class="col-lg-10 mx-auto">
                @if (Model != null && Model.Any()) {
                    foreach (var booking in Model) {
                        <div class="booking-card">
                            <div class="row g-4 align-items-center">
                                <div class="col-md-3">
                                    @{
                                        var imagesList = new List<string>();
                                        try {
                                            if (booking.Product != null && !string.IsNullOrEmpty(booking.Product.ImagesJson)) {
                                                imagesList = System.Text.Json.JsonSerializer.Deserialize<List<string>>(booking.Product.ImagesJson) ?? new List<string>();
                                            }
                                        } catch { }
                                        var mainImg = imagesList.Any() ? imagesList.First() : "https://images.unsplash.com/photo-1522771739844-6a9f6d5f14af?auto=format&fit=crop&w=600&q=80";
                                    }
                                    <img src="@mainImg" alt="@(booking.Product?.Name ?? "Tài sản")" class="product-img" onerror="this.src='https://images.unsplash.com/photo-1522771739844-6a9f6d5f14af?auto=format&fit=crop&w=600&q=80'" />
                                </div>
                                <div class="col-md-6">
                                    <span class="badge mb-2" style="background: var(--body-bg); color: #333333; border: 1px solid var(--border);">Đơn thuê: #@booking.Id.Substring(0, 8)</span>
                                    <h4 class="fw-bold mb-2" style="color: #000000;">@(booking.Product?.Name ?? "N/A")</h4>
                                    
                                    <div class="mb-2" style="font-size: 0.95rem; color: #333333;">
                                        <i class="bi bi-calendar3 text-primary me-2"></i> Thời gian: 
                                        <strong>@booking.StartDate.ToString("dd/MM/yyyy")</strong> đến <strong>@booking.EndDate.ToString("dd/MM/yyyy")</strong>
                                    </div>
                                    <div class="mb-3" style="font-size: 0.95rem; color: #333333;">
                                        <i class="bi bi-geo-alt-fill text-danger me-2"></i> Địa chỉ nhận: 
                                        <span>@booking.RentalAddress</span>
                                    </div>

                                    <div class="d-flex flex-wrap gap-2">
                                        <!-- Booking Status -->
                                        @if (booking.Status == "PENDING") { <span class="badge bg-warning text-dark badge-status">Chờ duyệt</span> }
                                        else if (booking.Status == "APPROVED") { <span class="badge bg-info badge-status">Đã duyệt</span> }
                                        else if (booking.Status == "ONGOING") { <span class="badge badge-status" style="background: var(--primary); color: #000000;">Đang thuê</span> }
                                        else if (booking.Status == "COMPLETED") { <span class="badge bg-success badge-status">Hoàn thành</span> }
                                        else if (booking.Status == "CANCELLED" || booking.Status == "REJECTED") { <span class="badge bg-danger badge-status">Đã hủy</span> }
                                        else { <span class="badge bg-secondary badge-status">@booking.Status</span> }

                                        <!-- Payment Status -->
                                        @if (booking.PaymentStatus == "UNPAID") { <span class="badge bg-danger badge-status">Chưa thanh toán</span> }
                                        else if (booking.PaymentStatus == "PAID") { <span class="badge bg-success badge-status">Đã thanh toán cọc</span> }
                                        else if (booking.PaymentStatus == "REFUNDED") { <span class="badge bg-info badge-status">Đã hoàn tiền</span> }
                                    </div>
                                </div>
                                <div class="col-md-3 text-md-end d-flex flex-column justify-content-between align-items-md-end">
                                    <div class="mb-3">
                                        <small class="d-block" style="color: #333333;">Tổng chi phí thuê</small>
                                        <h3 class="fw-bold m-0" style="color: var(--primary);">@booking.TotalPrice.ToString("N0")đ</h3>
                                    </div>

                                    @if (booking.PaymentStatus == "UNPAID" && booking.Status != "CANCELLED" && booking.Status != "REJECTED") {
                                        <a href="/Home/Payment/@booking.Id" class="btn btn-primary-custom w-100 py-2">
                                            <i class="bi bi-wallet2"></i> Thanh toán cọc
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                } else {
                    <div class="text-center py-5 bg-white border rounded-4 shadow-sm" style="border-color: var(--border);">
                        <i class="bi bi-inboxes fs-1 mb-3 d-block" style="color: #666666;"></i>
                        <p class="fs-5" style="color: #333333;">Bạn chưa thực hiện bất kỳ giao dịch thuê tài sản nào.</p>
                        <a href="/" class="btn btn-primary-custom px-4 py-2 mt-3">Trở về Trang chủ</a>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer>
        <div class="container text-center" style="color: #64748b; font-size: 0.9rem;">
            &copy; @DateTime.Now.Year OmniRent. Mọi quyền được bảo lưu.
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function updateCartBadge() {
            let cart = JSON.parse(localStorage.getItem('cart')) || [];
            let badge = document.getElementById('cartBadge');
            if (badge) {
                if (cart.length > 0) {
                    badge.innerText = cart.length; badge.style.display = 'inline-block';
                } else { badge.style.display = 'none'; }
            }
        }
        document.addEventListener('DOMContentLoaded', updateCartBadge);
    </script>
</body>
</html>
