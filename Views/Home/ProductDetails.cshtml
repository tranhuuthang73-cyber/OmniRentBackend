@using OmniRentBackend.Models
@model Product
@{
    Layout = null;
    var isAuthenticated = User.Identity != null && User.Identity.IsAuthenticated;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Model.Name — OmniRent</title>
    <meta name="description" content="@Model.Description" />

    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Bootstrap & Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>
        :root {
            --primary: #6C63FF;
            --primary-hover: #5a52d5;
            --secondary: #0f0c29;
            --dark-bg: #1a1a3e;
            --card-bg: rgba(255, 255, 255, 0.05);
            --text-main: #ffffff;
            --text-muted: #a89fd8;
            --border-color: rgba(255, 255, 255, 0.1);
            --glass-bg: rgba(26, 26, 62, 0.85);
        }

        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, var(--secondary) 0%, var(--dark-bg) 100%);
            color: var(--text-main);
            min-height: 100vh;
            margin: 0;
            padding: 0;
            overflow-x: hidden;
        }

        /* Navbar */
        .navbar-custom {
            background: var(--glass-bg);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border-color);
            padding: 1rem 0;
            position: fixed;
            top: 0;
            width: 100%;
            z-index: 1000;
        }

        .navbar-brand {
            font-weight: 800;
            font-size: 1.5rem;
            color: var(--text-main) !important;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            text-decoration: none;
        }

        .brand-icon {
            color: var(--primary);
            font-size: 1.8rem;
        }

        .btn-outline-primary-custom {
            color: var(--text-main);
            border: 1px solid var(--primary);
            border-radius: 50px;
            padding: 0.5rem 1.5rem;
            font-weight: 500;
            transition: all 0.3s;
            text-decoration: none;
        }

        .btn-outline-primary-custom:hover {
            background: var(--primary);
            color: white;
            box-shadow: 0 4px 15px rgba(108, 99, 255, 0.4);
        }

        .btn-primary-custom {
            background: var(--primary);
            color: white;
            border: none;
            border-radius: 50px;
            padding: 0.5rem 1.5rem;
            font-weight: 600;
            transition: all 0.3s;
            text-decoration: none;
        }

        .btn-primary-custom:hover {
            background: var(--primary-hover);
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(108, 99, 255, 0.4);
        }

        /* Content Container */
        .main-container {
            margin-top: 120px;
            padding-bottom: 80px;
        }

        /* Product Gallery */
        .gallery-wrapper {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 24px;
            overflow: hidden;
            backdrop-filter: blur(10px);
            padding: 1.5rem;
        }

        .main-image {
            width: 100%;
            height: 450px;
            object-fit: cover;
            border-radius: 16px;
            border: 1px solid var(--border-color);
            background: #2a2a4a;
        }

        /* Info Block */
        .info-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 24px;
            padding: 2.5rem;
            backdrop-filter: blur(10px);
            height: 100%;
        }

        .product-category {
            font-size: 0.9rem;
            color: var(--primary);
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            margin-bottom: 0.8rem;
        }

        .product-title {
            font-size: 2.5rem;
            font-weight: 800;
            margin-bottom: 1.5rem;
            line-height: 1.2;
        }

        .price-badge {
            display: inline-block;
            background: rgba(108, 99, 255, 0.15);
            border: 1px solid rgba(108, 99, 255, 0.3);
            border-radius: 12px;
            padding: 0.75rem 1.5rem;
            margin-bottom: 2rem;
        }

        .price-value {
            font-size: 2rem;
            font-weight: 800;
            color: white;
        }

        .price-unit {
            font-size: 1rem;
            color: var(--text-muted);
            font-weight: 400;
        }

        /* Tabs and Details */
        .spec-item {
            display: flex;
            justify-content: space-between;
            padding: 1rem 0;
            border-bottom: 1px solid var(--border-color);
        }

        .spec-label {
            color: var(--text-muted);
            font-weight: 500;
        }

        .spec-value {
            font-weight: 600;
            color: white;
        }

        /* Checkout Card */
        .booking-card {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid var(--border-color);
            border-radius: 24px;
            padding: 2rem;
            backdrop-filter: blur(15px);
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
            position: sticky;
            top: 120px;
        }

        .form-control-custom {
            background: rgba(0, 0, 0, 0.3) !important;
            border: 1px solid var(--border-color) !important;
            color: white !important;
            border-radius: 12px !important;
            padding: 0.8rem 1rem !important;
        }

        .form-control-custom:focus {
            border-color: var(--primary) !important;
            box-shadow: 0 0 10px rgba(108, 99, 255, 0.3) !important;
        }

        .form-label-custom {
            font-weight: 600;
            color: var(--text-muted);
            margin-bottom: 0.5rem;
            font-size: 0.9rem;
        }

        .pricing-summary {
            background: rgba(0,0,0,0.2);
            border-radius: 16px;
            padding: 1.5rem;
            margin: 1.5rem 0;
            border: 1px solid var(--border-color);
        }

        .summary-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 0.75rem;
            font-size: 0.95rem;
        }

        .summary-row.total {
            margin-bottom: 0;
            padding-top: 0.75rem;
            border-top: 1px solid var(--border-color);
            font-size: 1.25rem;
            font-weight: 800;
            color: #43e97b;
        }

        /* Footer */
        footer {
            background: rgba(0,0,0,0.3);
            border-top: 1px solid var(--border-color);
            padding: 4rem 0 2rem;
            margin-top: 5rem;
        }
    </style>
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-custom">
        <div class="container">
            <a class="navbar-brand" href="/">
                <i class="bi bi-building-fill brand-icon"></i> OmniRent
            </a>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/">Trang chủ</a>
                    </li>
                    @if (isAuthenticated)
                    {
                        <li class="nav-item">
                            <a class="nav-link text-white" href="/Home/MyBookings">Đơn hàng của tôi</a>
                        </li>
                    }
                </ul>
            </div>
            <div class="ms-auto d-flex gap-3 align-items-center">
                <a href="/Home/Cart" class="position-relative text-white me-3 d-flex align-items-center" style="font-size: 1.3rem; text-decoration: none;">
                    <i class="bi bi-cart3"></i>
                    <span id="cartBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.65rem; display: none;">0</span>
                </a>

                @if (isAuthenticated)
                {
                    <span class="text-white fw-bold d-none d-md-inline me-2">Xin chào, @User.Identity.Name</span>
                    <form action="/Account/Logout" method="post" class="d-inline m-0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-primary-custom">Đăng xuất</button>
                    </form>
                }
                else
                {
                    <a href="/Account/Login?returnUrl=/Home/ProductDetails/@Model.Id" class="btn btn-outline-primary-custom">Đăng nhập</a>
                }
            </div>
        </div>
    </nav>

    <!-- Toast Notification -->
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 1100;">
        <div id="cartToast" class="toast align-items-center text-white bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="bi bi-check-circle-fill me-2"></i> Đã thêm sản phẩm vào giỏ hàng!
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="container main-container">
        <div class="row g-5">
            <!-- Left Column: Product Info -->
            <div class="col-lg-7">
                <div class="gallery-wrapper mb-4">
                    @{
                        var imagesList = new List<string>();
                        try {
                            if (!string.IsNullOrEmpty(Model.ImagesJson)) {
                                imagesList = System.Text.Json.JsonSerializer.Deserialize<List<string>>(Model.ImagesJson) ?? new List<string>();
                            }
                        } catch { }

                        var mainImg = imagesList.Any() ? imagesList.First() : "https://images.unsplash.com/photo-1522771739844-6a9f6d5f14af?auto=format&fit=crop&w=600&q=80";
                    }
                    <img src="@mainImg" alt="@Model.Name" class="main-image img-fluid" onerror="this.src='https://images.unsplash.com/photo-1522771739844-6a9f6d5f14af?auto=format&fit=crop&w=600&q=80'" />
                </div>

                <div class="info-card">
                    <div class="product-category">@(Model.Category?.Name ?? "Sản phẩm")</div>
                    <h1 class="product-title">@Model.Name</h1>

                    <div class="price-badge">
                        <div class="price-value">
                            @Model.PricePerDay.ToString("N0")đ <span class="price-unit">/ ngày</span>
                        </div>
                    </div>

                    <h4 class="mb-3 fw-bold"><i class="bi bi-file-text-fill text-primary"></i> Mô tả sản phẩm</h4>
                    <p class="text-muted" style="line-height: 1.8; font-size: 1.05rem; white-space: pre-line;">@Model.Description</p>

                    <h4 class="mt-5 mb-3 fw-bold"><i class="bi bi-gear-wide-connected text-primary"></i> Thông số kỹ thuật</h4>
                    <div class="specs-wrapper mb-5">
                        <div class="spec-item">
                            <span class="spec-label">Tiền đặt cọc bắt buộc</span>
                            <span class="spec-value text-warning">@Model.DepositAmount.ToString("N0")đ</span>
                        </div>
                        @if (Model.ProductAttributes != null && Model.ProductAttributes.Any())
                        {
                            foreach (var attr in Model.ProductAttributes)
                            {
                                <div class="spec-item">
                                    <span class="spec-label">@(attr.Attribute?.Name ?? "Thông số")</span>
                                    <span class="spec-value">@attr.Value</span>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-muted py-2">Sản phẩm này chưa được bổ sung các thông số chi tiết khác.</div>
                        }
                    </div>

                    <h4 class="mt-5 mb-3 fw-bold"><i class="bi bi-person-badge-fill text-primary"></i> Thông tin chủ sở hữu</h4>
                    <div class="d-flex align-items-center gap-3 p-3 rounded-4" style="background: rgba(255,255,255,0.02); border: 1px solid var(--border-color);">
                        <div class="avatar-lg bg-primary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 50px; height: 50px; font-size: 1.25rem;">
                            @((Model.Owner?.FullName ?? "U").Substring(0, 1).ToUpper())
                        </div>
                        <div>
                            <h5 class="m-0 fw-bold">@(Model.Owner?.FullName ?? "Chủ sở hữu")</h5>
                            <small class="text-muted">Độ uy tín renter: @(Model.Owner?.RenterTrustScore ?? 80.0) điểm</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column: Simple Order Card -->
            <div class="col-lg-5">
                <div class="booking-card">
                    <h3 class="mb-4 fw-bold"><i class="bi bi-tag-fill text-primary"></i> Đặt thuê tài sản</h3>
                    
                    <div class="pricing-summary">
                        <div class="summary-row">
                            <span>Giá thuê đồ</span>
                            <span class="fw-bold">@Model.PricePerDay.ToString("N0")đ / ngày</span>
                        </div>
                        <div class="summary-row">
                            <span>Tiền đặt cọc</span>
                            <span class="fw-bold text-warning">@Model.DepositAmount.ToString("N0")đ</span>
                        </div>
                        <div class="summary-row">
                            <span>Trạng thái tài sản</span>
                            <span class="badge bg-success">Sẵn sàng cho thuê</span>
                        </div>
                    </div>

                    <div class="d-flex flex-column gap-3">
                        <a href="/Home/Checkout/@Model.Id" class="btn btn-primary-custom w-100 py-3 font-weight-bold">
                            <i class="bi bi-lightning-fill"></i> Thuê ngay (Checkout)
                        </a>
                        <button class="btn btn-outline-primary-custom w-100 py-3" onclick="addToCart()">
                            <i class="bi bi-cart-plus-fill"></i> Thêm vào giỏ hàng
                        </button>
                    </div>

                    <div class="mt-4 p-3 rounded-4" style="background: rgba(255,255,255,0.02); border: 1px solid var(--border-color); font-size: 0.85rem; color: var(--text-muted);">
                        <i class="bi bi-info-circle text-primary"></i> <strong>Lưu ý:</strong> Tiền cọc sẽ được hoàn lại 100% sau khi bạn hoàn trả tài sản nguyên vẹn cho chủ đồ.
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer>
        <div class="container text-center text-muted" style="font-size: 0.9rem;">
            &copy; @DateTime.Now.Year OmniRent. Mọi quyền được bảo lưu.
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const productId = "@Model.Id";
        const productName = "@Model.Name";
        const productPrice = @Model.PricePerDay;
        const productImage = "@mainImg";
        const productOwner = "@(Model.Owner?.FullName ?? "Chủ đồ")";

        function updateCartBadge() {
            let cart = JSON.parse(localStorage.getItem('cart')) || [];
            let badge = document.getElementById('cartBadge');
            if (badge) {
                if (cart.length > 0) {
                    badge.innerText = cart.length;
                    badge.style.display = 'inline-block';
                } else {
                    badge.style.display = 'none';
                }
            }
        }

        function addToCart() {
            let cart = JSON.parse(localStorage.getItem('cart')) || [];
            
            // Check if already in cart
            if (cart.some(item => item.id === productId)) {
                alert("Sản phẩm này đã có sẵn trong giỏ hàng của bạn!");
                return;
            }

            cart.push({
                id: productId,
                name: productName,
                price: productPrice,
                image: productImage,
                owner: productOwner
            });

            localStorage.setItem('cart', JSON.stringify(cart));
            updateCartBadge();

            // Show Toast
            let toastEl = document.getElementById('cartToast');
            let toast = new bootstrap.Toast(toastEl);
            toast.show();
        }

        document.addEventListener('DOMContentLoaded', updateCartBadge);
    </script>
</body>
</html>
