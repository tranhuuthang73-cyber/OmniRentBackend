@using OmniRentBackend.Models
@model Product
@{
    Layout = null;
    var isAuthenticated = User.Identity != null && User.Identity.IsAuthenticated;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Model.Name — OmniRent</title>
    <meta name="description" content="@Model.Description" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>
        :root {
            --primary:       #f59e0b;
            --primary-hover: #d97706;
            --primary-light: #fef3c7;
            --navy:          #0f172a;
            --navy-2:        #1e293b;
            --text-main:     #000000;
            --text-sub:      #333333;
            --text-muted:    #666666;
            --border:        #e2e8f0;
            --body-bg:       #f8fafc;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--body-bg);
            color: var(--text-main);
            min-height: 100vh;
            margin: 0; padding: 0;
            overflow-x: hidden;
        }

        /* Navbar */
        .navbar-custom {
            background: var(--navy);
            border-bottom: 1px solid rgba(255,255,255,0.06);
            padding: 1rem 0;
            position: fixed;
            top: 0; width: 100%;
            z-index: 1000;
        }
        .navbar-brand {
            font-weight: 800; font-size: 1.5rem;
            color: #ffffff !important;
            display: flex; align-items: center; gap: 0.5rem;
            text-decoration: none;
        }
        .brand-icon { color: var(--primary); font-size: 1.8rem; }
        
        .nav-link { color: #cbd5e1 !important; font-weight: 500; }
        .nav-link:hover, .nav-link.active { color: #ffffff !important; }

        .btn-outline-primary-custom {
            color: #fff;
            border: 1.5px solid rgba(255,255,255,0.25);
            border-radius: 50px;
            padding: 0.5rem 1.5rem;
            font-weight: 600;
            transition: all 0.2s;
            text-decoration: none;
        }
        .btn-outline-primary-custom:hover {
            border-color: var(--primary); color: var(--primary);
            background: rgba(245,158,11,0.08);
        }

        .btn-primary-custom {
            background: var(--primary);
            color: var(--navy);
            border: none; border-radius: 50px;
            padding: 0.5rem 1.5rem;
            font-weight: 700;
            transition: all 0.2s;
            text-decoration: none;
            box-shadow: 0 4px 14px rgba(245,158,11,0.3);
        }
        .btn-primary-custom:hover {
            background: var(--primary-hover); transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(245,158,11,0.4);
        }

        /* Content */
        .main-container { margin-top: 120px; padding-bottom: 80px; }

        .gallery-wrapper {
            background: #ffffff;
            border: 1px solid var(--border);
            border-radius: 20px;
            overflow: hidden;
            padding: 1.5rem;
            box-shadow: 0 4px 12px rgba(15,23,42,0.03);
        }
        .main-image {
            width: 100%; height: 450px;
            object-fit: cover; border-radius: 12px;
            border: 1px solid var(--border);
            background: var(--body-bg);
        }

        .info-card {
            background: #ffffff;
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 2.5rem;
            height: 100%;
            box-shadow: 0 4px 12px rgba(15,23,42,0.03);
        }

        .product-category {
            font-size: 0.9rem; color: var(--primary);
            font-weight: 800; text-transform: uppercase;
            letter-spacing: 1.5px; margin-bottom: 0.8rem;
        }
        .product-title {
            font-size: 2.5rem; font-weight: 800;
            margin-bottom: 1.5rem; line-height: 1.2;
            color: #000000;
        }

        .price-badge {
            display: inline-block;
            background: var(--primary-light);
            border: 1px solid rgba(245,158,11,0.3);
            border-radius: 12px;
            padding: 0.75rem 1.5rem;
            margin-bottom: 2rem;
        }
        .price-value { font-size: 2rem; font-weight: 800; color: #92400e; }
        .price-unit { font-size: 1rem; color: #b45309; font-weight: 500; }

        .spec-item {
            display: flex; justify-content: space-between;
            padding: 1rem 0; border-bottom: 1px solid var(--border);
        }
        .spec-label { color: #333333; font-weight: 600; }
        .spec-value { font-weight: 700; color: #000000; }

        .booking-card {
            background: #ffffff;
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 2rem;
            box-shadow: 0 15px 40px rgba(15,23,42,0.08);
            position: sticky; top: 120px;
        }

        .pricing-summary {
            background: var(--body-bg);
            border-radius: 16px;
            padding: 1.5rem; margin: 1.5rem 0;
            border: 1px solid var(--border);
        }
        .summary-row {
            display: flex; justify-content: space-between;
            margin-bottom: 0.75rem; font-size: 0.95rem;
            color: #333333;
        }
        .summary-row .fw-bold { color: #000000; }

        /* Footer */
        footer {
            background: var(--navy); border-top: 1px solid rgba(255,255,255,0.06);
            padding: 4rem 0 2rem; margin-top: 5rem;
        }
    </style>
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-custom">
        <div class="container">
            <a class="navbar-brand" href="/">
                <i class="bi bi-building-fill brand-icon"></i> OmniRent
            </a>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto">
                    <li class="nav-item"><a class="nav-link" href="/">Trang chủ</a></li>
                    @if (isAuthenticated) {
                        <li class="nav-item"><a class="nav-link" href="/Home/MyBookings">Đơn hàng của tôi</a></li>
                    }
                </ul>
            </div>
            <div class="ms-auto d-flex gap-3 align-items-center">
                <a href="/Home/Cart" class="position-relative text-white me-3 d-flex align-items-center" style="font-size: 1.3rem; text-decoration: none;">
                    <i class="bi bi-cart3"></i>
                    <span id="cartBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.65rem; display: none;">0</span>
                </a>

                @if (isAuthenticated) {
                    <span class="text-white fw-bold d-none d-md-inline me-2">Xin chào, @User.Identity.Name</span>
                    <form action="/Account/Logout" method="post" class="d-inline m-0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-primary-custom">Đăng xuất</button>
                    </form>
                } else {
                    <a href="/Account/Login?returnUrl=/Home/ProductDetails/@Model.Id" class="btn btn-outline-primary-custom">Đăng nhập</a>
                }
            </div>
        </div>
    </nav>

    <!-- Toast Notification -->
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 1100;">
        <div id="cartToast" class="toast align-items-center text-white bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body"><i class="bi bi-check-circle-fill me-2"></i> Đã thêm sản phẩm vào giỏ hàng!</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="container main-container">
        <div class="row g-5">
            <!-- Left: Product Info -->
            <div class="col-lg-7">
                <div class="gallery-wrapper mb-4">
                    @{
                        var imagesList = new List<string>();
                        try {
                            if (!string.IsNullOrEmpty(Model.ImagesJson)) {
                                imagesList = System.Text.Json.JsonSerializer.Deserialize<List<string>>(Model.ImagesJson) ?? new List<string>();
                            }
                        } catch { }
                        var mainImg = imagesList.Any() ? imagesList.First() : "https://images.unsplash.com/photo-1522771739844-6a9f6d5f14af?auto=format&fit=crop&w=600&q=80";
                    }
                    <img src="@mainImg" alt="@Model.Name" class="main-image img-fluid" onerror="this.src='https://images.unsplash.com/photo-1522771739844-6a9f6d5f14af?auto=format&fit=crop&w=600&q=80'" />
                </div>

                <div class="info-card">
                    <div class="product-category">@(Model.Category?.Name ?? "Sản phẩm")</div>
                    <h1 class="product-title">@Model.Name</h1>

                    <div class="price-badge">
                        <div class="price-value">@Model.PricePerDay.ToString("N0")đ <span class="price-unit">/ ngày</span></div>
                    </div>

                    <h4 class="mb-3 fw-bold" style="color: #000000;"><i class="bi bi-file-text-fill text-primary"></i> Mô tả sản phẩm</h4>
                    <p style="color: #333333; line-height: 1.8; font-size: 1.05rem; white-space: pre-line;">@Model.Description</p>

                    <h4 class="mt-5 mb-3 fw-bold" style="color: #000000;"><i class="bi bi-gear-wide-connected text-primary"></i> Thông số kỹ thuật</h4>
                    <div class="specs-wrapper mb-5">
                        <div class="spec-item">
                            <span class="spec-label">Tiền đặt cọc bắt buộc</span>
                            <span class="spec-value" style="color: #dc2626;">@Model.DepositAmount.ToString("N0")đ</span>
                        </div>
                        @if (Model.ProductAttributes != null && Model.ProductAttributes.Any()) {
                            foreach (var attr in Model.ProductAttributes) {
                                <div class="spec-item">
                                    <span class="spec-label">@(attr.Attribute?.Name ?? "Thông số")</span>
                                    <span class="spec-value">@attr.Value</span>
                                </div>
                            }
                        } else {
                            <div class="py-2" style="color: #666666;">Sản phẩm này chưa được bổ sung các thông số chi tiết khác.</div>
                        }
                    </div>

                    <h4 class="mt-5 mb-3 fw-bold" style="color: #000000;"><i class="bi bi-person-badge-fill text-primary"></i> Thông tin chủ sở hữu</h4>
                    <div class="d-flex align-items-center gap-3 p-3 rounded-4" style="background: var(--body-bg); border: 1px solid var(--border);">
                        <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 50px; height: 50px; font-size: 1.25rem; background: var(--primary-light); color: var(--primary);">
                            @((Model.Owner?.FullName ?? "U").Substring(0, 1).ToUpper())
                        </div>
                        <div>
                            <h5 class="m-0 fw-bold" style="color: #000000;">@(Model.Owner?.FullName ?? "Chủ sở hữu")</h5>
                            <small style="color: #333333;">Độ uy tín renter: @(Model.Owner?.RenterTrustScore ?? 80.0) điểm</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right: Order Card -->
            <div class="col-lg-5">
                <div class="booking-card">
                    <h3 class="mb-4 fw-bold" style="color: #000000;"><i class="bi bi-tag-fill text-primary"></i> Đặt thuê tài sản</h3>
                    
                    <div class="pricing-summary">
                        <div class="summary-row">
                            <span>Giá thuê đồ</span>
                            <span class="fw-bold">@Model.PricePerDay.ToString("N0")đ / ngày</span>
                        </div>
                        <div class="summary-row">
                            <span>Tiền đặt cọc</span>
                            <span class="fw-bold" style="color: #dc2626;">@Model.DepositAmount.ToString("N0")đ</span>
                        </div>
                        <div class="summary-row">
                            <span>Trạng thái</span>
                            <span class="badge bg-success" style="font-weight: 600;">Sẵn sàng cho thuê</span>
                        </div>
                    </div>

                    <div class="d-flex flex-column gap-3">
                        <a href="/Home/Checkout/@Model.Id" class="btn btn-primary-custom w-100 py-3 font-weight-bold">
                            <i class="bi bi-lightning-fill"></i> Thuê ngay (Checkout)
                        </a>
                        <button class="btn w-100 py-3 fw-bold" style="border: 2px solid var(--primary); color: var(--primary); border-radius: 50px;" onclick="addToCart()" onmouseover="this.style.background='var(--primary-light)'" onmouseout="this.style.background='transparent'">
                            <i class="bi bi-cart-plus-fill"></i> Thêm vào giỏ hàng
                        </button>
                    </div>

                    <div class="mt-4 p-3 rounded-4" style="background: var(--primary-light); border: 1px solid rgba(245,158,11,0.3); font-size: 0.85rem; color: #92400e;">
                        <i class="bi bi-info-circle text-primary"></i> <strong style="color: #78350f;">Lưu ý:</strong> Tiền cọc sẽ được hoàn lại 100% sau khi bạn hoàn trả tài sản nguyên vẹn cho chủ đồ.
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer>
        <div class="container text-center" style="color: #64748b; font-size: 0.9rem;">
            &copy; @DateTime.Now.Year OmniRent. Mọi quyền được bảo lưu.
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const productId = "@Model.Id";
        const productName = "@Model.Name";
        const productPrice = @Model.PricePerDay;
        const productImage = "@mainImg";
        const productOwner = "@(Model.Owner?.FullName ?? "Chủ đồ")";

        function updateCartBadge() {
            let cart = JSON.parse(localStorage.getItem('cart')) || [];
            let badge = document.getElementById('cartBadge');
            if (badge) {
                if (cart.length > 0) {
                    badge.innerText = cart.length; badge.style.display = 'inline-block';
                } else { badge.style.display = 'none'; }
            }
        }

        function addToCart() {
            let cart = JSON.parse(localStorage.getItem('cart')) || [];
            if (cart.some(item => item.id === productId)) {
                alert("Sản phẩm này đã có sẵn trong giỏ hàng của bạn!"); return;
            }
            cart.push({ id: productId, name: productName, price: productPrice, image: productImage, owner: productOwner });
            localStorage.setItem('cart', JSON.stringify(cart));
            updateCartBadge();
            let toastEl = document.getElementById('cartToast');
            let toast = new bootstrap.Toast(toastEl);
            toast.show();
        }
        document.addEventListener('DOMContentLoaded', updateCartBadge);
    </script>
</body>
</html>
