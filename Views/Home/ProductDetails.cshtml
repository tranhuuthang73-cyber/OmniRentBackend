@using OmniRentBackend.Models
@model Product
@{
    Layout = null;
    var isAuthenticated = User.Identity != null && User.Identity.IsAuthenticated;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Model.Name — OmniRent</title>
    <meta name="description" content="@Model.Description" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>
        :root, [data-theme="light"] {
            --primary:        #eab308; /* Premium Gold Yellow */
            --primary-hover:  #ca8a04;
            --primary-light:  #fef9c3;
            --navy:           #09090b; /* Pure Obsidian Black */
            --navy-2:         #18181b; /* Dark zinc */
            --accent:         #eab308;
            --body-bg:        #fafafa; /* Sleek light gray */
            --section-alt:    #ffffff;
            --text-primary:   #09090b;
            --text-secondary: #4b5563;
            --text-muted:     #9ca3af;
            --border:         #e5e7eb;
            --card-bg:        #ffffff;
            --card-shadow:    0 4px 20px rgba(9,9,11,0.03);
            --navbar-bg:      rgba(255, 255, 255, 0.85);
            --navbar-shadow:  0 1px 2px rgba(9,9,11,0.05);
            --footer-bg:      #09090b;
            --footer-text:    #9ca3af;
            --footer-heading:  #f3f4f6;
            --footer-border:  #1f2937;
            --tag-color:      #854d0e;
        }

        [data-theme="dark"] {
            --primary:        #facc15; /* Vibrant Gold Yellow */
            --primary-hover:  #eab308;
            --primary-light:  rgba(250,204,21,0.1);
            --navy:           #f3f4f6; /* Off-white text */
            --navy-2:         #e5e7eb;
            --accent:         #fbbf24;
            --body-bg:        #09090b; /* Pure Black Background */
            --section-alt:    #121214; /* Charcoal background */
            --text-primary:   #f3f4f6;
            --text-secondary: #9ca3af;
            --text-muted:     #6b7280;
            --border:         #1f2937;
            --card-bg:        #18181b;
            --card-shadow:    0 10px 30px rgba(0,0,0,0.3);
            --navbar-bg:      rgba(9, 9, 11, 0.85);
            --navbar-shadow:  0 1px 0 rgba(255,255,255,0.05);
            --footer-bg:      #020203;
            --footer-text:    #6b7280;
            --footer-heading:  #f3f4f6;
            --footer-border:  #18181b;
            --tag-color:      #fde047;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--body-bg);
            color: var(--text-primary);
            min-height: 100vh;
            margin: 0; padding: 0;
            overflow-x: hidden;
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        /* Navbar */
        .navbar-custom {
            background: var(--navbar-bg);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border);
            padding: 0.875rem 0;
            position: fixed;
            top: 0; width: 100%;
            z-index: 1000;
            box-shadow: var(--navbar-shadow);
            transition: all 0.3s ease;
        }
        .navbar-brand {
            font-weight: 800; font-size: 1.4rem;
            color: var(--text-primary) !important;
            display: flex; align-items: center; gap: 0.5rem;
            text-decoration: none;
        }
        .brand-icon { color: var(--primary); font-size: 1.6rem; }
        
        .nav-link-custom {
            color: var(--text-secondary) !important;
            font-weight: 500;
            font-size: 0.9rem;
            padding: 0.5rem 0.85rem !important;
            border-radius: 6px;
            transition: all 0.2s;
            text-decoration: none;
        }
        .nav-link-custom:hover, .nav-link-custom.active {
            color: var(--primary) !important;
            background: var(--primary-light);
        }

        .btn-nav-outline {
            color: var(--text-secondary);
            border: 1.5px solid var(--border);
            border-radius: 8px;
            padding: 0.45rem 1.1rem;
            font-size: 0.85rem;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
        }
        .btn-nav-outline:hover {
            border-color: var(--primary);
            color: var(--primary);
            background: rgba(245,158,11,0.06);
        }

        .btn-nav-primary {
            background: var(--primary);
            color: var(--navy) !important;
            border: none;
            border-radius: 8px;
            padding: 0.45rem 1.2rem;
            font-size: 0.85rem;
            font-weight: 700;
            text-decoration: none;
            transition: all 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
        }
        .btn-nav-primary:hover {
            background: var(--primary-hover);
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(245,158,11,0.4);
        }

        .cart-icon {
            color: var(--text-secondary);
            font-size: 1.25rem;
            text-decoration: none;
            position: relative;
            transition: color 0.2s;
        }
        .cart-icon:hover { color: var(--primary); }

        .theme-toggle {
            background: transparent;
            border: 1.5px solid var(--border);
            border-radius: 10px;
            width: 38px; height: 38px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 1.1rem;
            color: var(--text-secondary);
            transition: all 0.25s;
            flex-shrink: 0;
        }
        .theme-toggle:hover {
            border-color: var(--primary);
            color: var(--primary);
            background: var(--primary-light);
        }
        .theme-toggle .bi-moon-fill { display: inline; }
        .theme-toggle .bi-sun-fill { display: none; }
        [data-theme="dark"] .theme-toggle .bi-moon-fill { display: none; }
        [data-theme="dark"] .theme-toggle .bi-sun-fill { display: inline; }

        /* Content */
        .main-container { margin-top: 120px; padding-bottom: 80px; }

        .gallery-wrapper {
            background: var(--card-bg);
            border: 1.5px solid var(--border);
            border-radius: 20px;
            overflow: hidden;
            padding: 1.5rem;
            box-shadow: var(--card-shadow);
            transition: background-color 0.3s ease, border-color 0.3s ease;
        }
        .main-image {
            width: 100%; height: 450px;
            object-fit: cover; border-radius: 12px;
            border: 1px solid var(--border);
            background: var(--body-bg);
        }

        .info-card {
            background: var(--card-bg);
            border: 1.5px solid var(--border);
            border-radius: 20px;
            padding: 2.5rem;
            box-shadow: var(--card-shadow);
            transition: background-color 0.3s ease, border-color 0.3s ease;
        }

        .product-category {
            font-size: 0.72rem;
            color: var(--tag-color);
            font-weight: 750;
            text-transform: uppercase;
            letter-spacing: 1px;
            background: var(--primary-light);
            display: inline-block;
            padding: 0.25rem 0.75rem;
            border-radius: 6px;
            margin-bottom: 1rem;
        }
        .product-title {
            font-size: 2.2rem; font-weight: 800;
            margin-bottom: 1.5rem; line-height: 1.25;
            color: var(--text-primary);
        }

        .price-badge {
            display: inline-block;
            background: var(--primary-light);
            border: 1px solid rgba(245,158,11,0.3);
            border-radius: 12px;
            padding: 0.75rem 1.5rem;
            margin-bottom: 2rem;
        }
        .price-value { font-size: 2rem; font-weight: 850; color: var(--tag-color); }
        .price-unit { font-size: 1rem; color: var(--text-secondary); font-weight: 500; }

        .spec-item {
            display: flex; justify-content: space-between;
            padding: 1rem 0; border-bottom: 1px solid var(--border);
        }
        .spec-label { color: var(--text-secondary); font-weight: 600; }
        .spec-value { font-weight: 700; color: var(--text-primary); }

        .booking-card {
            background: var(--card-bg);
            border: 1.5px solid var(--border);
            border-radius: 20px;
            padding: 2rem;
            box-shadow: var(--card-shadow);
            position: sticky; top: 120px;
            transition: background-color 0.3s ease, border-color 0.3s ease;
        }

        .pricing-summary {
            background: var(--body-bg);
            border-radius: 16px;
            padding: 1.5rem; margin: 1.5rem 0;
            border: 1px solid var(--border);
            transition: background-color 0.3s ease, border-color 0.3s ease;
        }
        .summary-row {
            display: flex; justify-content: space-between;
            margin-bottom: 0.75rem; font-size: 0.95rem;
            color: var(--text-secondary);
        }
        .summary-row .fw-bold { color: var(--text-primary); }

        .owner-avatar-details {
            width: 50px; height: 50px;
            font-size: 1.25rem;
            border-radius: 50%;
            background: var(--primary-light);
            color: var(--tag-color);
            display: flex; align-items: center; justify-content: center;
            font-weight: 700;
        }

        /* Footer */
        footer {
            background: var(--footer-bg);
            border-top: 1px solid var(--footer-border);
            padding: 4rem 0 2rem;
            margin-top: 5rem;
            transition: background-color 0.3s ease;
        }

        .footer-brand {
            font-size: 1.5rem;
            font-weight: 800;
            color: #ffffff;
            display: flex;
            align-items: center;
            gap: 0.4rem;
            margin-bottom: 0.75rem;
        }

        .footer-text { color: #64748b; max-width: 280px; font-size: 0.875rem; line-height: 1.7; }
        .footer-title { font-weight: 700; color: #e2e8f0; font-size: 0.85rem; margin-bottom: 1.25rem; text-transform: uppercase; letter-spacing: 0.5px; }

        .footer-links { list-style: none; padding: 0; margin: 0; }
        .footer-links li { margin-bottom: 0.65rem; }
        .footer-links a { color: #64748b; text-decoration: none; font-size: 0.875rem; transition: color 0.2s; }
        .footer-links a:hover { color: var(--primary); }

        .social-icon {
            width: 36px; height: 36px;
            border-radius: 8px;
            background: rgba(255,255,255,0.06);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: #64748b;
            font-size: 1rem;
            text-decoration: none;
            transition: all 0.2s;
        }
        .social-icon:hover { background: var(--primary); color: var(--navy); }

        /* Review section styles */
        .review-header-stats {
            display: flex;
            align-items: center;
            gap: 1.5rem;
            padding: 1.5rem;
            background: var(--body-bg);
            border: 1px solid var(--border);
            border-radius: 16px;
            margin-bottom: 2rem;
            transition: background-color 0.3s ease, border-color 0.3s ease;
        }
        .rating-avg-box {
            font-size: 3rem;
            font-weight: 850;
            color: var(--text-primary);
            line-height: 1;
        }
        .review-card {
            border-bottom: 1px solid var(--border);
            padding: 1.5rem 0;
        }
        .review-card:last-child {
            border-bottom: none;
        }
        .reviewer-avatar {
            width: 44px; height: 44px;
            border-radius: 50%;
            background: var(--primary-light);
            color: var(--tag-color);
            font-weight: 700;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
        }
        .review-stars {
            color: var(--primary);
            font-size: 0.9rem;
        }
        .text-lead-description {
            color: var(--text-secondary);
            line-height: 1.8;
            font-size: 1.05rem;
            white-space: pre-line;
        }
    </style>
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-custom">
        <div class="container">
            <a class="navbar-brand" href="/">
                <i class="bi bi-building-fill brand-icon"></i> OmniRent
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                    aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <i class="bi bi-list fs-2" style="color:var(--text-primary)"></i>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                    <li class="nav-item">
                        <a class="nav-link-custom" href="/">Trang chủ</a>
                    </li>
                <div class="d-flex gap-2 mt-3 mt-lg-0 align-items-center">
                    <!-- Theme Toggle -->
                    <button class="theme-toggle" id="themeToggle" title="Chuyển chế độ sáng/tối">
                        <i class="bi bi-moon-fill"></i>
                        <i class="bi bi-sun-fill"></i>
                    </button>

                    <!-- Cart -->
                    <a href="/Home/Cart" class="cart-icon position-relative me-1">
                        <i class="bi bi-cart3"></i>
                        <span id="cartBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.6rem; display: none;">0</span>
                    </a>

                    @if (isAuthenticated) {
                        var userAvatar = User.FindFirst("AvatarUrl")?.Value;
                        <div class="dropdown">
                            <button class="btn dropdown-toggle d-flex align-items-center gap-2 border-0 bg-transparent p-0" type="button" id="userMenuButton" data-bs-toggle="dropdown" aria-expanded="false" style="color:var(--text-primary); font-size:0.9rem; font-weight:600;">
                                <div class="profile-avatar" style="width: 32px; height: 32px; border-radius: 50%; background: var(--primary); color: var(--navy); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.85rem; overflow: hidden; border: 1.5px solid var(--primary);">
                                    @if (!string.IsNullOrEmpty(userAvatar))
                                    {
                                        <img src="@userAvatar" alt="Avatar" style="width:100%; height:100%; object-fit:cover;" />
                                    }
                                    else
                                    {
                                        @User.Identity.Name.Substring(0, 1).ToUpper()
                                    }
                                </div>
                                <span class="d-none d-md-inline" style="color:var(--text-primary)">@User.Identity.Name</span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end p-2 border-0" aria-labelledby="userMenuButton" style="background: var(--card-bg); box-shadow: var(--card-shadow); border-radius: 12px; min-width: 200px;">
                                <li>
                                    <a class="dropdown-item rounded-3 py-2 px-3 d-flex align-items-center gap-2"
                                       href="/Account/EditProfile"
                                       style="color: var(--text-primary); font-size: 0.85rem; font-weight: 500;">
                                        <i class="bi bi-person-gear text-primary"></i> Chỉnh sửa hồ sơ
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item rounded-3 py-2 px-3 d-flex align-items-center gap-2" href="/Account/Profile" style="color: var(--text-primary); font-size: 0.85rem; font-weight: 500;">
                                        <i class="bi bi-person-circle text-primary"></i> Trang cá nhân & Lịch sử
                                    </a>
                                </li>
                                @if (User.IsInRole("OWNER"))
                                {
                                    <li>
                                        <a class="dropdown-item rounded-3 py-2 px-3 d-flex align-items-center gap-2" href="/OwnerDashboard" style="color: var(--text-primary); font-size: 0.85rem; font-weight: 500;">
                                            <i class="bi bi-house-door-fill text-primary"></i> Quản lý tài sản
                                        </a>
                                    </li>
                                }
                                @if (User.IsInRole("ADMIN"))
                                {
                                    <li>
                                        <a class="dropdown-item rounded-3 py-2 px-3 d-flex align-items-center gap-2" href="/AdminDashboard/Bookings" style="color: var(--text-primary); font-size: 0.85rem; font-weight: 500;">
                                            <i class="bi bi-shield-lock-fill text-primary"></i> Trang quản trị
                                        </a>
                                    </li>
                                }
                                <li><hr class="dropdown-divider" style="border-color: var(--border);"></li>
                                <li>
                                    <form action="/Account/Logout" method="post" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item rounded-3 py-2 px-3 text-danger d-flex align-items-center gap-2 bg-transparent border-0 w-100 text-start" style="font-size: 0.85rem; font-weight: 600;">
                                            <i class="bi bi-box-arrow-right"></i> Đăng xuất
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    } else {
                        <a href="/Account/Login?returnUrl=/Home/ProductDetails/@Model.Id" class="btn-nav-outline">Đăng nhập</a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <!-- Toast Notification -->
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 1100;">
        <div id="cartToast" class="toast align-items-center text-white bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body"><i class="bi bi-check-circle-fill me-2"></i> Đã thêm sản phẩm vào giỏ hàng!</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="container main-container">
        <div class="row g-5">
            <!-- Left: Product Info -->
            <div class="col-lg-7">
                <div class="gallery-wrapper mb-4">
                    @{
                        var imagesList = new List<string>();
                        try {
                            if (!string.IsNullOrEmpty(Model.ImagesJson)) {
                                imagesList = System.Text.Json.JsonSerializer.Deserialize<List<string>>(Model.ImagesJson) ?? new List<string>();
                            }
                        } catch { }
                        var mainImg = imagesList.Any() ? imagesList.First() : "https://images.unsplash.com/photo-1522771739844-6a9f6d5f14af?auto=format&fit=crop&w=600&q=80";
                    }
                    <img src="@mainImg" alt="@Model.Name" class="main-image img-fluid" onerror="this.src='https://images.unsplash.com/photo-1522771739844-6a9f6d5f14af?auto=format&fit=crop&w=600&q=80'" />
                </div>

                <div class="info-card">
                    <div class="product-category">@(Model.Category?.Name ?? "Sản phẩm")</div>
                    <h1 class="product-title">@Model.Name</h1>

                    <div class="price-badge">
                        <div class="price-value">@Model.PricePerDay.ToString("N0")đ <span class="price-unit">/ ngày</span></div>
                    </div>

                    <h4 class="mb-3 fw-bold" style="color: var(--text-primary);"><i class="bi bi-file-text-fill text-primary"></i> Mô tả sản phẩm</h4>
                    <p class="text-lead-description">@Model.Description</p>

                    <h4 class="mt-5 mb-3 fw-bold" style="color: var(--text-primary);"><i class="bi bi-gear-wide-connected text-primary"></i> Thông số kỹ thuật</h4>
                    <div class="specs-wrapper mb-5">
                        <div class="spec-item">
                            <span class="spec-label">Tiền đặt cọc bắt buộc</span>
                            <span class="spec-value text-danger">@Model.DepositAmount.ToString("N0")đ</span>
                        </div>
                        @if (Model.ProductAttributes != null && Model.ProductAttributes.Any()) {
                            foreach (var attr in Model.ProductAttributes) {
                                <div class="spec-item">
                                    <span class="spec-label">@(attr.Attribute?.Name ?? "Thông số")</span>
                                    <span class="spec-value">@attr.Value</span>
                                </div>
                            }
                        } else {
                            <div class="py-2 style-muted" style="color: var(--text-muted);">Sản phẩm này chưa được bổ sung các thông số chi tiết khác.</div>
                        }
                    </div>

                    <h4 class="mt-5 mb-3 fw-bold" style="color: var(--text-primary);"><i class="bi bi-person-badge-fill text-primary"></i> Thông tin chủ sở hữu</h4>
                    <div class="d-flex align-items-center gap-3 p-3 rounded-4" style="background: var(--body-bg); border: 1px solid var(--border);">
                        <div class="owner-avatar-details">
                            @((Model.Owner?.FullName ?? "U").Substring(0, 1).ToUpper())
                        </div>
                        <div>
                            <h5 class="m-0 fw-bold" style="color: var(--text-primary);">@(Model.Owner?.FullName ?? "Chủ sở hữu")</h5>
                            <small style="color: var(--text-secondary);">Độ uy tín renter: @(Model.Owner?.RenterTrustScore ?? 80.0) điểm</small>
                        </div>
                    </div>
                </div>

                <!-- Reviews Section -->
                <div class="info-card mt-4">
                    <h4 class="mb-4 fw-bold" style="color: var(--text-primary);"><i class="bi bi-star-fill text-primary"></i> Đánh giá từ khách hàng</h4>
                    
                    @{
                        var reviews = Model.Reviews != null ? Model.Reviews.ToList() : new List<Review>();
                        var avgRating = reviews.Any() ? reviews.Average(r => r.Rating) : 0;
                        var totalReviews = reviews.Count;
                    }

                    @if (reviews.Any()) {
                        <div class="review-header-stats">
                            <div class="rating-avg-box">@avgRating.ToString("F1")</div>
                            <div>
                                <div class="review-stars mb-1">
                                    @for (int i = 1; i <= 5; i++) {
                                        if (i <= Math.Round(avgRating)) {
                                            <i class="bi bi-star-fill"></i>
                                        } else {
                                            <i class="bi bi-star"></i>
                                        }
                                    }
                                </div>
                                <div style="font-size: 0.9rem; color: var(--text-secondary);">Dựa trên @totalReviews đánh giá thực tế</div>
                            </div>
                        </div>

                        <div class="reviews-list">
                            @foreach (var review in reviews.OrderByDescending(r => r.CreatedAt)) {
                                <div class="review-card">
                                    <div class="d-flex align-items-start gap-3">
                                        <div class="reviewer-avatar">
                                            @((review.User?.FullName ?? "U").Substring(0, 1).ToUpper())
                                        </div>
                                        <div class="flex-grow-1">
                                            <div class="d-flex justify-content-between align-items-center mb-1">
                                                <h6 class="m-0 fw-bold" style="color: var(--text-primary);">@(review.User?.FullName ?? "Khách hàng ẩn danh")</h6>
                                                <small style="color: var(--text-muted);">@review.CreatedAt.ToString("dd/MM/yyyy")</small>
                                            </div>
                                            <div class="review-stars mb-2">
                                                @for (int i = 1; i <= 5; i++) {
                                                    if (i <= review.Rating) {
                                                        <i class="bi bi-star-fill"></i>
                                                    } else {
                                                        <i class="bi bi-star"></i>
                                                    }
                                                }
                                            </div>
                                            <p class="m-0" style="color: var(--text-secondary); font-size: 0.95rem; line-height: 1.6; white-space: pre-line;">@review.Comment</p>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    } else {
                        <div class="text-center py-5 rounded-4" style="background: var(--body-bg); border: 1px solid var(--border);">
                            <i class="bi bi-chat-left-text text-muted fs-1 mb-3 d-block"></i>
                            <p style="color: var(--text-secondary); margin: 0;">Chưa có đánh giá nào cho sản phẩm này.</p>
                            <small style="color: var(--text-muted);">Hãy là người đầu tiên thuê và chia sẻ cảm nhận!</small>
                        </div>
                    }
                </div>
            </div>

            <!-- Right: Order Card -->
            <div class="col-lg-5">
                <div class="booking-card">
                    <h3 class="mb-4 fw-bold" style="color: var(--text-primary);"><i class="bi bi-tag-fill text-primary"></i> Đặt thuê tài sản</h3>
                    
                    <div class="pricing-summary">
                        <div class="summary-row">
                            <span>Giá thuê đồ</span>
                            <span class="fw-bold">@Model.PricePerDay.ToString("N0")đ / ngày</span>
                        </div>
                        <div class="summary-row">
                            <span>Tiền đặt cọc</span>
                            <span class="fw-bold text-danger">@Model.DepositAmount.ToString("N0")đ</span>
                        </div>
                        <div class="summary-row">
                            <span>Trạng thái</span>
                            <span class="badge bg-success" style="font-weight: 600;">Sẵn sàng cho thuê</span>
                        </div>
                    </div>

                    <div class="d-flex flex-column gap-3">
                        <a href="/Home/Checkout/@Model.Id" class="btn btn-nav-primary w-100 py-3 font-weight-bold text-center justify-content-center">
                            <i class="bi bi-lightning-fill"></i> Thuê ngay
                        </a>
                        <button class="btn w-100 py-3 fw-bold" style="border: 2px solid var(--primary); color: var(--primary); border-radius: 50px; background: transparent; transition: all 0.2s;" onclick="addToCart()" onmouseover="this.style.background='var(--primary-light)'" onmouseout="this.style.background='transparent'">
                            <i class="bi bi-cart-plus-fill"></i> Thêm vào giỏ hàng
                        </button>
                    </div>

                    <div class="mt-4 p-3 rounded-4" style="background: var(--primary-light); border: 1px solid rgba(245,158,11,0.3); font-size: 0.85rem; color: var(--tag-color);">
                        <i class="bi bi-info-circle text-primary"></i> <strong>Lưu ý:</strong> Tiền cọc sẽ được hoàn lại 100% sau khi bạn hoàn trả tài sản nguyên vẹn cho chủ đồ.
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ======================== FOOTER ======================== -->
    <footer>
        <div class="container">
            <div class="row g-5">
                <div class="col-lg-4">
                    <div class="footer-brand">
                        <i class="bi bi-building-fill" style="color: var(--primary);"></i> OmniRent
                    </div>
                    <p class="footer-text">Nền tảng kết nối người thuê và người cho thuê nhanh chóng, an toàn và minh bạch nhất hiện nay.</p>
                    <div class="d-flex gap-2 mt-3">
                        <a href="#" class="social-icon"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="social-icon"><i class="bi bi-instagram"></i></a>
                        <a href="#" class="social-icon"><i class="bi bi-twitter-x"></i></a>
                    </div>
                </div>
                <div class="col-lg-2 col-md-4">
                    <h4 class="footer-title">Khám phá</h4>
                    <ul class="footer-links">
                        <li><a href="#">Tất cả tài sản</a></li>
                        <li><a href="#">Danh mục nổi bật</a></li>
                        <li><a href="#">Chủ cho thuê uy tín</a></li>
                    </ul>
                </div>
                <div class="col-lg-2 col-md-4">
                    <h4 class="footer-title">Hỗ trợ</h4>
                    <ul class="footer-links">
                        <li><a href="#">Trung tâm trợ giúp</a></li>
                        <li><a href="#">Quy định an toàn</a></li>
                        <li><a href="#">Chính sách bảo mật</a></li>
                    </ul>
                </div>
                <div class="col-lg-4 col-md-4">
                    <h4 class="footer-title">Liên hệ</h4>
                    <ul class="footer-links">
                        <li><i class="bi bi-envelope me-2" style="color:var(--primary)"></i>support@omnirent.vn</li>
                        <li><i class="bi bi-telephone me-2" style="color:var(--primary)"></i>1800 000 000</li>
                        <li><i class="bi bi-geo-alt me-2" style="color:var(--primary)"></i>Hồ Chí Minh, Việt Nam</li>
                    </ul>
                </div>
            </div>
            <div class="text-center mt-5 pt-4" style="border-top: 1px solid rgba(255,255,255,0.06); color: #475569; font-size: 0.82rem;">
                &copy; @DateTime.Now.Year OmniRent. Mọi quyền được bảo lưu.
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const productId = "@Model.Id";
        const productName = "@Model.Name";
        const productPrice = @Model.PricePerDay;
        const productImage = "@mainImg";
        const productOwner = "@(Model.Owner?.FullName ?? "Chủ đồ")";

        // =================== Theme Toggle ===================
        (function() {
            const root = document.documentElement;
            const toggle = document.getElementById('themeToggle');
            const storageKey = 'omnirent-theme';

            function getPreferred() {
                const saved = localStorage.getItem(storageKey);
                if (saved) return saved;
                return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
            }

            function applyTheme(theme) {
                root.setAttribute('data-theme', theme);
                localStorage.setItem(storageKey, theme);
            }

            applyTheme(getPreferred());

            if (toggle) {
                toggle.addEventListener('click', () => {
                    const current = root.getAttribute('data-theme') || 'light';
                    applyTheme(current === 'dark' ? 'light' : 'dark');
                });
            }

            window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
                if (!localStorage.getItem(storageKey)) {
                    applyTheme(e.matches ? 'dark' : 'light');
                }
            });
        })();

        function updateCartBadge() {
            let cart = JSON.parse(localStorage.getItem('cart')) || [];
            let badge = document.getElementById('cartBadge');
            if (badge) {
                if (cart.length > 0) {
                    badge.innerText = cart.length; badge.style.display = 'inline-block';
                } else { badge.style.display = 'none'; }
            }
        }

        function addToCart() {
            let cart = JSON.parse(localStorage.getItem('cart')) || [];
            if (cart.some(item => item.id === productId)) {
                alert("Sản phẩm này đã có sẵn trong giỏ hàng của bạn!"); return;
            }
            cart.push({ id: productId, name: productName, price: productPrice, image: productImage, owner: productOwner });
            localStorage.setItem('cart', JSON.stringify(cart));
            updateCartBadge();
            let toastEl = document.getElementById('cartToast');
            let toast = new bootstrap.Toast(toastEl);
            toast.show();
        }
        document.addEventListener('DOMContentLoaded', updateCartBadge);
    </script>
</body>
</html>
