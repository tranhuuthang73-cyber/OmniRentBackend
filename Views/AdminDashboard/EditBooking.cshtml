@using OmniRentBackend.Models
@model Booking
@{
    ViewData["Title"] = "Cập nhật Trạng thái Đơn hàng";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card card-custom p-4" style="max-width: 800px; margin: 0 auto;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="m-0 fw-bold">Cập nhật Trạng thái Đơn hàng</h4>
        <a href="/AdminDashboard/Bookings" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Hủy</a>
    </div>

    <form method="post" action="/AdminDashboard/EditBooking/@Model.Id">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label class="form-label text-muted">Sản phẩm</label>
            <input type="text" class="form-control" value="@(Model.Product?.Name)" disabled>
        </div>

        <div class="mb-3">
            <label class="form-label text-muted">Người thuê</label>
            <input type="text" class="form-control" value="@(Model.Renter?.FullName)" disabled>
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Địa chỉ nhận tài sản cho thuê</label>
            <textarea class="form-control" rows="2" disabled>@Model.RentalAddress</textarea>
        </div>

        <div class="row mb-3">
            <div class="col-md-6">
                <label for="StartDate" class="form-label fw-bold">Ngày thuê</label>
                <input type="date" class="form-control" id="StartDate" value="@Model.StartDate.ToString("yyyy-MM-dd")" disabled>
            </div>
            <div class="col-md-6">
                <label for="EndDate" class="form-label fw-bold">Ngày trả</label>
                <input type="date" class="form-control" id="EndDate" value="@Model.EndDate.ToString("yyyy-MM-dd")" disabled>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-6">
                <label for="Status" class="form-label fw-bold">Trạng thái</label>
                <select class="form-select" id="Status" name="Status" required>
                    <option value="PENDING" selected="@(Model.Status == "PENDING")">Chờ duyệt (PENDING)</option>
                    <option value="APPROVED" selected="@(Model.Status == "APPROVED")">Đã duyệt (APPROVED)</option>
                    <option value="ONGOING" selected="@(Model.Status == "ONGOING")">Đang thuê (ONGOING)</option>
                    <option value="COMPLETED" selected="@(Model.Status == "COMPLETED")">Hoàn thành (COMPLETED)</option>
                    <option value="CANCELLED" selected="@(Model.Status == "CANCELLED")">Hủy (CANCELLED)</option>
                </select>
            </div>
            <div class="col-md-6">
                <label for="PaymentStatus" class="form-label fw-bold">Thanh toán</label>
                <select class="form-select" id="PaymentStatus" name="PaymentStatus" required>
                    <option value="UNPAID" selected="@(Model.PaymentStatus == "UNPAID")">Chưa thanh toán</option>
                    <option value="PAID" selected="@(Model.PaymentStatus == "PAID")">Đã thanh toán</option>
                    <option value="REFUNDED" selected="@(Model.PaymentStatus == "REFUNDED")">Đã hoàn tiền</option>
                </select>
            </div>
        </div>

        <div class="mb-3">
            <label for="TotalPrice" class="form-label fw-bold">Tổng tiền (VNĐ)</label>
            <input type="number" class="form-control" id="TotalPrice" value="@Model.TotalPrice" disabled>
        </div>

        <button type="submit" class="btn btn-primary w-100 mt-3"><i class="bi bi-save"></i> Lưu thay đổi</button>
    </form>
</div>
