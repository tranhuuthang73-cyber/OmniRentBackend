@{
    Layout = null;
    var userName = User.Identity?.Name ?? "";
    var userEmail = User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Dashboard — OmniRent</title>
    <meta name="description" content="Trang quản trị hệ thống OmniRent dành cho Admin." />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
          crossorigin="anonymous" />
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
          rel="stylesheet" />

    <style>
        :root {
            --brand:    #6C63FF;
            --brand-lt: #9c91ff;
            --dark-1:   #0f0c29;
            --dark-2:   #1a1a3e;
            --dark-3:   #24243e;
            --text-main:#f0eeff;
            --text-sub: #a89fd8;
            --card-bg:  rgba(255,255,255,0.06);
            --card-bd:  rgba(255,255,255,0.11);
            --admin-accent: #ff6584;
        }
        html, body { min-height: 100vh; margin: 0; font-family: 'Inter', sans-serif; color: var(--text-main); }
        body { background: linear-gradient(135deg, var(--dark-1) 0%, var(--dark-2) 55%, var(--dark-3) 100%); }

        /* Navbar */
        .omni-navbar {
            background: rgba(15,12,41,0.8);
            backdrop-filter: blur(18px);
            border-bottom: 1px solid var(--card-bd);
            padding: 0.7rem 0;
            position: sticky; top: 0; z-index: 100;
        }
        .brand-icon {
            width: 34px; height: 34px;
            background: linear-gradient(135deg, var(--brand), var(--brand-lt));
            border-radius: 9px;
            display: flex; align-items: center; justify-content: center;
            box-shadow: 0 4px 12px rgba(108,99,255,0.4);
        }
        .brand-icon i { color: #fff; font-size: 1rem; }
        .brand-name {
            font-size: 1.2rem; font-weight: 700;
            background: linear-gradient(90deg, #fff, var(--brand-lt));
            -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
        }
        .role-badge {
            background: rgba(255,101,132,0.18);
            border: 1px solid rgba(255,101,132,0.35);
            color: var(--admin-accent);
            border-radius: 20px;
            font-size: 0.75rem; font-weight: 700;
            padding: 0.25rem 0.75rem;
            letter-spacing: 0.06em;
        }

        /* Logout form */
        .btn-logout {
            background: rgba(255,101,132,0.15);
            border: 1px solid rgba(255,101,132,0.35);
            color: var(--admin-accent);
            border-radius: 8px;
            font-size: 0.84rem; font-weight: 600;
            padding: 0.38rem 0.9rem;
            cursor: pointer;
            display: inline-flex; align-items: center; gap: 0.35rem;
            transition: background 0.2s;
        }
        .btn-logout:hover { background: rgba(255,101,132,0.28); }

        /* Page header */
        .page-header {
            padding: 3rem 0 2rem;
            border-bottom: 1px solid var(--card-bd);
            margin-bottom: 2.5rem;
        }
        .page-header h1 {
            font-size: 2rem; font-weight: 800;
            display: flex; align-items: center; gap: 0.6rem;
            margin-bottom: 0.35rem;
        }
        .page-header h1 .icon-circle {
            width: 44px; height: 44px;
            background: linear-gradient(135deg, var(--admin-accent), #ff8fa8);
            border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.2rem;
            box-shadow: 0 6px 18px rgba(255,101,132,0.4);
        }
        .page-header p { color: var(--text-sub); margin: 0; font-size: 0.95rem; }

        /* Stat cards */
        .stat-card {
            background: var(--card-bg);
            border: 1px solid var(--card-bd);
            border-radius: 14px;
            padding: 1.5rem;
            display: flex; align-items: center; gap: 1rem;
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .stat-card:hover { transform: translateY(-4px); box-shadow: 0 12px 30px rgba(108,99,255,0.18); }
        .stat-icon { width: 50px; height: 50px; border-radius: 13px; display: flex; align-items: center; justify-content: center; font-size: 1.4rem; flex-shrink: 0; }
        .stat-card .stat-value { font-size: 1.6rem; font-weight: 800; line-height: 1; }
        .stat-card .stat-label { font-size: 0.8rem; color: var(--text-sub); margin-top: 0.15rem; }

        /* Info alert */
        .info-banner {
            background: rgba(108,99,255,0.12);
            border: 1px solid rgba(108,99,255,0.3);
            border-radius: 12px;
            padding: 1.1rem 1.3rem;
            color: var(--text-sub);
            font-size: 0.9rem;
            display: flex; align-items: center; gap: 0.6rem;
        }
        .info-banner i { color: var(--brand-lt); font-size: 1.1rem; flex-shrink: 0; }
    </style>
</head>
<body>

    <!-- Navbar -->
    <nav class="omni-navbar">
        <div class="container d-flex align-items-center justify-content-between">
            <a href="/" class="d-flex align-items-center gap-2 text-decoration-none">
                <div class="brand-icon"><i class="bi bi-building-fill"></i></div>
                <span class="brand-name">OmniRent</span>
            </a>
            <div class="d-flex align-items-center gap-3">
                <span class="role-badge">⚡ ADMIN</span>
                <span style="color:var(--text-sub); font-size:0.85rem;">@userName</span>
                <form method="post" action="/auth/logout" style="margin:0;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-logout" id="logout-btn">
                        <i class="bi bi-box-arrow-right"></i> Đăng xuất
                    </button>
                </form>
            </div>
        </div>
    </nav>

    <!-- Content -->
    <main class="container" id="admin-dashboard-main">

        <!-- Page header -->
        <div class="page-header" id="admin-page-header">
            <h1>
                <span class="icon-circle"><i class="bi bi-shield-fill-check"></i></span>
                Admin Dashboard
            </h1>
            <p>Xin chào, <strong style="color:var(--text-main);">@userName</strong> — bạn đang đăng nhập với quyền Quản trị viên hệ thống.</p>
        </div>

        <!-- Info banner -->
        <div class="info-banner mb-4" id="admin-info-banner">
            <i class="bi bi-info-circle-fill"></i>
            <span>Đây là trang <strong style="color:var(--text-main);">Admin Dashboard</strong> sơ khai của đồ án. Các chức năng quản lý (Người dùng, Sản phẩm, Phân quyền...) sẽ được phát triển trong các sprint tiếp theo.</span>
        </div>

        <!-- Placeholder stat cards -->
        <div class="row g-3" id="admin-stat-cards">
            <div class="col-md-3 col-sm-6">
                <div class="stat-card" id="stat-users">
                    <div class="stat-icon" style="background:rgba(108,99,255,0.2);">
                        <i class="bi bi-people-fill" style="color:#9c91ff;"></i>
                    </div>
                    <div>
                        <div class="stat-value">—</div>
                        <div class="stat-label">Tổng người dùng</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="stat-card" id="stat-products">
                    <div class="stat-icon" style="background:rgba(67,233,123,0.15);">
                        <i class="bi bi-box-seam-fill" style="color:#43e97b;"></i>
                    </div>
                    <div>
                        <div class="stat-value">—</div>
                        <div class="stat-label">Sản phẩm cho thuê</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="stat-card" id="stat-bookings">
                    <div class="stat-icon" style="background:rgba(255,193,7,0.15);">
                        <i class="bi bi-calendar-check-fill" style="color:#ffc107;"></i>
                    </div>
                    <div>
                        <div class="stat-value">—</div>
                        <div class="stat-label">Đơn đặt thuê</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="stat-card" id="stat-roles">
                    <div class="stat-icon" style="background:rgba(255,101,132,0.15);">
                        <i class="bi bi-key-fill" style="color:#ff6584;"></i>
                    </div>
                    <div>
                        <div class="stat-value">—</div>
                        <div class="stat-label">Phân quyền RBAC</div>
                    </div>
                </div>
            </div>
        </div>

    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-YvpcrYf0tY3lHB60NNkmXc4s9bIOgUxi8T/jzmLCqQhN6SREfMQ2V3bM6cQBQKB"
            crossorigin="anonymous"></script>
</body>
</html>
