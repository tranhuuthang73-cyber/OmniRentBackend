@using OmniRentBackend.Models
@model IEnumerable<Booking>
@{
    ViewData["Title"] = "Quản lý Đơn hàng";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card card-custom p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="m-0 fw-bold">Danh sách Đơn hàng</h4>
        <a href="/AdminDashboard/CreateBooking" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Thêm mới</a>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Mã Đơn</th>
                    <th>Sản phẩm</th>
                    <th>Người thuê</th>
                    <th>Ngày Thuê</th>
                    <th>Ngày Trả</th>
                    <th>Tổng Tiền</th>
                    <th>Trạng thái</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if(Model != null && Model.Any())
                {
                    foreach(var item in Model)
                    {
                        <tr>
                            <td><small class="text-muted">@item.Id.Substring(0, 8)...</small></td>
                            <td>
                                <strong>@(item.Product?.Name ?? "N/A")</strong>
                            </td>
                            <td>
                                @(item.Renter?.FullName ?? "N/A")
                            </td>
                            <td>@item.StartDate.ToString("dd/MM/yyyy")</td>
                            <td>@item.EndDate.ToString("dd/MM/yyyy")</td>
                            <td class="text-danger fw-bold">@item.TotalPrice.ToString("N0")đ</td>
                            <td>
                                @if(item.Status == "PENDING") { <span class="badge bg-warning text-dark badge-status">Chờ duyệt</span> }
                                else if(item.Status == "APPROVED") { <span class="badge bg-info badge-status">Đã duyệt</span> }
                                else if(item.Status == "ONGOING") { <span class="badge bg-primary badge-status">Đang thuê</span> }
                                else if(item.Status == "COMPLETED") { <span class="badge bg-success badge-status">Hoàn thành</span> }
                                else if(item.Status == "CANCELLED" || item.Status == "REJECTED") { <span class="badge bg-danger badge-status">Đã hủy</span> }
                                else { <span class="badge bg-secondary badge-status">@item.Status</span> }
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <a href="/AdminDashboard/BookingDetails/@item.Id" class="btn btn-outline-secondary" title="Xem"><i class="bi bi-eye"></i></a>
                                    <a href="/AdminDashboard/EditBooking/@item.Id" class="btn btn-outline-primary" title="Sửa"><i class="bi bi-pencil"></i></a>
                                    <form action="/AdminDashboard/DeleteBooking/@item.Id" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc chắn muốn xóa đơn hàng này?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-danger" title="Xóa"><i class="bi bi-trash"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-center py-4 text-muted">Chưa có đơn hàng nào.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
