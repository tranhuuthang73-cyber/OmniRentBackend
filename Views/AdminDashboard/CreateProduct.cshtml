@using OmniRentBackend.Models
@model dynamic
@{
    ViewData["Title"] = "Thêm Sản phẩm";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var categories = (List<Category>)ViewBag.Categories;
}

<style>
    /* ====== Page-specific styles for CreateProduct ====== */
    .page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.5rem;
    }
    .page-header h4 {
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--text-primary);
        margin: 0;
    }
    .page-header .breadcrumb-text {
        font-size: 0.75rem;
        color: var(--text-muted);
        margin-top: 2px;
    }

    .section-divider {
        display: flex;
        align-items: center;
        gap: 0.65rem;
        margin: 1.75rem 0 1.1rem;
    }
    .section-divider .divider-icon {
        width: 28px;
        height: 28px;
        background: var(--primary-light, #ebf0ff);
        border-radius: 7px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--primary, #1a56db);
        font-size: 0.85rem;
        flex-shrink: 0;
    }
    .section-divider .divider-label {
        font-size: 0.82rem;
        font-weight: 700;
        color: var(--text-primary, #0f172a);
        letter-spacing: 0.2px;
    }
    .section-divider::after {
        content: '';
        flex: 1;
        height: 1px;
        background: var(--border-color, #e2e8f0);
    }

    /* Image preview */
    .image-preview {
        display: inline-block;
        margin-right: 8px;
        margin-bottom: 8px;
        position: relative;
    }
    .image-preview img {
        width: 90px;
        height: 90px;
        object-fit: cover;
        border-radius: 8px;
        border: 1.5px solid var(--border-color, #e2e8f0);
    }
    .image-preview .remove-btn {
        position: absolute;
        top: 4px;
        right: 4px;
        background-color: rgba(220,38,38,0.85);
        color: white;
        border: none;
        border-radius: 50%;
        width: 22px;
        height: 22px;
        cursor: pointer;
        font-size: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.2s;
    }
    .image-preview .remove-btn:hover {
        background-color: #dc2626;
    }

    /* Drop zone */
    .drop-zone {
        border: 2px dashed #93c5fd;
        border-radius: 10px;
        padding: 24px;
        text-align: center;
        cursor: pointer;
        background-color: #f0f7ff;
        transition: all 0.25s ease;
        color: var(--text-secondary, #475569);
    }
    .drop-zone:hover, .drop-zone.drag-over {
        border-color: var(--primary, #1a56db);
        background-color: #dbeafe;
    }
    .drop-zone i {
        color: var(--primary, #1a56db);
        font-size: 1.4rem;
        margin-bottom: 6px;
        display: block;
    }

    /* URL row */
    .image-url-row {
        animation: fadeIn 0.2s ease;
    }
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(-4px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    /* Form actions bar */
    .form-actions {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 2rem;
        padding-top: 1.25rem;
        border-top: 1px solid var(--border-color, #e2e8f0);
    }
</style>

<!-- Page Header -->
<div class="page-header">
    <div>
        <h4><i class="bi bi-plus-circle me-2" style="color:var(--primary)"></i>Thêm Sản phẩm Mới</h4>
        <div class="breadcrumb-text">Sản phẩm &rsaquo; Thêm mới</div>
    </div>
</div>

<div class="card-custom p-4">
    <form method="post" enctype="multipart/form-data" id="productForm">
        @Html.AntiForgeryToken()

        <!-- Thông tin cơ bản -->
        <div class="section-divider">
            <div class="divider-icon"><i class="bi bi-info-circle"></i></div>
            <span class="divider-label">Thông tin cơ bản</span>
        </div>

        <div class="row mb-3">
            <div class="col-md-6 mb-3 mb-md-0">
                <label for="Name" class="form-label">Tên Sản phẩm <span class="text-danger">*</span></label>
                <input type="text" class="form-control" id="Name" name="Name" required placeholder="Ví dụ: Laptop Dell XPS 13, iPhone 15 Pro...">
                <div class="form-text">Nhập tên đầy đủ và chính xác của sản phẩm.</div>
            </div>
            <div class="col-md-6">
                <label for="CategoryId" class="form-label">Danh mục <span class="text-danger">*</span></label>
                <select class="form-control" id="CategoryId" name="CategoryId" required>
                    <option value="">-- Chọn danh mục --</option>
                    @if (categories != null && categories.Any())
                    {
                        foreach (var parent in categories)
                        {
                            <optgroup label="@parent.Name">
                                @if (parent.Subcategories != null && parent.Subcategories.Any())
                                {
                                    foreach (var sub in parent.Subcategories)
                                    {
                                        <option value="@sub.Id">@sub.Name</option>
                                    }
                                }
                            </optgroup>
                        }
                    }
                </select>
            </div>
        </div>

        <div class="mb-3">
            <label for="Description" class="form-label">Mô tả Chi tiết</label>
            <textarea class="form-control" id="Description" name="Description" rows="4" placeholder="Nhập mô tả đầy đủ về sản phẩm, điều kiện, tính năng..."></textarea>
        </div>

        <!-- Giá & Sở hữu -->
        <div class="section-divider">
            <div class="divider-icon"><i class="bi bi-currency-exchange"></i></div>
            <span class="divider-label">Giá cả & Trạng thái</span>
        </div>

        <div class="row mb-3">
            <div class="col-md-6 mb-3 mb-md-0">
                <label for="PricePerDay" class="form-label">Giá thuê / Ngày (đ)</label>
                <input type="number" class="form-control" id="PricePerDay" name="PricePerDay" step="1000" min="0" placeholder="50,000">
            </div>
            <div class="col-md-6 mb-3 mb-md-0">
                <label for="DepositAmount" class="form-label">Tiền Cọc (đ)</label>
                <div class="input-group">
                    <select class="form-select" id="DepositPercentage" style="max-width: 110px;" title="Gợi ý mức cọc">
                        <option value="">Tùy chỉnh</option>
                        <option value="30">30%</option>
                        <option value="50">50%</option>
                        <option value="70">70%</option>
                    </select>
                    <input type="number" class="form-control" id="DepositAmount" name="DepositAmount" step="1000" min="0" placeholder="500000">
                </div>
            </div>
        </div>

        <div class="mb-3" style="max-width: 280px;">
            <label for="Status" class="form-label">Trạng thái</label>
            <select class="form-control" id="Status" name="Status">
                <option value="AVAILABLE">✅ Có sẵn</option>
                <option value="PENDING_APPROVAL">⏳ Chờ duyệt</option>
                <option value="MAINTENANCE">🔧 Bảo trì</option>
                <option value="RENTED">📦 Đang cho thuê</option>
            </select>
        </div>

        <!-- Ảnh sản phẩm -->
        <div class="section-divider">
            <div class="divider-icon"><i class="bi bi-images"></i></div>
            <span class="divider-label">Ảnh Sản phẩm (Link URL)</span>
        </div>

        <div class="drop-zone mb-3">
            <i class="bi bi-link-45deg"></i>
            <div style="font-size:0.82rem; font-weight:600;">Dán link ảnh bên dưới</div>
            <div style="font-size:0.75rem; margin-top:2px;">Hỗ trợ URL từ bất kỳ nguồn ảnh nào</div>
        </div>

        <div id="imageUrlsContainer">
            <div class="image-url-row d-flex gap-2 mb-2" id="urlRow_0">
                <input type="text" class="form-control" name="ImageUrls" placeholder="https://example.com/image.jpg" oninput="previewUrlImage(this, 0)">
                <button type="button" class="btn btn-outline-danger" onclick="removeUrlRow(0)" title="Xóa"><i class="bi bi-trash"></i></button>
            </div>
        </div>
        <button type="button" class="btn btn-outline-secondary btn-sm mt-1" onclick="addUrlRow()">
            <i class="bi bi-plus-circle"></i> Thêm link ảnh
        </button>

        <div id="imagePreviewContainer" class="mt-3" style="display: none;">
            <div style="font-size:0.78rem; font-weight:600; color:var(--text-secondary); margin-bottom:0.5rem;">Xem trước ảnh:</div>
            <div id="previewsList" class="d-flex flex-wrap gap-2"></div>
        </div>

        <!-- Actions -->
        <div class="form-actions">
            <a href="/AdminDashboard/Products" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Quay lại
            </a>
            <button type="submit" class="btn btn-success px-4" id="submitBtn">
                <i class="bi bi-check-circle"></i> Thêm Sản phẩm
            </button>
        </div>
    </form>
</div>

<script>
    let urlRowCount = 1;

    function addUrlRow() {
        const container = document.getElementById('imageUrlsContainer');
        const idx = urlRowCount++;
        const div = document.createElement('div');
        div.className = 'image-url-row d-flex gap-2 mb-2';
        div.id = 'urlRow_' + idx;
        div.innerHTML = `
            <input type="text" class="form-control" name="ImageUrls" placeholder="https://example.com/image.jpg" oninput="previewUrlImage(this, ${idx})">
            <button type="button" class="btn btn-outline-danger" onclick="removeUrlRow(${idx})" title="Xóa"><i class="bi bi-trash"></i></button>
        `;
        container.appendChild(div);
    }

    function removeUrlRow(idx) {
        const row = document.getElementById('urlRow_' + idx);
        if (row) {
            row.remove();
            updateUrlPreviews();
        }
    }

    function previewUrlImage(input, idx) {
        updateUrlPreviews();
    }

    function updateUrlPreviews() {
        const inputs = document.querySelectorAll('#imageUrlsContainer input[name="ImageUrls"]');
        const container = document.getElementById('previewsList');
        container.innerHTML = '';
        let hasUrl = false;
        inputs.forEach(function (inp) {
            const url = inp.value.trim();
            if (url) {
                hasUrl = true;
                const div = document.createElement('div');
                div.className = 'image-preview';
                div.innerHTML = `<img src="${url}" alt="Preview" onerror="this.src=''; this.style.border='2px solid red';" />`;
                container.appendChild(div);
            }
        });
        document.getElementById('imagePreviewContainer').style.display = hasUrl ? 'block' : 'none';
    }

    document.getElementById('DepositPercentage').addEventListener('change', function() {
        var percentage = this.value;
        var priceStr = document.getElementById('PricePerDay').value;
        if (percentage && priceStr) {
            var price = parseFloat(priceStr);
            if (!isNaN(price)) {
                document.getElementById('DepositAmount').value = price * (percentage / 100);
            }
        }
    });

    document.getElementById('PricePerDay').addEventListener('input', function() {
        var percentage = document.getElementById('DepositPercentage').value;
        var priceStr = this.value;
        if (percentage && priceStr) {
            var price = parseFloat(priceStr);
            if (!isNaN(price)) {
                document.getElementById('DepositAmount').value = price * (percentage / 100);
            }
        }
    });

    // Form validation — chỉ bắt buộc Tên
    document.getElementById('productForm').addEventListener('submit', function (e) {
        const name = document.getElementById('Name').value.trim();
        if (!name) {
            e.preventDefault();
            alert('Vui lòng nhập tên sản phẩm');
            return false;
        }
    });
</script>
