@using OmniRentBackend.Models
@model dynamic
@{
    ViewData["Title"] = "Thêm Sản phẩm";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var categories = (List<Category>)ViewBag.Categories;
    var owners = (List<User>)ViewBag.Owners;
}

<style>
    .image-preview {
        display: inline-block;
        margin-right: 10px;
        margin-bottom: 10px;
        position: relative;
    }
    .image-preview img {
        width: 100px;
        height: 100px;
        object-fit: cover;
        border-radius: 4px;
        border: 1px solid #ddd;
    }
    .image-preview .remove-btn {
        position: absolute;
        top: 5px;
        right: 5px;
        background-color: rgba(255, 0, 0, 0.8);
        color: white;
        border: none;
        border-radius: 50%;
        width: 25px;
        height: 25px;
        cursor: pointer;
        font-size: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .image-preview .remove-btn:hover {
        background-color: rgba(255, 0, 0, 1);
    }
    .drop-zone {
        border: 2px dashed #007bff;
        border-radius: 4px;
        padding: 30px;
        text-align: center;
        cursor: pointer;
        background-color: #f8f9fa;
        transition: all 0.3s ease;
    }
    .drop-zone:hover {
        border-color: #0056b3;
        background-color: #e7f1ff;
    }
    .drop-zone.drag-over {
        border-color: #0056b3;
        background-color: #e7f1ff;
    }
    .form-section-title {
        font-size: 0.95rem;
        font-weight: bold;
        color: #333;
        margin-top: 20px;
        margin-bottom: 15px;
        padding-bottom: 10px;
        border-bottom: 2px solid #007bff;
    }
</style>

<div class="card card-custom p-4">
    <h4 class="mb-4 fw-bold">Thêm Sản phẩm Mới</h4>

    <form method="post" enctype="multipart/form-data" id="productForm">
        @Html.AntiForgeryToken()

        <div class="row mb-4">
            <div class="col-md-6">
                <label for="Name" class="form-label fw-bold">Tên Sản phẩm <span class="text-danger">*</span></label>
                <input type="text" class="form-control" id="Name" name="Name" required placeholder="Nhập tên sản phẩm">
                <small class="form-text text-muted">Ví dụ: Laptop Dell XPS 13, iPhone 15 Pro, ...</small>
            </div>
            <div class="col-md-6">
                <label for="CategoryId" class="form-label fw-bold">Danh mục <span class="text-danger">*</span></label>
                <select class="form-control" id="CategoryId" name="CategoryId" required>
                    <option value="">-- Chọn danh mục --</option>
                    @if (categories != null && categories.Any())
                    {
                        foreach (var cat in categories)
                        {
                            <option value="@cat.Id">@cat.Name</option>
                        }
                    }
                </select>
            </div>
        </div>

        <div class="mb-4">
            <label for="Description" class="form-label fw-bold">Mô tả Chi tiết</label>
            <textarea class="form-control" id="Description" name="Description" rows="4" placeholder="Nhập mô tả đầy đủ về sản phẩm, điều kiện, tính năng..."></textarea>
        </div>

        <div class="row mb-4">
            <div class="col-md-4">
                <label for="PricePerDay" class="form-label fw-bold">Giá cho thuê/Ngày (đ)</label>
                <input type="number" class="form-control" id="PricePerDay" name="PricePerDay" step="1000" min="0" placeholder="50000">
            </div>
            <div class="col-md-4">
                <label for="DepositAmount" class="form-label fw-bold">Tiền Cọc (đ)</label>
                <input type="number" class="form-control" id="DepositAmount" name="DepositAmount" step="1000" min="0" placeholder="500000">
            </div>
            <div class="col-md-4">
                <label for="OwnerId" class="form-label fw-bold">Chủ sở hữu</label>
                <select class="form-control" id="OwnerId" name="OwnerId">
                    <option value="">-- Chọn chủ sở hữu --</option>
                    @if (owners != null && owners.Any())
                    {
                        foreach (var owner in owners)
                        {
                            <option value="@owner.Id">@owner.FullName (@owner.Email)</option>
                        }
                    }
                </select>
            </div>
        </div>

        <div class="mb-4">
            <label for="Status" class="form-label fw-bold">Trạng thái</label>
            <select class="form-control" id="Status" name="Status">
                <option value="AVAILABLE">Có sẵn</option>
                <option value="PENDING_APPROVAL">Chờ duyệt</option>
                <option value="MAINTENANCE">Bảo trì</option>
                <option value="RENTED">Đang cho thuê</option>
            </select>
        </div>

        <div class="form-section-title">
            <i class="bi bi-image"></i> Ảnh Sản phẩm (Link URL)
        </div>

        <div id="imageUrlsContainer">
            <div class="image-url-row d-flex gap-2 mb-2" id="urlRow_0">
                <input type="text" class="form-control" name="ImageUrls" placeholder="https://example.com/image.jpg" oninput="previewUrlImage(this, 0)">
                <button type="button" class="btn btn-outline-danger" onclick="removeUrlRow(0)" title="Xóa"><i class="bi bi-trash"></i></button>
            </div>
        </div>
        <button type="button" class="btn btn-outline-secondary btn-sm mt-2" onclick="addUrlRow()">
            <i class="bi bi-plus-circle"></i> Thêm link ảnh
        </button>

        <div id="imagePreviewContainer" class="mt-4" style="display: none;">
            <h6 class="fw-bold mb-3">Xem trước ảnh:</h6>
            <div id="previewsList" class="d-flex flex-wrap gap-2"></div>
        </div>

        <div class="d-flex justify-content-between mt-5">
            <a href="/AdminDashboard/Products" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Quay lại
            </a>
            <button type="submit" class="btn btn-success" id="submitBtn">
                <i class="bi bi-check-circle"></i> Thêm Sản phẩm
            </button>
        </div>
    </form>
</div>

<script>
    let urlRowCount = 1;

    function addUrlRow() {
        const container = document.getElementById('imageUrlsContainer');
        const idx = urlRowCount++;
        const div = document.createElement('div');
        div.className = 'image-url-row d-flex gap-2 mb-2';
        div.id = 'urlRow_' + idx;
        div.innerHTML = `
            <input type="text" class="form-control" name="ImageUrls" placeholder="https://example.com/image.jpg" oninput="previewUrlImage(this, ${idx})">
            <button type="button" class="btn btn-outline-danger" onclick="removeUrlRow(${idx})" title="Xóa"><i class="bi bi-trash"></i></button>
        `;
        container.appendChild(div);
    }

    function removeUrlRow(idx) {
        const row = document.getElementById('urlRow_' + idx);
        if (row) {
            row.remove();
            updateUrlPreviews();
        }
    }

    function previewUrlImage(input, idx) {
        updateUrlPreviews();
    }

    function updateUrlPreviews() {
        const inputs = document.querySelectorAll('#imageUrlsContainer input[name="ImageUrls"]');
        const container = document.getElementById('previewsList');
        container.innerHTML = '';
        let hasUrl = false;
        inputs.forEach(function (inp) {
            const url = inp.value.trim();
            if (url) {
                hasUrl = true;
                const div = document.createElement('div');
                div.className = 'image-preview';
                div.innerHTML = `<img src="${url}" alt="Preview" onerror="this.src=''; this.style.border='2px solid red';" />`;
                container.appendChild(div);
            }
        });
        document.getElementById('imagePreviewContainer').style.display = hasUrl ? 'block' : 'none';
    }

    // Form validation — chỉ bắt buộc Tên
    document.getElementById('productForm').addEventListener('submit', function (e) {
        const name = document.getElementById('Name').value.trim();
        if (!name) {
            e.preventDefault();
            alert('Vui lòng nhập tên sản phẩm');
            return false;
        }
    });
</script>
