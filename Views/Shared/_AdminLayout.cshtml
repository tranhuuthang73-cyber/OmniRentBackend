<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Dashboard</title>

    <!-- Google Fonts: Inter -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>
        /* ============================================
           OMNIRENT ADMIN - Light Professional Theme
           Palette: Navy Blue + Slate Gray + Clean White
           ============================================ */
        :root {
            --primary:        #1d4ed8;      /* Main blue for buttons and active states */
            --primary-dark:   #1e40af;
            --primary-light:  #dbeafe;
            --accent:         #0f766e;
            --sidebar-bg:     #0f172a;      /* Navy dark sidebar */
            --sidebar-hover:  #1e293b;      /* Sidebar hover row */
            --sidebar-text:   #dbe4f0;      /* Readable slate text */
            --sidebar-active: #ffffff;      /* Active nav text */
            --sidebar-border: rgba(255,255,255,0.06);
            --admin-bg:       #f3f6fb;      /* Light slate background */
            --card-bg:        #ffffff;
            --card-shadow:    0 1px 3px rgba(15,23,42,0.08), 0 4px 16px rgba(15,23,42,0.04);
            --topbar-shadow:  0 1px 0 #e2e8f0;
            --text-primary:   #0f172a;      /* Near-black */
            --text-secondary: #334155;      /* High-contrast secondary text */
            --text-muted:     #64748b;      /* Readable muted text */
            --border-color:   #e2e8f0;
            --input-focus:    0 0 0 3px rgba(37,99,235,0.16);
            --success:        #16a34a;
            --danger:         #dc2626;
            --warning:        #d97706;
        }

        * { box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #f3f6fb;
            background-color: var(--admin-bg, #f3f6fb);
            color: #0f172a;
            color: var(--text-primary, #0f172a);
            margin: 0;
            padding: 0;
            display: flex;
            min-height: 100vh;
            font-size: 14px;
            line-height: 1.6;
        }

        /* ===================== SIDEBAR ===================== */
        .sidebar {
            width: 256px;
            background-color: #0f172a;
            background-color: var(--sidebar-bg, #0f172a);
            position: fixed;
            height: 100vh;
            overflow-y: auto;
            transition: transform 0.3s ease;
            z-index: 1000;
            display: flex;
            flex-direction: column;
        }

        .sidebar-header {
            padding: 1.75rem 1.5rem 1.25rem;
            border-bottom: 1px solid rgba(255,255,255,0.06);
            border-bottom-color: var(--sidebar-border, rgba(255,255,255,0.06));
        }

        .sidebar-header h4 {
            color: #f8fafc;
            font-weight: 800;
            font-size: 1.15rem;
            margin: 0;
            letter-spacing: -0.3px;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .sidebar-header h4 .logo-icon {
            width: 30px;
            height: 30px;
            background: #1d4ed8;
            background: var(--primary, #1d4ed8);
            border-radius: 8px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 0.9rem;
            color: white;
        }

        .sidebar-header small {
            color: #dbe4f0;
            color: var(--sidebar-text, #dbe4f0);
            font-size: 0.72rem;
            margin-top: 3px;
            display: block;
            text-transform: uppercase;
            letter-spacing: 0.8px;
        }

        .nav-section-label {
            padding: 1.25rem 1.5rem 0.4rem;
            font-size: 0.65rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #cbd5e1;
        }

        .nav-link {
            color: #dbe4f0;
            color: var(--sidebar-text, #dbe4f0);
            padding: 0.7rem 1.5rem;
            display: flex;
            align-items: center;
            gap: 0.7rem;
            transition: all 0.2s ease;
            border-radius: 0;
            font-size: 0.875rem;
            font-weight: 500;
            margin: 1px 0.5rem;
            border-radius: 8px;
        }

        .nav-link:hover {
            color: #f1f5f9;
            background-color: #1e293b;
            background-color: var(--sidebar-hover, #1e293b);
            text-decoration: none;
        }

        .nav-link.active {
            color: #ffffff;
            color: var(--sidebar-active, #ffffff);
            background-color: #1d4ed8;
            background-color: var(--primary, #1d4ed8);
            text-decoration: none;
            box-shadow: 0 8px 18px rgba(29,78,216,0.25);
        }

        .nav-link i {
            font-size: 1.05rem;
            width: 20px;
            text-align: center;
            flex-shrink: 0;
        }

        .sidebar-footer {
            margin-top: auto;
            padding: 1rem 0.5rem;
            border-top: 1px solid rgba(255,255,255,0.06);
            border-top-color: var(--sidebar-border, rgba(255,255,255,0.06));
        }

        /* ===================== MAIN CONTENT ===================== */
        .main-content {
            flex-grow: 1;
            margin-left: 256px;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            width: calc(100% - 256px);
        }

        .topbar {
            background-color: #ffffff;
            background-color: var(--card-bg, #ffffff);
            padding: 0.875rem 2rem;
            box-shadow: 0 1px 0 #e2e8f0;
            box-shadow: var(--topbar-shadow, 0 1px 0 #e2e8f0);
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 900;
        }

        .topbar h5 {
            font-weight: 700;
            font-size: 1rem;
            color: #0f172a;
            color: var(--text-primary, #0f172a);
            margin: 0;
        }

        .topbar-right {
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .admin-avatar {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: #1d4ed8;
            background: var(--primary, #1d4ed8);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.75rem;
            font-weight: 700;
        }

        .content-body {
            padding: 1.75rem 2rem 2.5rem;
            flex-grow: 1;
        }

        /* ===================== CARDS ===================== */
        .card-custom {
            background: #ffffff;
            background: var(--card-bg, #ffffff);
            border-radius: 8px;
            box-shadow: 0 1px 3px rgba(15,23,42,0.08), 0 4px 16px rgba(15,23,42,0.04);
            box-shadow: var(--card-shadow, 0 1px 3px rgba(15,23,42,0.08), 0 4px 16px rgba(15,23,42,0.04));
            border: 1px solid #e2e8f0;
            border-color: var(--border-color, #e2e8f0);
        }

        /* ===================== FORMS ===================== */
        .form-label {
            color: #0f172a;
            color: var(--text-primary, #0f172a);
            font-weight: 600;
            font-size: 0.82rem;
            margin-bottom: 0.35rem;
        }

        .form-control, .form-select {
            border: 1.5px solid #cbd5e1;
            border-color: var(--border-color, #cbd5e1);
            border-radius: 8px;
            color: #0f172a;
            color: var(--text-primary, #0f172a);
            font-size: 0.875rem;
            padding: 0.5rem 0.75rem;
            background-color: #fff;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

        .form-control:focus, .form-select:focus {
            border-color: #1d4ed8;
            border-color: var(--primary, #1d4ed8);
            box-shadow: 0 0 0 3px rgba(29,78,216,0.16);
            box-shadow: var(--input-focus, 0 0 0 3px rgba(29,78,216,0.16));
            outline: none;
            color: #0f172a;
            color: var(--text-primary, #0f172a);
        }

        .form-control::placeholder {
            color: #64748b;
            color: var(--text-muted, #64748b);
        }

        .form-text {
            font-size: 0.75rem;
            color: #64748b;
            color: var(--text-muted, #64748b);
            margin-top: 0.3rem;
        }

        /* ===================== BUTTONS ===================== */
        .btn-primary {
            background-color: #1d4ed8;
            background-color: var(--primary, #1d4ed8);
            border-color: #1d4ed8;
            border-color: var(--primary, #1d4ed8);
            color: #ffffff !important;
            font-weight: 700;
            border-radius: 8px;
            transition: all 0.2s;
            min-height: 38px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.45rem;
            box-shadow: 0 6px 14px rgba(29,78,216,0.22);
        }
        .btn-primary:hover {
            background-color: #1e40af;
            background-color: var(--primary-dark, #1e40af);
            border-color: #1e40af;
            border-color: var(--primary-dark, #1e40af);
            transform: translateY(-1px);
            color: #ffffff !important;
            box-shadow: 0 8px 18px rgba(29,78,216,0.28);
        }

        .btn-success {
            background-color: #16a34a;
            background-color: var(--success, #16a34a);
            border-color: #16a34a;
            border-color: var(--success, #16a34a);
            color: #ffffff !important;
            font-weight: 700;
            border-radius: 8px;
            transition: all 0.2s;
            min-height: 38px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.45rem;
        }
        .btn-success:hover {
            background-color: #15803d;
            border-color: #15803d;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(22,163,74,0.3);
        }

        .btn-secondary {
            background-color: #f1f5f9;
            border-color: #cbd5e1;
            border-color: var(--border-color, #cbd5e1);
            color: #334155;
            color: var(--text-secondary, #334155);
            font-weight: 600;
            border-radius: 8px;
            transition: all 0.2s;
            min-height: 38px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.45rem;
        }
        .btn-secondary:hover {
            background-color: #e2e8f0;
            border-color: #cbd5e1;
            color: var(--text-primary);
        }

        .btn-outline-danger {
            color: #dc2626;
            color: var(--danger, #dc2626);
            border-color: #fca5a5;
            border-radius: 8px;
            font-weight: 500;
            transition: all 0.2s;
            min-height: 38px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.45rem;
        }
        .btn-outline-danger:hover {
            background-color: #fef2f2;
            border-color: var(--danger);
            color: var(--danger);
        }

        .btn-outline-secondary {
            color: #334155;
            color: var(--text-secondary, #334155);
            border-color: #cbd5e1;
            border-color: var(--border-color, #cbd5e1);
            border-radius: 8px;
            font-weight: 500;
            min-height: 38px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.45rem;
        }
        .btn-outline-secondary:hover {
            background-color: #f1f5f9;
            border-color: #cbd5e1;
            color: var(--text-primary);
        }

        /* ===================== BADGES ===================== */
        .badge-status {
            padding: 0.35em 0.8em;
            border-radius: 50px;
            font-weight: 600;
            font-size: 0.72rem;
        }

        /* ===================== TABLES ===================== */
        .table {
            color: #0f172a;
            color: var(--text-primary, #0f172a);
        }
        .table thead th {
            background-color: #eef2f7;
            color: #0f172a;
            color: var(--text-primary, #0f172a);
            font-size: 0.72rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border-bottom: 1px solid #cbd5e1;
            border-bottom-color: var(--border-color, #cbd5e1);
            padding: 0.8rem 1rem;
        }
        .table tbody td {
            padding: 0.85rem 1rem;
            vertical-align: middle;
            border-color: #f1f5f9;
            color: #0f172a;
            color: var(--text-primary, #0f172a);
            font-size: 0.875rem;
        }
        .table tbody tr:hover {
            background-color: #f1f5f9;
        }

        /* ===================== TEXT UTILITIES ===================== */
        .text-muted {
            color: #64748b !important;
            color: var(--text-muted, #64748b) !important;
        }
        .text-danger {
            color: var(--danger) !important;
        }
        .text-success {
            color: var(--success) !important;
        }

        /* ===================== SCROLLBAR ===================== */
        .sidebar::-webkit-scrollbar { width: 4px; }
        .sidebar::-webkit-scrollbar-track { background: transparent; }
        .sidebar::-webkit-scrollbar-thumb { background: #334155; border-radius: 4px; }

        @@media (max-width: 768px) {
            .sidebar { transform: translateX(-256px); }
            .main-content { margin-left: 0; width: 100%; }
        }
    </style>
</head>
<body>
    <!-- Sidebar -->
    <nav class="sidebar">
        <div class="sidebar-header">
            <h4>
                <span class="logo-icon"><i class="bi bi-building-fill"></i></span>
                OmniRent
            </h4>
            <small>Admin Panel</small>
        </div>
        <div class="nav flex-column mt-2 px-0">
            @{
                var currentPath = Context.Request.Path.Value ?? "";
                var isDashboard = currentPath == "/AdminDashboard" || currentPath == "/AdminDashboard/";
                var isBookings = currentPath.StartsWith("/AdminDashboard/Booking") || currentPath.StartsWith("/AdminDashboard/CreateBooking") || currentPath.StartsWith("/AdminDashboard/EditBooking");
                var isProducts = currentPath.StartsWith("/AdminDashboard/Product") || currentPath.StartsWith("/AdminDashboard/CreateProduct") || currentPath.StartsWith("/AdminDashboard/EditProduct");
            }
            <span class="nav-section-label">Menu chính</span>
            <a href="/AdminDashboard" class="nav-link @(isDashboard ? "active" : "")">
                <i class="bi bi-speedometer2"></i> Dashboard
            </a>
            <a href="/AdminDashboard/Bookings" class="nav-link @(isBookings ? "active" : "")">
                <i class="bi bi-receipt"></i> Đơn hàng
            </a>
            <a href="/AdminDashboard/Products" class="nav-link @(isProducts ? "active" : "")">
                <i class="bi bi-box-seam"></i> Sản phẩm
            </a>
        </div>
        <div class="sidebar-footer">
            <a href="/" class="nav-link">
                <i class="bi bi-box-arrow-left"></i> Về trang chủ
            </a>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="main-content">
        <header class="topbar">
            <h5>@ViewData["Title"]</h5>
            <div class="topbar-right">
                <span class="text-muted" style="font-size:0.82rem;">Xin chào, <strong style="color:var(--text-primary)">Admin</strong></span>
                <div class="admin-avatar">AD</div>
            </div>
        </header>

        <main class="content-body">
            @RenderBody()
        </main>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

